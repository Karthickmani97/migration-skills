        }

        public string? Notes
        {
            get => _notes;
            set => SetProperty(ref _notes, value);
        }

        public event PropertyChangedEventHandler? PropertyChanged;

        protected void OnPropertyChanged([CallerMemberName] string? propertyName = null)
            => PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));

        /// <summary>
        /// Sets the field to the provided value and raises PropertyChanged if the value changed.
        /// Returns true if the value was changed; otherwise false.
        /// </summary>
        protected bool SetProperty<T>(ref T field, T value, [CallerMemberName] string? propertyName = null)
        {
            if (Equals(field, value)) return false;
            field = value;
            OnPropertyChanged(propertyName);
            return true;
        }
    }

    public void OnRowSelected(RowSelectEventArgs<TaskData> args)
    {
        SelectedRowIndex = args.RowIndex;
        SelectedRecord = args.Data;
        if (!SelectedRowIndexes.Contains(args.RowIndex))
        {
            SelectedRowIndexes.Add(args.RowIndex);
        }
    }
    public void CustomMultiOutdent()
    {
        if (!SelectedRowIndexes.Any())
            return;
        foreach (int index in SelectedRowIndexes)
        {
            TaskCollection[index].ParentId = null; // root
        }
    }
    public void CustomMultiIndent()
    {
        if (!SelectedRowIndexes.Any())
            return;

        // Sort to ensure correct order
        SelectedRowIndexes.Sort();

        int firstIndex = SelectedRowIndexes.First();

        // Boundary check
        if (firstIndex - 1 < 0 || firstIndex >= TaskCollection.Count)
            return;

        // Determine new parent
        var newParentId = TaskCollection[firstIndex - 1].TaskID;

        // 1️⃣ Reset parent to root before indent
        // foreach (int index in SelectedRowIndexes)
        // {
        //     TaskCollection[index].ParentId = null; // root
        // }

        // 2️⃣ Indent all selected rows under same parent
        foreach (int index in SelectedRowIndexes)
        {
            TaskCollection[index].ParentId = newParentId;
        }
    }

    public void CustomDescEdit()
    {
        var task = TaskCollection[SelectedRowIndex];

        if (task != null)
        {
            task.TaskName = $"Task {task.TaskID}";
        }

    }
    public async Task ClearPredecessors()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }

        var task = TaskCollection[SelectedRowIndex];
        // task.TaskName = "updated";
        task.Predecessor = null;
        // await Gantt.UpdateRecordByIDAsync(task);
    }
    public async void ChangeData()
    {
        isFirst = !isFirst;
        this.TaskCollection = GetTaskCollection();
    }
    public void CustomAdd()
    {
        var newTask = new TaskData() { TaskID = 100, TaskName = "Estimation approval", StartDate = new DateTime(2024, 04, 26), Duration = "1", EndDate = new DateTime(2024, 04, 27), Progress = 30 };
        if (SelectedRowIndex >= TaskCollection.Count - 1)
        {
            TaskCollection.Add(newTask);
        }
        else
        {
            TaskCollection.Insert(SelectedRowIndex + 1, newTask);
        }
        // this.scrollIndex = SelectedRowIndex;
        // this.dataReassign = true;
    }
    public void EmptyGantt()
    {
        TaskCollection.Clear();
    }
    public void DeleteTaskRemoveAt()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }
        TaskCollection.RemoveAt(SelectedRowIndex);
    }
    public void DeleteTaskRemove()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }
        TaskCollection.Remove(TaskCollection[SelectedRowIndex]);
    }
    public void RemoveExpand()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }
        TaskCollection[SelectedRowIndex].IsExpanded = !TaskCollection[SelectedRowIndex].IsExpanded;
    }
    public async Task DataBoundEvent()
    {
        if (this.dataReassign)
        {
            this.Gantt.ScrollIntoViewAsync(0, this.scrollIndex);
            this.dataReassign = false;
        }
    }

    public async void CustomIndent()
    {
        if (SelectedRowIndex - 1 < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }

        var SelectedRecords = await Gantt.GetSelectedRecordsAsync();

        // Get selected record from VIEW
       
        var CurrentViewRecords = Gantt.GetCurrentViewRecords();
        var actualRecord = TaskCollection.FirstOrDefault(x => x.TaskID == SelectedRecord.TaskID);
        int actualIndex = CurrentViewRecords
            .Select((item, index) => new { item, index })
            .FirstOrDefault(x => x.item.TaskID == SelectedRecord.TaskID)
            ?.index ?? -1;
        actualRecord?.ParentId = CurrentViewRecords[actualIndex - 1].TaskID;
    }

    public async void CustomOutdent()
    {
        var SelectedRecords = await Gantt.GetSelectedRecordsAsync();

        
        // Get the actual data record
        var CurrentViewRecords = Gantt.GetCurrentViewRecords();
        var actualRecord = TaskCollection.FirstOrDefault(x => x.TaskID == SelectedRecord.TaskID);

        var actualIndex = CurrentViewRecords.FindIndex(x => x.TaskID == SelectedRecord.TaskID);

        if (actualRecord == null)
        {
            return;
        }

        // Update ParentId (Outdent logic)
        actualRecord.ParentId = TaskCollection
            .FirstOrDefault(o => o.TaskID == actualRecord.ParentId)
            ?.ParentId;
    }

    public void AddTask_OC()
    {
        var newTask = new TaskData
        {
            TaskID = TaskCollection.Max(t => t.TaskID) + 1,
            TaskName = "New Task (Add)",
            StartDate = DateTime.Today,
            Duration = "1"
        };

        TaskCollection.Add(newTask);
    }

    public void InsertTask_OC()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
            return;

        var newTask = new TaskData
        {
            TaskID = TaskCollection.Max(t => t.TaskID) + 1,
            TaskName = "Inserted Task",
            StartDate = DateTime.Today,
            Duration = "1",
            ParentId = TaskCollection[SelectedRowIndex].ParentId
        };

        TaskCollection.Insert(SelectedRowIndex + 1, newTask);
    }
    public void RemoveTask_OC()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
            return;

        var task = TaskCollection[SelectedRowIndex];
        TaskCollection.Remove(task);
    }
    public void RemoveAt_OC()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
            return;

        TaskCollection.RemoveAt(SelectedRowIndex);
    }
    public void MoveTask_OC()
    {
        if (SelectedRowIndex <= 0 || SelectedRowIndex >= TaskCollection.Count)
            return;

        // Move selected task one position up
        TaskCollection.Move(SelectedRowIndex, SelectedRowIndex - 1);
    }
    public void ClearTasks_OC()
    {
        TaskCollection.Clear();
    }
