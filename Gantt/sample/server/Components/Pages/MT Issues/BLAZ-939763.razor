@page "/BLAZ-939763"

@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.TreeGrid;
@using System.Diagnostics
@using Syncfusion.Blazor.Navigations
@rendermode InteractiveServer
<div>
    <button @onclick="CollapseByKey">CollapsebyKey</button>
    <button @onclick="ExpandByKey">ExpandbyKey</button>
    <button @onclick="CollapseAtLevel">CollapseAtLevel</button>
    <button @onclick="ExpandAtLevel">ExpandAtLevel</button>
    <button @onclick="Refresh">Refresh</button>
    <button id="Scroll_Rows" class="btn btn-primary" @onclick="Scroll">Scroll</button>
    <button id="Position" class="btn btn-primary" @onclick="ScrollPosition">Position</button>
    <button id="Delete" @onclick="Delete">Delete Row</button>
    <button id="Convert" @onclick="ConvertToMilestone">ConvertToMilestone</button>
    <button id="Add_method" @onclick="Add">Add</button>
    <button id="ScrollToTask" @onclick="ScrollTask">ScrollToTask</button>
</div><br>

<SfGantt @ref="Gantt"
ID="Gantt"
DataSource="@TaskCollection"
         Toolbar="@ToolbarItems"
EnableRowVirtualization="true"
EnableTimelineVirtualization="true"
ScrollToTaskbarOnClick="true"
EnableColumnVirtualization="true"
AllowSelection="true"
EnableContextMenu="true"
AllowFiltering="true"
GridLines="Syncfusion.Blazor.Gantt.GridLine.Both"
AllowSorting="true"
AllowResizing="true"
AllowUnscheduledTasks="true"
EnablePredecessorValidation="true"
ShowColumnMenu="true"
AllowReordering="true"
HighlightWeekends="true"
AllowRowDragAndDrop="false"
DateFormat="dd/MM/yyyy"
Height="500px"
Width="1400px">
    <GanttTaskFields Id="ID"
    Name="TaskName"
    StartDate="StartDate"
    EndDate="EndDate"
    Duration="Duration"
    Progress="Progress"
    Dependency = "Predecessor"
    ParentID="ParentId">
    </GanttTaskFields>

    <GanttEditSettings AllowAdding="true"
    AllowDeleting="true"
    AllowEditing="true"
    AllowTaskbarEditing="true"
    ShowDeleteConfirmDialog="true">
    </GanttEditSettings>
    <GanttEventMarkers>
        <GanttEventMarker Day="@Event" Label="Project approval and kick-off"
        CssClass="e-custom-event-marker"></GanttEventMarker>
    </GanttEventMarkers>
    <GanttHolidays>
        <GanttHoliday From="@Holiday1" To="@Holiday2" Label="Public holidays"></GanttHoliday>
    </GanttHolidays>

    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>


    <GanttEvents TValue="TaskData"  
    OnLoad="LoadHandler" 
    Created="Created" 
    OnActionBegin="ActionBegin" 
    OnActionComplete="ActionComplete" 
    Expanding="Expanding" 
    Expanded="expanded" 
    Collapsing="collapsing" 
    Collapsed="collapsed" 
    RowSelected="selected"  
    RowSelecting="selecting" 
    SplitterResizeStart="Resizestart" 
    SplitterResizing ="Resized"
    EndEdit="EndEdit"
    Zoomed="ZoomCompleteHandler"
    ColumnReordered="ColumnReorderedHandler"
    Sorted="SortedHandler"
    Searched="SearchedHandler"
    Filtered="FilteredHandler"></GanttEvents>

    <GanttLabelSettings LeftLabel="TaskName" TValue="TaskData"></GanttLabelSettings>

    <GanttSplitterSettings Position="30%"></GanttSplitterSettings>
    <GanttSelectionSettings Mode="Syncfusion.Blazor.Grids.SelectionMode.Both" Type="Syncfusion.Blazor.Grids.SelectionType.Multiple"></GanttSelectionSettings>
    <GanttTimelineSettings UpdateTimescaleView="true"></GanttTimelineSettings>
</SfGantt>

