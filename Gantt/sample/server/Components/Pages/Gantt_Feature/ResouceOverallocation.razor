@page "/ResourceOverallocation"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.TreeGrid
@using Syncfusion.Blazor.Navigations    
<div style="width:1400px">
    <button @onclick="Resource" class="btn btn-primary my-2">Change ViewType</button>
<button id="Add" @onclick="Add">Add Record</button>
<button id="Add_resource" @onclick="Add1">Add Record Resoure</button>

<button id="Add_above" @onclick="Above">Add Above</button>

<button id="Add_below" @onclick="Below">Add Below</button>
<button @onclick="ScrollToTaskbar">ScrollToTaskbar</button>

    <SfGantt @ref="Gantt" ID="resource" ShowOverallocation="true" TreeColumnIndex="1" DataSource="@TaskCollection" Height="600px" Width="100%" Toolbar="@(new List<string>() {"GetPersistence", "SetPersistence", "ReloadPage", "ClearPersistence", "Add", "Cancel", "Update" , "Delete", "Edit", "CollapseAll", "ExpandAll", "ZoomIn", "ZoomOut", "ZoomToFit" ,"NextTimeSpan", "PrevTimeSpan", "Search" })" EnableContextMenu AllowFiltering AllowSelection AllowMultiSorting AllowReordering AllowResizing AllowRowDragAndDrop AllowSorting ViewType="@viewType">
        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
                         ParentID="ParentId" Work="Work" TaskType="TaskType" BaselineEndDate="BaselineEndDate" BaselineStartDate="BaselineStartDate" >
        </GanttTaskFields>
        <GanttEventMarkers>
            <GanttEventMarker Day="new DateTime(2022, 04, 05)" Label="Holiday"></GanttEventMarker>
            <GanttEventMarker Day="new DateTime(2022, 04, 11)" Label="Holiday"></GanttEventMarker>
        </GanttEventMarkers>
        <GanttHolidays>
            <GanttHoliday From="new DateTime(2022, 04, 13)" To="new DateTime(2022, 04, 14)"></GanttHoliday>
        </GanttHolidays>
        <GanttResource Group="ResourceGroup" DataSource="@ResourceCollection" Id="ResourceId" Name="ResourceName" MaxUnits="resourceunit" TResources="ResourceAlloacteData" TValue="TaskData"></GanttResource>
<GanttAssignmentFields DataSource="AssignmentCollection" PrimaryKey="@nameof(AssignmentModel.PrimaryId)" TaskID="@nameof(AssignmentModel.TaskId)" ResourceID="@nameof(AssignmentModel.ResourceId)" Units="@nameof(AssignmentModel.Unit)" TValue="TaskData" TAssignment="AssignmentModel">
    </GanttAssignmentFields><GanttLabelSettings RightLabel="Resources" LeftLabel="Resources" TValue="TaskData"></GanttLabelSettings>
        <GanttEditSettings AllowAdding AllowDeleting AllowEditing AllowTaskbarEditing></GanttEditSettings>
        <GanttColumns>
            <GanttColumn Field="TaskId" Visible=false></GanttColumn>
            <GanttColumn Field="TaskName" HeaderText="Task Name"></GanttColumn>
            <GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
            <GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
            <GanttColumn Field="Progress"></GanttColumn>      
        </GanttColumns>
         <GanttSplitterSettings ColumnIndex="5"></GanttSplitterSettings>
        <GanttCriticalPathSettings SlackValue="1"></GanttCriticalPathSettings>
        @*<GanttTaskbarSettings EnalbleMultiTaskbar = "true" AllowTaskbarOverlap="false"></GanttTaskbarSettings>*@
    </SfGantt>
</div>
@code {
