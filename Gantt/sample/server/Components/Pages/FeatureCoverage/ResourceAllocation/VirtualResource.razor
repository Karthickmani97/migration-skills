    private static List<ExpandoObject> GanttData = new List<ExpandoObject>();
    private static int ParentRecordID = 0;
    private static int ChildRecordID = 0;
    public static List<ExpandoObject> GetData()
    {
        GanttData.Clear();
        ParentRecordID = 0;
        ChildRecordID = 0;

        for (var i = 1; i <= 5; i++)
        {
            DateTime start = new DateTime(2021, 01, 10).AddDays(i * 3);
            DateTime end = start.AddDays(2);

            dynamic parentRecord = new ExpandoObject();
            parentRecord.TaskId = ++ParentRecordID;
            parentRecord.TaskName = "Parent task " + i;
            parentRecord.StartDate = start;
            parentRecord.EndDate = end;
            parentRecord.Progress = 30;
            parentRecord.TaskType = TaskType.FixedUnit;
            parentRecord.Duration = ParentRecordID % 2 == 0 ? "4" : "8";
            parentRecord.ParentId = null;

            GanttData.Add(parentRecord);

            AddChildRecords(parentRecord.TaskId);
        }

        return GanttData;
    }

    private static void AddChildRecords(int parentId)
    {
        for (var i = 1; i < 4; i++)
        {
            DateTime start = new DateTime(2021, 01, 10).AddDays(i);
            DateTime end = start.AddDays(2);

            dynamic childRecord = new ExpandoObject();
            childRecord.TaskId = ++ParentRecordID;
            childRecord.TaskName = "Child task " + ++ChildRecordID;
            childRecord.StartDate = start;
            childRecord.EndDate = end;
            childRecord.Progress = 40;
            childRecord.TaskType = TaskType.FixedUnit;
            childRecord.Work = 16;
            childRecord.Duration = ParentRecordID % 3 == 0 ? "3" : "6";
            childRecord.ParentId = parentId;

            GanttData.Add(childRecord);
        }
    }
