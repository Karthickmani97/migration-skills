        new CustomDurationUnit {Id="Day",Unit="Day"},
        new CustomDurationUnit {Id="Hour",Unit="Hour"},
        new CustomDurationUnit {Id="Minute",Unit="Minute"}
    };
    public class TimelineUnit
    {
        public string Id { get; set; }
        public string Unit { get; set; }
    }
    public class DayFormat
    {
        public string Id { get; set; }
        public string Format { get; set; }
    }
    public class CustomDurationUnit
    {
        public string Id { get; set; }
        public string Unit { get; set; }
    }
    public void TimelineViewModeChanged(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, TimelineUnit> args)
    {
        TimelineViewMode changedTopUnit;
        switch (args.Value)
        {
            case "Year":
                changedTopUnit = TimelineViewMode.Year;
                break;
            case "Month":
                changedTopUnit = TimelineViewMode.Month;
                break;
            case "Week":
                changedTopUnit = TimelineViewMode.Week;
                break;
            case "Day":
                changedTopUnit = TimelineViewMode.Day;
                break;
            case "Hour":
                changedTopUnit = TimelineViewMode.Hour;
                break;
            default:
                changedTopUnit = TimelineViewMode.Week;
                break;
        }
        timelineViewMode = changedTopUnit;
    }
    public void DurationUnitChanged(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, CustomDurationUnit> args)
    {
        switch (args.Value)
        {
            case "Day":
                durationUnit = Syncfusion.Blazor.Gantt.DurationUnit.Day;
                break;
            case "Hour":
                durationUnit = Syncfusion.Blazor.Gantt.DurationUnit.Hour;
                break;
            case "Minute":
                durationUnit = Syncfusion.Blazor.Gantt.DurationUnit.Minute;
                break;
            default:
                durationUnit = Syncfusion.Blazor.Gantt.DurationUnit.Day;
                break;
        }
        Gantt.RefreshAsync();
    }
    public void WorkUnitChanged(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, CustomDurationUnit> args)
    {
        switch (args.Value)
        {
            case "Day":
