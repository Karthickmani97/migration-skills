@page "/E2EMigration/editing1"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Gantt
<div>@message</div>
<SfTab>
    <TabItems>
    <ContentTemplate>
    <SfGantt ID="Editing" DataSource="@TaskCollection"  Toolbar="@(new List<string>() { "Add", "Cancel", "CollapseAll", "Delete", "Edit", "ExpandAll", "NextTimeSpan", "PrevTimeSpan", "Search", "Update","ZoomIn","ZoomOut","ZoomToFit" })" Height="450px" Width="900px" AllowFiltering="true" AllowSorting="true">
        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" Child="SubTasks">
        </GanttTaskFields>
        <GanttEditSettings AllowEditing="true" AllowAdding="true" AllowDeleting="true" >
        </GanttEditSettings>
        <GanttEvents TValue="TaskData" OnActionFailure="ActionFailureHandler"></GanttEvents>
    </SfGantt>
     </ContentTemplate> 
   </TabItems>
</SfTab>

@code{
    public List<TaskData> TaskCollection { get; set; }
    public string message{ get; set; }

    protected override void OnInitialized()
