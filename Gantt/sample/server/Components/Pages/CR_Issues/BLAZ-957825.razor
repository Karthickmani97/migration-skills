@page "/BLAZ-957825"
@using Syncfusion.Blazor.Gantt
@rendermode InteractiveServer
<div>@messsage</div>
<SfGantt DataSource="@TaskCollection" Height="450px" Width="900px">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate"
    Duration="Duration" Progress="Progress" ParentID="ParentId">
    </GanttTaskFields>
    <GanttEditSettings AllowTaskbarEditing="true"></GanttEditSettings>
    <GanttEvents TaskbarEdited="TaskbarEdited" TaskbarEditing="TaskbarEditing" OnActionBegin="OnActionBegin" OnActionComplete="OnActionComplete" TValue="TaskData"OnActionFailure="ActionFailureHandler"></GanttEvents>
</SfGantt>

@code {

    public SfGantt<TaskData> Gantt;
    private List<TaskData> TaskCollection { get; set; }
    public string messsage{ get; set; }

    protected override void OnInitialized()
    {
        this.TaskCollection = GetTaskCollection();
    }

    public void OnActionBegin(GanttActionEventArgs<TaskData> args)
    {
        // Here, you can get the error details in the args.
    }

     public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       messsage += " OnAction failure Event triggered";
    } 
    
    protected async Task OnActionComplete(GanttActionEventArgs<TaskData> args)
    {
        // Here, you can get the error details in the args.
        await Task.Yield();
    }

    
    public void TaskbarEditing(TaskbarEditingEventArgs<TaskData> args)
    {
        // Here, you can get the error details in the args.
    }

    public void TaskbarEdited(TaskbarEditedEventArgs<TaskData> args)
    {
        // Here, you can get the error details in the args.
        
    }

