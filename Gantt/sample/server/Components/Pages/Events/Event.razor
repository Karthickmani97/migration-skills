@page "/Event"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
<div>@message</div>
<div><Syncfusion.Blazor.Buttons.SfButton OnClick="Filter">Filter</Syncfusion.Blazor.Buttons.SfButton></div><br>
<section class="container-fluid">
    <div class="row">
        <div class="col-lg-9">

<SfGantt @ref="Gantt" DataSource="@TaskCollection" ID="Gantt" Height="550px" Width="100%" HighlightWeekends="true" AllowSorting AllowFiltering AllowReordering
                      Toolbar="@(new List<string>(){ "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll","Indent","Outdent","ZoomIn","ZoomOut","ZoomToFit","Search"})"
                      AllowSelection="true" TreeColumnIndex="1"
                      ProjectStartDate="@ProjectStart" ProjectEndDate="@ProjectEnd">
<GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
                                  Dependency="Predecessor" ParentID="ParentId"></GanttTaskFields>
<GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true"></GanttEditSettings>
<GanttSelectionSettings></GanttSelectionSettings>
<GanttColumns>
<GanttColumn Field="TaskId" Width="100"></GanttColumn>
<GanttColumn Field="TaskName" HeaderText="Job Name" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
<GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
<GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
<GanttColumn Field="Duration" HeaderText="Duration"></GanttColumn>
<GanttColumn Field="Progress" HeaderText="Progress"></GanttColumn>
<GanttColumn Field="Predecessor" HeaderText="Dependency"></GanttColumn>
</GanttColumns>
<GanttLabelSettings LeftLabel="TaskName" TValue="GanttData.TaskData">
</GanttLabelSettings>
<GanttSplitterSettings Position="40%"> </GanttSplitterSettings>
<GanttEvents TValue="GanttData.TaskData"
                              OnActionFailure="ActionFailureHandler"
                              GanttDialogOpening="DialogOpening" 
                              GanttDialogOpened="DialogOpened"
                              Zooming="ZoomBegin" 
                              Zoomed="ZoomComplete"
                              Sorting="Sorting" 
                              Sorted="Sorted"
                              Searching="Searching" 
                              Searched="Searched"
                              Filtering="Filtering" 
                              Filtered="Filtered" 
                              FilterDialogOpening="FilterDialogOpening" 
                              FilterDialogOpened="FilterDialogOpened"
                              ColumnReordering="ColumnReordering" 
                              ColumnReordered="ColumnReordered"
                              RowUpdating="RowUpdating" 
                              RowUpdated="RowUpdated"
                              RowDeleting="RowDeleting" 
                              RowDeleted="RowDeleted"
                              RowCreating="RowCreating" 
                              RowCreated="RowCreated">
</GanttEvents>
</SfGantt>
</div>
            <div class="col-lg-3">
                
                <table class="table table-bordered" style="border: 1px solid black">
                    <tr><th>Event</th><th>Count</th></tr>
                    <tr><td>DialogOpening</td><td>@DialogOpeningCount</td></tr>
                    <tr><td>DialogOpened</td><td>@DialogOpenedCount</td></tr>
                    <tr><td>ZoomBegin</td><td>@ZoomBeginCount</td></tr>
                    <tr><td>ZoomComplete</td><td>@ZoomCompleteCount</td></tr>
                    <tr><td>Sorting</td><td>@SortingCount</td></tr>
                    <tr><td>Sorted</td><td>@SortedCount</td></tr>
                    <tr><td>Searched</td><td>@SearchedCount</td></tr>   
                    <tr><td>Searching</td><td>@SearchingCount</td></tr>     
                    <tr><td>Filtering</td><td>@FilteringCount</td></tr>   
                    <tr><td>Filtered</td><td>@FilteredCount</td></tr>
                    <tr><td>FilterDialogOpening</td><td>@FilterDialogOpeningCount</td></tr>
                    <tr><td>FilterDialogOpened</td><td>@FilterDialogOpenedCount</td></tr>
                    <tr><td>ColumnReordering</td><td>@ColumnReorderingCount</td></tr>
                    <tr><td>ColumnReordered</td><td>@ColumnReorderedCount</td></tr>  
                    <tr><td>RowUpdating</td><td>@RowUpdatingCount</td></tr>
                    <tr><td>RowUpdated</td><td>@RowUpdatedCount</td></tr>
                    <tr><td>RowDeleting</td><td>@RowDeletingCount</td></tr>
                    <tr><td>RowDeleted</td><td>@RowDeletedCount</td></tr>    
                    <tr><td>RowCreating</td><td>@RowCreatingCount</td></tr>
                    <tr><td>RowCreated</td><td>@RowCreatedCount</td></tr>      
                </table>
            </div>
    </div>
</section>

<style>
    html, body {
        height: 100%;
    }
</style>
