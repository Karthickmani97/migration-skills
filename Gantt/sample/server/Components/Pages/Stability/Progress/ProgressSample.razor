@page "/BLAZ-939864"
@* 1, Run the sample.
2, Observe that Task ID 15 is displayed from June 2024 to October 2024 in the UI.
3, Export the Gantt Chart to PDF.
4, Check the exported PDF file—Task ID 15's taskbar is missing. *@
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Navigations
<div>@message</div>
<SfGantt @ref="GanttChartInstance" ID="GanttExport" DataSource="@Tasks" Height="450px" AllowPdfExport="true" Width="100%" DateFormat="MMM dd, y" 
HighlightWeekends="true" Toolbar="ToolbarActions" AllowExcelExport="true" AllowSelection="true" AllowUnscheduledTasks="true"
GridLines="GridLine.Both" TreeColumnIndex="1" ProjectStartDate="@ProjectStart" ProjectEndDate="@ProjectEnd">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Progress="Progress"
    ></GanttTaskFields>
    <GanttColumns>
        <GanttColumn Field="TaskId" Width="100"></GanttColumn>
        <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
        <GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
        <GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
        <GanttColumn Field="Progress" HeaderText="Progress"></GanttColumn>
    </GanttColumns>
    <GanttLabelSettings LeftLabel="TaskName" TValue="TaskInfoModel"></GanttLabelSettings>
    <GanttSplitterSettings ColumnIndex="2"></GanttSplitterSettings>
    <GanttEvents OnToolbarClick="HandleToolbarClick" TValue="TaskInfoModel" OnActionFailure="ActionFailureHandler"></GanttEvents>
    <GanttTimelineSettings>
        <GanttTopTierSettings Unit="TimelineViewMode.Week" Format="MMM dd, y"></GanttTopTierSettings>
        <GanttBottomTierSettings Unit="TimelineViewMode.Day"></GanttBottomTierSettings>
    </GanttTimelineSettings>
</SfGantt>
@code {
    private DateTime ProjectStart { get; set; } = new DateTime(2024, 3, 25);
    private DateTime ProjectEnd { get; set; } = new DateTime(2024, 7, 28);
    private List<TaskInfoModel> Tasks { get; set; }
    private List<object> ToolbarActions { get; set; } = new List<object>
    {
        "ZoomIn", "ZoomOut", "ZoomToFit", "ExcelExport", "CsvExport",new ToolbarItem { Text = "PDF Export", TooltipText = "PDF Export", Id = "PdfExport", PrefixIcon = "e-pdfexport" }

    };
    public string message{ get; set; } 
    public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       message += " OnAction failure Event triggered";
    }

    private SfGantt<TaskInfoModel> GanttChartInstance;
    protected override void OnInitialized()
    {
        Tasks = EditingData();
    }
    public async Task HandleToolbarClick(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (args.Item.Id == "GanttExport_excelexport")
        {
            await GanttChartInstance.ExportToExcelAsync();
        }
        else if (args.Item.Id == "GanttExport_csvexport")
        {
            await GanttChartInstance.ExportToCsvAsync();
        }
        else if (args.Item.Id == "PdfExport")
        {
            GanttPdfExportProperties Props = new GanttPdfExportProperties();
            await GanttChartInstance.ExportToPdfAsync(Props);
        }
    }
    public class TaskInfoModel
    {
        public int TaskId { get; set; }
        public string TaskName { get; set; }
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public string Duration { get; set; }
        public double Progress { get; set; }
        public string Predecessor { get; set; }
        public string Notes { get; set; }
        public int? ParentId { get; set; }
    }
    public static List<TaskInfoModel> EditingData()
    {
        List<TaskInfoModel> Tasks = new List<TaskInfoModel>() {
            new TaskInfoModel
            {
                TaskId = 53,
                StartDate = new DateTime(2024, 5, 29),
                EndDate = new DateTime(2024, 10, 11),
                TaskName = "Select LSP (On-Hold)",
                Notes = "Future Message, Co.",
                Progress = 0
            },
            new TaskInfoModel
            {
                TaskId = 15,
                StartDate = new DateTime(2024, 6, 17),
                EndDate = new DateTime(2024, 10, 30),
                TaskName = "Financial System Implementation (On-Hold)",
                Notes = "Key Pool, Co.",
                Progress = 383.2
            }
        };
        return Tasks;
    }
}