@page "/BLAZ-953040"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
<button @onclick="Timeline">Project End date Change</button>
<button @onclick="TimelineTier">Timeline Change</button>
<SfGantt DataSource="@EditingData" @ref="Gantt" ID="GanttExport" Height="450px" Width="700px" AllowPdfExport="true" AllowSelection="true" ProjectEndDate="@ProjectEndDate" ProjectStartDate="@ProjectStartDate" HighlightWeekends="true" Toolbar="@(new List<string>() { "ZoomToFit"})"
TreeColumnIndex="1" DateFormat="dd/MM/yyyy" AllowUnscheduledTasks="true" EnableContextMenu="true" AllowRowDragAndDrop="true" TaskType="TaskType.FixedDuration">
    <GanttTaskFields Id="TaskID" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" Dependency="Predecessor" Child="SubTasks" Notes="Info">
    </GanttTaskFields>
    <GanttEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true"></GanttEditSettings>
    <GanttColumns>
        <GanttColumn Field="TaskID" Width="80"></GanttColumn>
        <GanttColumn Field="TaskName" HeaderText="Job Name" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
        <GanttColumn Field="StartDate"></GanttColumn>
        <GanttColumn Field="EndDate"></GanttColumn>
        <GanttColumn Field="Duration"></GanttColumn>
        <GanttColumn Field="Hours"></GanttColumn>
        <GanttColumn Field="Custom"></GanttColumn>
        <GanttColumn Field="Progress"></GanttColumn>
        <GanttColumn Field="Predecessor"></GanttColumn>
    </GanttColumns>
    <GanttTimelineSettings>
        <GanttTopTierSettings Unit="@TopUnit" Format="@TopFormat"></GanttTopTierSettings>
        <GanttBottomTierSettings Unit="@BottomUnit" Format="@BottomFormat"></GanttBottomTierSettings>
    </GanttTimelineSettings>
    <GanttEditDialogFields>
        <GanttEditDialogField Type="GanttDialogFieldType.General" HeaderText="General"></GanttEditDialogField>
        <GanttEditDialogField Type="GanttDialogFieldType.Dependency"></GanttEditDialogField>
        <GanttEditDialogField Type="GanttDialogFieldType.Notes"></GanttEditDialogField>
    </GanttEditDialogFields>
    <GanttLabelSettings LeftLabel="TaskName" TaskLabel="Progress" TValue="TaskData">

    </GanttLabelSettings>
</SfGantt>

