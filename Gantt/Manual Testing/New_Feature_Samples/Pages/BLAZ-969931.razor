@page "/BLAZ-969931"
@using Syncfusion.Blazor.Gantt
@*
Replication Procedure:
    1. Run this sample.
    2. Click on the filter icon in any column header (e.g., "Task Name").
    3. Confirm that the Excel-style filter popup opens with checkbox-based single, multi-select options and select all options.
    4. Apply a condition-based filter (e.g., "Contains", "Greater Than") and verify filtered results.
    5. Use the FilterItemTemplate and confirm custom UI elements render correctly inside the popup.
    6. In the Filtering event, set args.Cancel = true and verify:
        - Filtering is not applied.
        - The popup remains open and interactive.
        - The interface remains responsive.
    7. In the FilterDialogOpening event, set args.Cancel = true and verify:
        - The popup does not open.
        - No flicker or error is shown.
    8. Set args.FilterChoiceCount and verify that the number of items shown in the popup is limited accordingly.
    9. Confirm that the following events are triggered in sequence:
        - FilterDialogOpening
        - FilterDialogOpened
        - Filtering
        - Filtered
    10. Verify that the filter popup renders with the correct height, width, and data when customized.
    11. Use keyboard navigation (Arrow keys, Enter, Escape, Tab) to interact with the popup.
    12. Verify that focus remains on the search box or last interacted element when filtering is canceled.
    13. Verify the custom filter dialog box position, rendering and its functions for filtering.
    14. Verify the clear filter button is functioned properly.
    15. Verify filtering for all the columns.
    16. Verify predeccessor is properly rendered.
    17. Verify the working of Filter dialog box "Ok" and "cancel" button.
    18. Verify all the args functionality in the events.
    19. Verify the filtering property with all hierarchy modes.
*@
<SfGantt @ref="GanttRef" DataSource="@TaskCollection" Height="550px" width="100%" AllowFiltering="true" WorkUnit="WorkUnit.Hour">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId" Work="Work" Manual="IsManual" Dependency="Predecessor" TaskType="TaskType" />
    <GanttColumns>
        <GanttColumn Field="TaskId" HeaderText="Task ID" />
        <GanttColumn Field="TaskName" HeaderText="Task Name">
            <FilterItemTemplate>
                @{
                    var filterContext = (context as FilterItemTemplateContext);
                    var itemTemplateValue = "Textofcheck(" + filterContext.Value + ")";
                }
                @itemTemplateValue
            </FilterItemTemplate>
        </GanttColumn>
        <GanttColumn Field="StartDate" HeaderText="StartDate" />
        <GanttColumn Field="EndDate" HeaderText="EndDate" />
        <GanttColumn Field="Duration" HeaderText="Duration" />
        <GanttColumn Field="Work" HeaderText="Work (hrs)" />
        <GanttColumn Field="IsManual" HeaderText="Task Mode" />
        <GanttColumn Field="TaskType" HeaderText="Task Type" />
        <GanttColumn Field="Predecessor" HeaderText="Predecessor" />
    </GanttColumns>
    <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true" />
    <GanttFilterSettings FilterType="Syncfusion.Blazor.Gantt.FilterType.Excel"
                         HierarchyMode="FilterHierarchyMode.Parent" />
    <GanttSplitterSettings Position="40%"></GanttSplitterSettings>
    <GanttEvents FilterDialogOpening="FilterDialogOpeningHandler" FilterDialogOpened="FilterDialogOpenedHandler" Filtering="FilteringHandler" Filtered="FilteredHandler" TValue="TaskData"></GanttEvents>
</SfGantt>

