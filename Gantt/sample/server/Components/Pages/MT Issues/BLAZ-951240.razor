                        </tr>
                        <tr>
                            <td style="width:30%;"><div>Duration Unit</div></td>
                            <td style="width: 70%">
                                <div>
                                    <SfDropDownList Enabled="@EnableTopUnitDropDown" TValue="string" TItem="CustomDurationUnit" Placeholder="Day" DataSource="@DurationUnits">
                                        <DropDownListFieldSettings Text="Unit" Value="Id"></DropDownListFieldSettings>
                                        <DropDownListEvents TValue="string" TItem="CustomDurationUnit" ValueChange="@DurationUnitChanged"></DropDownListEvents>
                                    </SfDropDownList>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td style="width:30%;"><div>Work Unit</div></td>
                            <td style="width: 70%">
                                <div>
                                    <SfDropDownList Enabled="@EnableTopUnitDropDown" TValue="string" TItem="CustomDurationUnit" Placeholder="Hour" DataSource="@DurationUnits">
                                        <DropDownListFieldSettings Text="Unit" Value="Id"></DropDownListFieldSettings>
                                        <DropDownListEvents TValue="string" TItem="CustomDurationUnit" ValueChange="@WorkUnitChanged"></DropDownListEvents>
                                    </SfDropDownList>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<SfDropDownList @bind-Value="selectedCollectionType" DataSource="collectionTypes" Placeholder="Select a collection type" Width="150px">
    <DropDownListEvents TItem="DropdownData" TValue="string" ValueChange="HandleCollectionChange"></DropDownListEvents>
    <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
</SfDropDownList>
<SfDropDownList @bind-Value="selectedTaskType" DataSource="TaskTypeCollection" Placeholder="FixedDuration" Width="150px">
