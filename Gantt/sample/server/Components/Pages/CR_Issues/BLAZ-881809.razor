    private List<ResourceData.TaskData> TaskCollection { get; set; }
    private List<ResourceData.ResourceAlloacteData> ResourceCollection { get; set; }
    private string messsage { get; set; }
    private static List<AssignmentModel> AssignmentCollection { get; set; } = new();
    protected override void OnInitialized()
    {
        this.TaskCollection = ResourceData.GetTaskCollection();
        this.ResourceCollection = ResourceData.GetResources;
        AssignmentCollection = GetAssignmentCollection();
    }
     public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       messsage += " OnAction failure Event triggered";
    }
    public void OnActionComplete(GanttActionEventArgs<ResourceData.TaskData> args)
    {
        if ((args.Action == "DialogEditing") && args.RequestType == Syncfusion.Blazor.Gantt.Action.Save && args.Data != null)
        {
            if (args.Data.Resources != null)
            {

                messsage = "Resources: " + args.Data.Resources.Count;
            }
            else
            {
                messsage = "No Resources";
            }
        }
    }
