@using Syncfusion.Blazor.Lists
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.NavigationManager UriHelper

<div class="col-lg-12 control-section">
    <div class="content-wrapper">
        <div class="row">
            <div>
                <SfGantt @ref="GanttInstance" RowHeight=RowHeightValue ID="GanttOverview" AllowExcelExport="true" AllowPdfExport="true" TaskbarHeight=TaskbarHeightValue DataSource="TaskCollection" TreeColumnIndex="1" ViewType="@SelectedViewType" Height="450px" Width="100%"
                         GridLines="@gridlines" WorkWeek="@WorkWeekDays" WorkUnit="WorkUnit.Hour" HighlightWeekends="true" Toolbar="Toolbaritems"
                         AllowFiltering="true" AllowResizing="true" AllowSorting="true" ShowColumnMenu="true" ScrollToTaskbarOnClick="true" AllowUnscheduledTasks="true" DurationUnit="@DurationValue" EnableRowHover="true" EnableCriticalPath="@IsCriticalPathEnabled" EnableContextMenu="true">
                    @if (!ShowDependency)
                    {
                        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Work="Work"
