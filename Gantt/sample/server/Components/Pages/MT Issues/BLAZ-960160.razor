@code {
    public SfGantt<TaskInfoModel> GanttInstance;
    private List<TaskInfoModel> TaskCollection { get; set; }
    private static List<AssignmentModel> AssignmentCollection { get; set; }
    private List<ResourceInfoModel> ResourceCollection { get; set; }
    private List<SegmentModel> SegmentCollection { get; set; }
    public int DefaultUnitWidth { get; set; } = 33;
    public int TopTierCount { get; set; } = 1;
    public int BottomTierCount { get; set; } = 1;
    public bool EnableTopNumericBox { get; set; } = true;
    public bool EnableTopUnitDropDown { get; set; } = true;
    public bool EnableTopFormatDropDown { get; set; } = true;
    public bool EnableBottomNumericBox { get; set; } = true;
    public bool EnableBottomUnitDropDown { get; set; } = true;
    public bool EnableBottomFormatDropDown { get; set; } = true;
    public string TopTierFormat { get; set; } = "MMM dd, yyyy";
    public string BottomTierFormat { get; set; } = "";
    private TimelineViewMode TopTierUnit { get; set; } = TimelineViewMode.Week;
    private TimelineViewMode BottomTierUnit { get; set; } = TimelineViewMode.Day;
    public Syncfusion.Blazor.Gantt.DurationUnit DurationValue { get; set; } = DurationUnit.Day;
    private WorkUnit workUnit { get; set; } = WorkUnit.Day;
    public string DurationUnitValue { get; set; } = "Day";
    private Boolean IsCheck { get; set; }
    private ViewType viewType = ViewType.ProjectView;
    private List<string> collectionTypes = new List<string> { "Self", "Rtl", "Virtual", "TopTierOnly", "BottomTierOnly", "NoTimelineTiers" };
    private string selectedCollectionType = "Self";
    private string currentDataType = string.Empty;
    private DateTime Holiday1 = new DateTime(2025, 04, 14);
    private DateTime Holiday2 = new DateTime(2025, 04, 14);
    private DateTime Holiday3 = new DateTime(2025, 04, 29);
    private DateTime Holiday4 = new DateTime(2025, 04, 29);
    private string selectedMethod { get; set; } = "";
    protected override void OnInitialized()
    {
        UpdateCollectionsBasedDataType(selectedCollectionType);
        currentDataType = selectedCollectionType;
    }
    private void HandleCollectionChange(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, string> args)
    {
        selectedCollectionType = args.Value;
        UpdateCollectionsBasedDataType(selectedCollectionType);
    }
    private void UpdateCollectionsBasedDataType(string dataType)
    {
        switch (dataType)
        {
            case "Self":
            case "Rtl":
            case "TopTierOnly":
            case "BottomTierOnly":
            case "NoTimelineTiers":
                TaskCollection = GetTaskCollection();
                ResourceCollection = GetResources;
                AssignmentCollection = GetAssignmentCollection();
                SegmentCollection = GetSegmentCollection();
                currentDataType = dataType;
                break;
            case "Virtual":
                TaskCollection = GetTaskCollection();
                ResourceCollection = GetResources;
                AssignmentCollection = GetAssignmentCollection();
                SegmentCollection = GetSegmentCollection();
                currentDataType = dataType;
                break;
            default:
                break;
        }
    }
    private List<DropdownData> methods = new List<DropdownData>
    {
        new DropdownData{ Text = "ZoomToFit", Value = "ZoomToFit" },
        new DropdownData{ Text = "ZoomIn", Value = "ZoomIn" },
        new DropdownData{ Text = "ZoomOut", Value = "ZoomOut" },
        new DropdownData{ Text = "NextTimeSpan", Value = "NextTimeSpan" },
        new DropdownData{ Text = "PrevTimeSpan", Value = "PrevTimeSpan" },
        new DropdownData{ Text = "ScrollIntoView", Value = "ScrollIntoView" },
        new DropdownData{ Text = "ScrollToTimeline", Value = "ScrollToTimeline" },
    };
    private void HandleMethodChange(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, DropdownData> args)
    {
        selectedMethod = args.Value;
        SwitchMethods();
    }
    private async void SwitchMethods()
    {
        switch (selectedMethod)
        {
            case "ZoomToFit":
                await this.GanttInstance.ZoomToFitAsync();
                break;
            case "ZoomIn":
                await GanttInstance.ZoomInAsync();
