@page "/multipage-pdf-customization"

@rendermode InteractiveServer
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Navigations
@using System.Collections.Generic
@using Syncfusion.PdfExport

<div class="control-section">
    <div>
        <SfComboBox @ref="@CustomListPdf" TItem="CustomData" TValue="string" Placeholder="Custom DataSource" 
        DataSource="@CustomListPdfData" FloatLabelType="FloatLabelType.Always" Width="250px">
            <ComboBoxFieldSettings Text="Name" Value="Value"></ComboBoxFieldSettings>
            <ComboBoxEvents TItem="CustomData" TValue="string" ValueChange="ChangeExportProperties"></ComboBoxEvents>
        </SfComboBox>
    </div>
    <div>
        <SfComboBox @ref="@ExportPropertiesComboBox" TItem="ExportPropertyData" TValue="string" Placeholder="Select Export Property"
        DataSource="@ExportPropertiesData" FloatLabelType="FloatLabelType.Always" Width="250px">
            <ComboBoxFieldSettings Text="Name" Value="Value"></ComboBoxFieldSettings>
            <ComboBoxEvents TItem="ExportPropertyData" TValue="string" ValueChange="OnExportPropertyChange"></ComboBoxEvents>
        </SfComboBox>
    </div>
    <div id="ganttpdfcustomization">
        <SfGantt @ref="@Gantt" ID="GanttPdfCustomization" Height="450px" TValue="GanttTask" DataSource="ProjectNewData"
        AllowSorting="true" AllowReordering="true" EnableContextMenu="true"
        AllowExcelExport="true" AllowPdfExport="true" AllowRowDragAndDrop="true"
        HighlightWeekends="true" AllowResizing="true" AllowFiltering="true"
        GridLines="@gridLines" ShowColumnMenu="true"
        EnableCriticalPath="@enableCriticalPath" TaskMode="@TaskModeType"
        Toolbar="@ToolbarItems" RenderBaseline="true">

            <GanttTaskFields Id="TaskID" Name="TaskName" StartDate="StartDate"
            EndDate="EndDate" Duration="Duration" Progress="Progress"
            Dependency="Predecessor" BaselineStartDate="BaselineStartDate"
            BaselineEndDate="BaselineEndDate" Child="Subtasks"
            Indicators="Indicators" Manual="IsManual">
            </GanttTaskFields>

            <GanttEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true"
            AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true">
            </GanttEditSettings>

            <GanttColumns>
                <GanttColumn Field="TaskID" HeaderText="Task ID"></GanttColumn>
                <GanttColumn Field="TaskName" HeaderText="Task Name" AllowReordering="false"></GanttColumn>
                <GanttColumn Field="StartDate" HeaderText="Start Date" AllowSorting="false"></GanttColumn>
                <GanttColumn Field="Duration" HeaderText="Duration" AllowEditing="false"></GanttColumn>
                <GanttColumn Field="Progress" HeaderText="Progress" AllowFiltering="false"></GanttColumn>
            </GanttColumns>

            <GanttSplitterSettings Position="50%"></GanttSplitterSettings>

            <GanttTimelineSettings>
                <GanttTopTierSettings Unit="TimelineViewMode.Week"></GanttTopTierSettings>
                <GanttBottomTierSettings Unit="TimelineViewMode.Day"></GanttBottomTierSettings>
            </GanttTimelineSettings>
            @if (eventMarkers.Count > 0)
            {
                <GanttEventMarkers>
                    @foreach (var events in eventMarkers)
                    {
                        <GanttEventMarker Day="@events.Day" Label="@events.Label"></GanttEventMarker>
                    }
                </GanttEventMarkers>
            }
            <GanttLabelSettings LeftLabel="TaskID" RightLabel="TaskName" TaskLabel="Progress" TValue="GanttTask"></GanttLabelSettings>
            <GanttEvents TValue="GanttTask" OnToolbarClick="OnToolbarClick" PdfExporting=" PdfExportingHandler"></GanttEvents>
        </SfGantt>
    </div>
</div>
<style>
    .control-section{
    display: flex;
    flex-direction: column;
    gap: 1rem;
    }
</style>
