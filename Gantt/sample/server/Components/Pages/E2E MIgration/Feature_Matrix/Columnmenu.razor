@page "/E2EMigration/columnmenu"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
<div>@messsage</div>
<button id="AddColumns" @onclick="@AddColumns">Add Columns</button>
<button id="RemoveColumns" @onclick="@RemoveColumns">Remove Columns</button>

<SfGantt @ref="TaskGantt" ID="GanttColumnmenu" DataSource="@TaskCollection" Columns="GanttColumns" Height="450px" Width="1400px" ShowColumnMenu="true" AllowFiltering="true" AllowSorting="true">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate"
                     Duration="Duration" Progress="Progress" Child="SubTasks">
    </GanttTaskFields>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
    <GanttEvents TValue="TaskData" Created="Created"OnActionFailure="ActionFailureHandler"></GanttEvents>
</SfGantt>
@code{
    private SfGantt<TaskData> TaskGantt { get; set; }
    public List<GanttColumn> GanttColumns { get; set; } = new List<GanttColumn>();
    public List<TaskData> TaskCollection { get; set; }
    public string messsage{ get; set; }
    protected override void OnInitialized()
    {
        this.TaskCollection = GetTaskCollection();
        GanttColumns.Add(new GanttColumn { Field = "TaskId" });
        GanttColumns.Add(new GanttColumn { Field = "TaskName" });
        GanttColumns.Add(new GanttColumn { Field = "StartDate" });
        GanttColumns.Add(new GanttColumn { Field = "EndDate" });
        GanttColumns.Add(new GanttColumn { Field = "Duration" });
        GanttColumns.Add(new GanttColumn { Field = "Progress" });
        

    }
    public async Task Created()
    {   
     
    }
     public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       messsage += " OnAction failure Event triggered";
    }

    private Task AddColumns()
    {
        GanttColumns.Add(new GanttColumn { Field = "StartDate" });
        GanttColumns.Add(new GanttColumn { Field = "Duration" });
        TaskGantt.RefreshColumnsAsync();
        return Task.CompletedTask;
    }
    private Task RemoveColumns()
    {
        GanttColumns.Remove(GanttColumns[3]);
        GanttColumns.Remove(GanttColumns[2]);
        GanttColumns = GanttColumns;
        TaskGantt.RefreshColumnsAsync();
        return Task.CompletedTask;
    }
    public class TaskData
    {
        public int TaskId { get; set; }
        public string TaskName { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public string? Duration { get; set; }
        public int Progress { get; set; }
        public List<TaskData> SubTasks { get; set; }
    }

    public static List<TaskData> GetTaskCollection()
    {
