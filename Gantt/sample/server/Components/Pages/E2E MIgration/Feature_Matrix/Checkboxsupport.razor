
@page "/E2EMigration/Checkbox"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.TreeGrid
<div>@messsage</div>
<SfGantt ID="GanttCheckbox" DataSource="@TaskCollection" Toolbar="@(new List<string>() { "Add", "Cancel", "Update", "CollapseAll", "Delete", "Edit", "ExpandAll" })" Height="500px" Width="1400px" >
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate"
                     Duration="Duration" Progress="Progress" Child="SubTasks">
    </GanttTaskFields>
    <GanttEditSettings AllowTaskbarEditing="true" AllowEditing="true" ShowDeleteConfirmDialog="true" AllowAdding="true" AllowDeleting="true" Mode="Syncfusion.Blazor.Gantt.EditMode.Auto"></GanttEditSettings>
    <GanttColumns>
        <GanttColumn Field="TaskId"></GanttColumn>
        <GanttColumn Field="TaskName" ShowCheckbox="true"></GanttColumn>
        <GanttColumn Field="StartDate"></GanttColumn>
        <GanttColumn Field="EndDate"></GanttColumn>
        <GanttColumn Field="Duration" ></GanttColumn>
        <GanttColumn Field="App" DisplayAsCheckBox="true" EditType=Syncfusion.Blazor.Grids.EditType.BooleanEdit></GanttColumn> 
    </GanttColumns>
<GanttSplitterSettings Position="70%"></GanttSplitterSettings>
<GanttEvents TValue="TaskData" Created="Created"OnActionFailure="ActionFailureHandler"></GanttEvents>
</SfGantt>
@code{ 
   
    public List<TaskData> TaskCollection { get; set; }
    public string messsage{ get; set; }
    protected override void OnInitialized()
    {
        this.TaskCollection = GetTaskCollection();
    }
    public async Task Created()
    {   
     
    }
    public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       messsage += " OnAction failure Event triggered";
