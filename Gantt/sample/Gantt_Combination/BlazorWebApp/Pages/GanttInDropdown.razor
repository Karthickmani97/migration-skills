@page "/gantt-dropdown"
@rendermode InteractiveServer
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Gantt

<h3>Gantt per Project (Dropdown)</h3>

<div class="mb-3">
    <p class="text-muted">Select a project from the dropdown to view its Gantt chart. The dropdown includes a live timeline preview in the popup!</p>
</div>

<div class="mb-3" style="max-width:1000px">
    <label class="form-label"><strong>Select Project:</strong></label>
    <SfDropDownList ID="projectDropdown" 
                    TValue="int" 
                    TItem="Project" 
                    DataSource="@Projects" 
                    Placeholder="Select a project to view timeline"
                    Value="@SelectedProjectId"
                    ValueChanged="@OnProjectChanged"
                    PopupHeight="650px"
                    PopupWidth="1000px">
        <DropDownListFieldSettings Value="Id" Text="Name"></DropDownListFieldSettings>
        
        <DropDownListTemplates TItem="Project">
            <ItemTemplate Context="project">
                <div class="d-flex align-items-center">
                    <i class="e-icons e-file-new me-2"></i>
                    <div>
                        <div class="fw-bold">@project.Name</div>
                        <small class="text-muted">@project.Tasks.Count task(s), @GetProjectProgress(project)% complete</small>
                    </div>
                </div>
            </ItemTemplate>
            
            <FooterTemplate>
                <div style="padding: 10px; background-color: #f8f9fa; border-top: 1px solid #dee2e6;">
                    <h6 class="mb-2">
                        <i class="e-icons e-schedule me-2"></i>Live Timeline Preview
                    </h6>
                    @if (SelectedGanttData.Any())
                    {
                        <div style="background-color: white; border: 1px solid #dee2e6; border-radius: 4px; padding: 5px;">
                            <SfGantt DataSource="@SelectedGanttData" 
                                     Height="500px" 
                                     Width="950px"
                                     Toolbar="@(new List<string>() { "ExpandAll", "CollapseAll", "ZoomIn", "ZoomOut", "ZoomToFit" })">
                                <GanttTaskFields Id="TaskId" 
                                               Name="TaskName" 
                                               StartDate="StartDate" 
                                               Duration="Duration" 
                                               Progress="Progress" 
                                               Child="SubTasks"
                                               Dependency="Predecessor">
                                </GanttTaskFields>
                                <GanttColumns>
                                    <GanttColumn Field="TaskId" Width="60"></GanttColumn>
                                    <GanttColumn Field="TaskName" Width="200"></GanttColumn>
                                    <GanttColumn Field="StartDate" Width="110" Format="d"></GanttColumn>
                                    <GanttColumn Field="Duration" Width="80"></GanttColumn>
                                    <GanttColumn Field="Progress" Width="90"></GanttColumn>
                                </GanttColumns>
                            </SfGantt>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="e-icons e-schedule" style="font-size: 48px; color: #ccc;"></i>
                            <p class="text-muted mt-2">Select a project to preview timeline</p>
                        </div>
                    }
                </div>
            </FooterTemplate>
        </DropDownListTemplates>
    </SfDropDownList>
</div>

@if (SelectedGanttData.Any())
{
    <div class="row">
        <div class="col-md-8">
            <div id="projectInfo" class="alert alert-info mb-3">
                <i class="e-icons e-info me-2"></i>
                Showing <strong>@SelectedGanttData.Count</strong> task(s) for <strong>@Projects.FirstOrDefault(p => p.Id == SelectedProjectId)?.Name</strong>
            </div>
        </div>
        <div class="col-md-4">
            <div id="progressCard" class="card mb-3">
                <div class="card-body py-2">
                    <small class="text-muted">Project Progress</small>
                    <h5 class="mb-0">@GetCurrentProjectProgress()%</h5>
                </div>
            </div>
        </div>
    </div>
}

<div id="mainGanttContainer" style="background-color: white; border: 1px solid #dee2e6; border-radius: 4px; padding: 10px;">
    <SfGantt DataSource="@SelectedGanttData" 
             Height="520px" 
             Width="1000px"
             Toolbar="@(new List<string>() { "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll", "ZoomIn", "ZoomOut", "ZoomToFit" })">
        <GanttTaskFields Id="TaskId" 
                       Name="TaskName" 
                       StartDate="StartDate" 
                       Duration="Duration" 
                       Progress="Progress" 
                       Child="SubTasks" 
                       Dependency="Predecessor">
        </GanttTaskFields>
        <GanttEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true"></GanttEditSettings>
        <GanttColumns>
            <GanttColumn Field="TaskId" HeaderText="ID" Width="80"></GanttColumn>
            <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250"></GanttColumn>
            <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150" Format="d"></GanttColumn>
            <GanttColumn Field="Duration" HeaderText="Duration" Width="100"></GanttColumn>
            <GanttColumn Field="Progress" HeaderText="Progress %" Width="120"></GanttColumn>
        </GanttColumns>
    </SfGantt>
</div>

@code {
    private List<Project> Projects = new();

    private int _selectedProjectId;
    private int SelectedProjectId
    {
        get => _selectedProjectId;
        set
        {
            if (_selectedProjectId == value) return;
            _selectedProjectId = value;
            UpdateGanttData();
        }
    }

    // Make Gantt data a concrete list so the component has a stable reference to render
    private List<GanttTask> SelectedGanttData { get; set; } = new();

    private void OnProjectChanged(int newProjectId)
    {
        _selectedProjectId = newProjectId;
        UpdateGanttData();
    }

    private void UpdateGanttData()
    {
        var selectedProject = Projects.FirstOrDefault(p => p.Id == _selectedProjectId);
        if (selectedProject != null && selectedProject.Tasks != null)
        {
            SelectedGanttData = new List<GanttTask>(selectedProject.Tasks);
        }
        else
        {
            SelectedGanttData = new List<GanttTask>();
        }
        StateHasChanged();
    }

    private int GetProjectProgress(Project project)
    {
        if (project?.Tasks == null || !project.Tasks.Any()) return 0;
        return (int)project.Tasks.Average(t => t.Progress);
    }

    private int GetCurrentProjectProgress()
    {
        if (!SelectedGanttData.Any()) return 0;
        return (int)SelectedGanttData.Average(t => t.Progress);
    }

    protected override void OnInitialized()
    {
        Projects = GetSampleProjects();
        if (Projects.Any())
        {
            SelectedProjectId = Projects[0].Id;
        }
    }

