    public string Formatter(DateTime? date)
    {
        DateTime dateTime = (DateTime)(date);
        var month = dateTime.Month;
        if (month >= 0 && month <= 2)
        {
            return "Q1";
        }
        else if (month >= 3 && month <= 5)
        {
            return "Q2";
        }
        else if (month >= 6 && month <= 8)
        {
            return "Q3";
        }
        else
        {
            return "Q4";
        }
    }
