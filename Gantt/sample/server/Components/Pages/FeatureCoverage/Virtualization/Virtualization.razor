            </SfGantt>
        }
        else
        {
            <SfGantt @ref="Gantt" DataSource="@TaskCollection" Height="450px" Width="100%" PageSize="20" TreeColumnIndex="0" AllowRowDragAndDrop="@isRowDragAndDrop" EnableRowVirtualization="true" EnableTimelineVirtualization="true" EnableColumnVirtualization="true"
                     Toolbar="@(new List<string>() { "Add", "Delete", "Edit", "ZoomIn", "ZoomOut" })" ScrollToTaskbarOnClick="true">
                <GanttLabelSettings LeftLabel="TaskName" TValue="TaskData"></GanttLabelSettings>
                <GanttTaskFields ParentID="ParentId" Work="Work" Id="ID" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" TaskType="TaskType" Dependency="Predecessor">
                </GanttTaskFields>
                @if (isFrozen)
                {
                    <GanttColumns>
