            new TaskInfoModel() { TaskId = 2, TaskName = "Identify Site location", StartDate = new DateTime(2021, 01, 06), Duration = "4", Progress = 30, ParentId = 1, },
            new TaskInfoModel() { TaskId = 3, TaskName = "Perform soil test", StartDate = new DateTime(2021, 01, 06), Duration = "4", Progress = 40, ParentId = 1,Predecessor="2" },
            new TaskInfoModel() { TaskId = 4, TaskName = "Soil test approval", StartDate = new DateTime(2021, 01, 06), Duration = "3", Progress = 30, ParentId = 1, },
            new TaskInfoModel() { TaskId = 5, TaskName = "Project estimation", StartDate = new DateTime(2021, 01, 06), EndDate = new DateTime(2021, 01, 07), },
            new TaskInfoModel() { TaskId = 6, TaskName = "Develop floor plan for estimation", StartDate = new DateTime(2021, 01, 05), Duration = "3", Progress = 30, ParentId = 5, },
            new TaskInfoModel() { TaskId = 7, TaskName = "List materials", StartDate = new DateTime(2021, 01, 06), Duration = "3", Progress = 40, ParentId = 5, },
            new TaskInfoModel() { TaskId = 8, TaskName = "Estimation approval", StartDate = new DateTime(2021, 01, 06), Duration = "3", Progress = 30, ParentId = 5, }
        };
        return Tasks;
    }
