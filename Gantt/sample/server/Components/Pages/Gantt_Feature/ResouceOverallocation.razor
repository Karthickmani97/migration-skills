    public async Task Add()
    {
           await this.Gantt.AddRecordAsync(record, 0,Syncfusion.Blazor.Gantt.RowPosition.Below);

    }
    public async Task Add1()
    {
           await this.Gantt.AddRecordAsync(record);

    }
    public async Task Above()
    {
           await this.Gantt.AddRecordAsync(record, 1,Syncfusion.Blazor.Gantt.RowPosition.Above);

    }
    public async Task Below()
    {
           await this.Gantt.AddRecordAsync(record, 1,Syncfusion.Blazor.Gantt.RowPosition.Below);

    }
