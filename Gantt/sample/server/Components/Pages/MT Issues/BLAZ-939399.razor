@page "/BLAZ-939399"
@using Syncfusion.Blazor.Gantt
@rendermode InteractiveServer
<SampleDescription>
    This sample demonstrates the enhanced performance capabilities of the <a aria-label="Navigate to the explore Syncfusion Blazor gantt chart component" target='_blank' href='https://www.syncfusion.com/blazor-components/blazor-gantt-chart'>Blazor Gantt Chart</a> when handling large datasets. It visualizes the lifecycle of software development projects, showing task dependencies, progress, and timelines for multiple projects. The optimization allows for efficient rendering and interaction with up to 25,000 tasks, facilitating project managers in tracking development milestones and managing resources effectively.
</SampleDescription>
<ActionDescription>
    In this example, the Blazor Gantt Chart displays a comprehensive view of software project management, including project initiatives, phases, and individual tasks. It tracks tasks across various stages of development such as requirement analysis, feature development, and deployment. Key features include row and timeline virtualization, allowing for smooth scrolling and efficient data handling. Users can interact with taskbar editing, adjust task dependencies, and review project progress through integrated visual tools.
</ActionDescription>

<div class="col-lg-12 control-section">
    <div class="content-wrapper">
        <div class="row">
            <SfGantt TValue="TaskData" DataSource="TaskCollection" Height="450px" Width="100%" TreeColumnIndex="1" ProjectStartDate="new DateTime(2022, 12, 28)" ScrollToTaskbarOnClick="true" EnablePredecessorValidation="false" AutoCalculateDateScheduling="false" EnableRowVirtualization="true" EnableTimelineVirtualization="true">
                <GanttTaskFields Id="TaskId"
                                 Name="TaskName"
                                 StartDate="StartDate"
                                 EndDate="EndDate"
                                 Progress="Progress"
                                 ParentID="ParentId"
                                 Dependency="Predecessor"
                                 Duration="Duration">
                </GanttTaskFields>
                <GanttColumns>
                    <GanttColumn Field="TaskId" ></GanttColumn>
                    <GanttColumn Field="TaskName" HeaderText="Project Activity" Width="280"></GanttColumn>
                    <GanttColumn Field="StartDate" HeaderText="Planned Start Date"></GanttColumn>
                    <GanttColumn Field="EndDate" HeaderText="Planned End Date"></GanttColumn>
                    <GanttColumn Field="Duration" HeaderText="Estimated Duration"></GanttColumn>
                    <GanttColumn Field="Progress" HeaderText="Completion (%)"></GanttColumn>
                    <GanttColumn Field="Predecessor" HeaderText="Dependencies"></GanttColumn>
                </GanttColumns>
                <GanttEditSettings AllowTaskbarEditing="true"></GanttEditSettings>
                <GanttLabelSettings LeftLabel="TaskName" TaskLabel="Progress" TValue="TaskData"></GanttLabelSettings>
                <GanttSplitterSettings ColumnIndex="3"></GanttSplitterSettings>
            </SfGantt>
        </div>
    </div>
</div>
@code {
    private List<TaskData> TaskCollection { get; set; }
    protected override void OnInitialized()
    {
        this.TaskCollection = GenerateTaskData();
    }
    public class TaskData
    {
        public int TaskId { get; set; }
        public string TaskName { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public int Duration { get; set; }
        public int Progress { get; set; }
        public int? ParentId { get; set; }
        public DateTime BaselineStartDate { get; set; }
        public DateTime BaselineEndDate { get; set; }
        public string Predecessor { get; set; }
    }
    public List<TaskData> GenerateTaskData()
    {
        List<TaskData> taskList = new List<TaskData>();
        DateTime projectStartDate = new DateTime(2023, 1, 1);
        int nextTaskIdentifier = 1;

        for (int projectIndex = 0; projectIndex < 1000; projectIndex++)
        {
            int mainProjectTaskId = nextTaskIdentifier++;
            taskList.Add(CreateTask(mainProjectTaskId, $"Project Initiative {projectIndex + 1}",
                EnsureWeekday(projectStartDate), EnsureWeekday(projectStartDate.AddDays(180)), 180, null, 50));

            for (int phaseIndex = 0; phaseIndex < 2; phaseIndex++)
            {
                int phaseTaskId = nextTaskIdentifier++;
                DateTime phaseStartDate = projectStartDate.AddDays(phaseIndex * 60);
                taskList.Add(CreateTask(phaseTaskId, $"Phase {phaseIndex + 1}: Design & Development",
                    EnsureWeekday(phaseStartDate), EnsureWeekday(phaseStartDate.AddDays(60)), 60, mainProjectTaskId, 20 + phaseIndex * 10));

                for (int taskIndex = 0; taskIndex < 11; taskIndex++)
                {
                    int individualTaskId = nextTaskIdentifier++;
                    DateTime taskStartDate = phaseStartDate.AddDays(taskIndex * 5);
                    DateTime taskEndDate = taskStartDate.AddDays(10);

                    int progress = (taskIndex < 6 && phaseIndex == 0) ? 100 : (taskIndex < 3 && phaseIndex == 1) ? 80 : 0;
                    string? predecessorId = individualTaskId > phaseTaskId + 1 ? $"{individualTaskId - 1}" : null;

                    string taskName = taskIndex switch
                    {
                        0 => "Requirement Analysis",
                        1 => "Architecture Planning",
                        2 => "Feature Development",
                        3 => "Code Review",
                        4 => "Testing",
                        5 => "Documentation",
                        6 => "Performance Optimization",
                        7 => "User Acceptance Testing",
                        8 => "Deployment Prep",
                        9 => "Go Live",
                        _ => "Post Deployment Monitoring"
                    };

                    taskList.Add(CreateTask(individualTaskId, taskName,
                        EnsureWeekday(taskStartDate), EnsureWeekday(taskEndDate), 10, phaseTaskId, progress, predecessorId));
                }
            }
        }
        return taskList;
    }
    private DateTime EnsureWeekday(DateTime date)
    {
        return date.DayOfWeek switch
        {
            DayOfWeek.Saturday => date.AddDays(2), // If Saturday, move to Monday
            DayOfWeek.Sunday => date.AddDays(1),   // If Sunday, move to Monday
            _ => date // If weekday, keep it as is
        };
    }
    private TaskData CreateTask(int taskId, string taskName, DateTime startDate, DateTime endDate,
        int duration, int? parentId, int progress, string? predecessor = null)
    {
        return new TaskData
            {
                TaskId = taskId,
                TaskName = taskName,
                StartDate = startDate,
                EndDate = endDate,
                Duration = duration,
                Progress = progress,
                ParentId = parentId,
                Predecessor = predecessor
            };
    }
}
