    private async void AddAssignment()
    {
        var record = new AssignmentModel() { Id = 8, TaskId = 9, ResourceId = 2 };
        Gantt.AddResourceAssignmentAsync(record);
    }
    public void RowUpdatingHandler(GanttRowUpdatingEventArgs<TaskData> args)
    {
        args.Data.TaskName = "Row Updated";
        var record = new AssignmentModel() { Id = 8, TaskId = args.Data.TaskID, ResourceId = 2 };
        Gantt.AddResourceAssignmentAsync(record);
    }
