@page "/E2EMigration/Baseline1"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
<div>@message</div>
<SfGantt ID="GanttBaseline" @ref="Gantt" DataSource="@TaskCollection" Height="450px" Width="1200px" Toolbar="@(new List<string>() { "Add", "Cancel", "Delete", "Edit", "Update" })" RenderBaseline="true">
    <GanttTaskFields Id="TaskId" Name="TaskName" BaselineStartDate="BaselineStartDate"
                     BaselineEndDate="BaselineEndDate" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId">
    </GanttTaskFields>
    <GanttTimelineSettings UpdateTimescaleView="true"> </GanttTimelineSettings>
    <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true" ></GanttEditSettings>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
    <GanttEvents TValue="TaskData" Created="Created" OnActionFailure="ActionFailureHandler"></GanttEvents>
</SfGantt>
<style>
    .e-baseline-milestone-top {
        border-top: 0px solid transparent;
        border-bottom-style: solid;
    }

    .e-baseline-milestone-bottom {
        border-bottom: 0px solid transparent;
        border-top-style: solid;
    }
</style>

