@page "/contextmenu"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
<SfGantt ID="GanttContextmenu" DataSource="@TaskCollection" AllowUnscheduledTasks="true" EnableContextMenu="true" Height="450px" Width="1400px" AllowFiltering="true" AllowSorting="true">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Interval" Progress="Progress" Dependency="Predecessor" Child="SubTasks">
    </GanttTaskFields>
    <GanttEditSettings AllowEditing="true" AllowAdding="true" AllowDeleting="true" AllowTaskbarEditing="true">
    </GanttEditSettings>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
    <GanttEvents TValue="TaskData" Created="Created" ></GanttEvents>
</SfGantt>

