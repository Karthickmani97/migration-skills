    private List<DefaultData.TaskData> TaskCollection { get; set; } = new List<DefaultData.TaskData>();
    public DateTime ProjectStartDate { get; set; } = new DateTime(2021, 03, 25);
    public DateTime ProjectEndDate { get; set; } = new DateTime(2021, 07, 17);

    protected override void OnInitialized()
    {
        TaskCollection = DefaultData.ProjectNewData();
    }
    private async Task OnToolbarClick(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (mGanttRef is null)
            return;
        if (args.Item.Id.EndsWith("Add"))
        {
            var id = TaskCollection.Count > 0 ? TaskCollection.Max(t => t.TaskId) + 1 : 1;
            var index = (await mGanttRef.GetSelectedRowIndexesAsync()).FirstOrDefault();
            await mGanttRef.AddRecordAsync(new DefaultData.TaskData() { TaskId = id, TaskName = "New Task", StartDate = ProjectStartDate, EndDate = ProjectEndDate, Duration = "5" }, index, Syncfusion.Blazor.Gantt.RowPosition.Below);
        }
        else if (args.Item.Id.EndsWith("Delete"))
        {
            await mGanttRef.DeleteRecordAsync();
        }
    }
	 private void OnActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
	 {
		 ErrorMessage = args.Error.Message;
	 }
}