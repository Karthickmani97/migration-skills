@page "/Predecessor/selfreference"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Buttons
<SfGantt DataSource="@TaskCollection" @ref="Gantt" Height="550px" Width="100%" HighlightWeekends="true" EnablePredecessorValidation="@IsPredecessorValidation" EnableRowVirtualization="@IsRowVirtualization" EnableCriticalPath="@IsCriticalPath" EnableTimelineVirtualization="@IsTimeLineVirtualization"
Toolbar="@(new List<string>() { "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll", "Indent", "Outdent","ZoomIn","ZoomOut","ZoomToFit","CriticalPath" })"
AllowSelection="true" GridLines="Syncfusion.Blazor.Gantt.GridLine.Both" TreeColumnIndex="1" RenderBaseline="@IsBaseLine"
ScrollToTaskbarOnClick="true">
    @if (SelectedDataCollectionType == "RenderWithoutDependency")
    {
        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
        ParentID="ParentId"></GanttTaskFields>
    }
    else
    {
        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
        Dependency="Predecessor" ParentID="ParentId" BaselineEndDate="BaselineEndDate" BaselineStartDate="BaselineStartDate"></GanttTaskFields>
    }
    <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true"></GanttEditSettings>
    <GanttLabelSettings LeftLabel="TaskName" TaskLabel="Progress" TValue="TaskInfoModel"></GanttLabelSettings>
    <GanttSplitterSettings ColumnIndex="2"></GanttSplitterSettings>
    <GanttCriticalPathSettings SlackValue="6"></GanttCriticalPathSettings>
    @if (IsEvents)
    {
        <GanttEvents TValue="TaskInfoModel" TaskbarEditing="OnTaskbarEditingHandler" TaskbarEdited="OnTaskbarEditedHandler" TaskConnectorChanging="ConnectorLineDrawHandler" TaskConnectorChanged="ConnectorLineDrawCompletedHandler"></GanttEvents>
    }
</SfGantt>
<div>
    <SfDropDownList @bind-Value="SelectedDataCollectionType" DataSource="DataCollection" Placeholder="DataSource" Width="300px">
        <DropDownListEvents TItem="DropdownData" TValue="string" ValueChange="HandleDataCollectionChange"></DropDownListEvents>
        <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
    </SfDropDownList>
    <button @onclick="EnableEvents">Events</button>
    <button @onclick="EnableCriticalPath">Critical Path</button>
    <button @onclick="EnableBaseLine">Render BaseLine</button>
</div>
@code {
    private SfGantt<TaskInfoModel> Gantt;
    private DateTime ProjectStartDate = new DateTime(2025, 3, 25);
    private DateTime ProjectEndDate = new DateTime(2025, 9, 01);
    private List<TaskInfoModel> TaskCollection { get; set; }
    public string SelectedDataCollectionType { get; set; } = "EditingData";
    public bool IsRowVirtualization { get; set; }
    public bool IsEvents { get; set; }
    public bool IsBaseLine { get; set; }
    public bool IsCriticalPath { get; set; }
    public bool IsPredecessorValidation { get; set; } = true;
    public bool IsTimeLineVirtualization { get; set; }
    protected override void OnInitialized()
    {
        TaskCollection = EditingData().ToList();
    }
    private List<DropdownData> DataCollection = new List<DropdownData>
    {
        new DropdownData{ Text = "EditingData", Value = "EditingData" },
        new DropdownData{ Text = "Disable Predecessor Validation", Value = "DisablePredecessorValidation" },
        new DropdownData{ Text = "Render Without Dependency", Value = "RenderWithoutDependency" },
        new DropdownData{ Text = "Virtual", Value = "Virtual" },
    };
    private void HandleDataCollectionChange(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, DropdownData> args)
    {
        SelectedDataCollectionType = args.Value;
        SwitchDataSource();
        StateHasChanged();
    }
    private void SwitchDataSource()
    {
        switch (SelectedDataCollectionType)
        {
            case "EditingData":
                TaskCollection = EditingData().ToList();
                break;
            case "DisablePredecessorValidation":
                IsPredecessorValidation = false;
                TaskCollection = GetTaskCollection().ToList();
                break;
            case "RenderWithoutDependency":
                TaskCollection = EditingData().ToList();
                break;
            case "Virtual":
                IsRowVirtualization = true;
                IsTimeLineVirtualization = true;
                TaskCollection = GetVirtualData().ToList();
                break;
        }
    }
    private void EnableEvents()
    {
        IsEvents = IsEvents ? false : true;
    }
    private void EnableBaseLine()
    {
        IsBaseLine = IsBaseLine ? false : true;
    }
    private void EnableCriticalPath()
    {
        IsCriticalPath = IsCriticalPath ? false : true;
    }
    public async void ConnectorLineDrawHandler(TaskConnectorChangeEventArgs<TaskInfoModel> args)
    {
        args.Cancel = true;
        await Task.CompletedTask;
    }
    public async void ConnectorLineDrawCompletedHandler(TaskConnectorChangedEventArgs<TaskInfoModel> args)
    {
        await Task.CompletedTask;
    }
    private async Task OnTaskbarEditingHandler(TaskbarEditingEventArgs<TaskInfoModel> args)
    {
        args.EnablePredecessorOffsetValidation = true;
        await Task.CompletedTask;
    }
    private async Task OnTaskbarEditedHandler(TaskbarEditedEventArgs<TaskInfoModel> args)
    {
        await Task.CompletedTask;
    }
    public class DropdownData
    {
        public string? Text { get; set; }
