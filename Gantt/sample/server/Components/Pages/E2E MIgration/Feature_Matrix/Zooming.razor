@page "/E2EMigration/zooming"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
<div>@message</div>
<button @onclick="InitDataAsync" id="InitDataAsync">InitDataAsync</button>
<button @onclick="ClearData" id="Cleardata">ClearDataAsync</button>
<SfGantt ID="GanttZooming" @ref="Gantt" DataSource="@TaskCollection" Toolbar="@(new List<string>() { "ZoomIn","ZoomOut","ZoomToFit" })" Height="450px" Width="1400px">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" Child="SubTasks" Dependency="Predecessor">
    </GanttTaskFields>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
     <GanttEvents TValue="TaskData" Created="Created"OnActionFailure="ActionFailureHandler" ></GanttEvents>
</SfGantt>

@code{
    public SfGantt<TaskData> Gantt;
    public string message{ get; set; }
    public List<TaskData> TaskCollection { get; set; } = new List<TaskData>();
    public void InitDataAsync()
    {
        this.TaskCollection = GetTaskCollection();
    }
    public async Task Created()
    {   
     
    }
     public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       message += " OnAction failure Event triggered";
    }
    private void ClearData()
    {
        this.TaskCollection = new List<TaskData>();
    }

