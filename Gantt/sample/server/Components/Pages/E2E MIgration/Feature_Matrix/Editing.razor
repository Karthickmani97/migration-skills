                    },
                    new TaskData() {
                        TaskId = 8,
                        TaskName = "Estimation approval",
                        StartDate = new DateTime(2019, 04, 04),
                        Duration = "0",
                        Progress = 30,
                    },
                })
            }
        };

            return Tasks;
        }
    }