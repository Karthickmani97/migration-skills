	/// <summary>
	/// Ordered timeline units used to validate tier selections.
	/// </summary>
	private string[] UnitOrder { get; set; } = new string[]
	{
		"None", "Hour", "Day", "Week", "Month", "Quarter", "HalfYear", "Year"
