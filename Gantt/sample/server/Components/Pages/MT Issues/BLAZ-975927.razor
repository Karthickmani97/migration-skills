@page "/BLAZ-975927"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Navigations
<SfGantt @ref="GanttInstance" DataSource="@TaskCollection" EnableContextMenu="true" AllowPdfExport="true" Toolbar="@toolbarItems" TaskMode="ScheduleMode.Auto" DateFormat="d MMM yyyy hh:mm tt" IncludeWeekend="true" RenderBaseline="true" DurationUnit="DurationUnit.Hour" Height="550px" Timezone="@TimeZone" Width="100%" ProjectStartDate="@ProjectStartDate" ProjectEndDate="@ProjectEndDate"
         AllowSelection="true" GridLines="GridLine.Both" TreeColumnIndex="1"
         ScrollToTaskbarOnClick="true">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
                     Dependency="Predecessor" ParentID="ParentId" Indicators="Indicators" BaselineEndDate="BaselineEndDate" BaselineStartDate="BaselineStartDate"></GanttTaskFields>
    <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true"></GanttEditSettings>
    <GanttColumns>
        <GanttColumn Field="TaskId" Width="100"></GanttColumn>
        <GanttColumn Field="TaskName" HeaderText="Job Name" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip">
        </GanttColumn>
        <GanttColumn Field="StartDate" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit" HeaderText="Start Date"></GanttColumn>
        <GanttColumn Field="EndDate" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit" HeaderText="End Date"></GanttColumn>
        <GanttColumn Field="Duration" HeaderText="Duration"></GanttColumn>
        <GanttColumn Field="Progress" HeaderText="Progress"></GanttColumn>
        <GanttColumn Field="BaselineStartDate" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit" HeaderText="Baseline Start Date"></GanttColumn>
        <GanttColumn Field="BaselineEndDate" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit" HeaderText="Baseline End Date"></GanttColumn>
        <GanttColumn Field="Predecessor" HeaderText="Dependency"></GanttColumn>
    </GanttColumns>
    <GanttDayWorkingTimeCollection>
        <GanttDayWorkingTime From="0" To="24"></GanttDayWorkingTime>
    </GanttDayWorkingTimeCollection>
    <GanttEventMarkers>
        <GanttEventMarker Day="new DateTime(2019, 3, 8, 12, 0, 0)" Label="Requirements Sign-Off"></GanttEventMarker>
        <GanttEventMarker Day="new DateTime(2019, 3, 9, 16, 0, 0)" Label="UI Design Complete"></GanttEventMarker>
        <GanttEventMarker Day="new DateTime(2019, 3, 11, 13, 0, 0)" Label="System Integration Started"></GanttEventMarker>
    </GanttEventMarkers>
    <GanttLabelSettings LeftLabel="TaskName" TaskLabel="Progress" TValue="GanttData.TaskData"></GanttLabelSettings>
    <GanttSplitterSettings ColumnIndex="2"></GanttSplitterSettings>
    <GanttTimelineSettings TimelineUnitSize="40">
        <GanttTopTierSettings Unit="TimelineViewMode.Day" Format="MMM dd, yyyy"></GanttTopTierSettings>
        <GanttBottomTierSettings Unit="TimelineViewMode.Hour" Count="1" Format="hh:mm"></GanttBottomTierSettings>
    </GanttTimelineSettings>
    <GanttEvents OnToolbarClick="HandleToolbarClick" TValue=GanttData.TaskData></GanttEvents>
</SfGantt>
@code {
    private DateTime ProjectStartDate = new DateTime(2019, 3, 7);
    private DateTime ProjectEndDate { get; set; } = new DateTime(2019, 3, 12);
    private List<GanttData.TaskData> TaskCollection { get; set; }
    private SfGantt<GanttData.TaskData> GanttInstance;
    private List<Object> toolbarItems;
    public string TimeZone { get; set; } = TimeZoneValues[0];
    private static List<string> TimeZoneValues = new List<string> {
        "America/New_York", "America/Chicago", "America/Denver", "America/Los_Angeles",
        "America/Phoenix", "America/Sao_Paulo", "Europe/London", "Europe/Paris", "Europe/Berlin",
        "Europe/Moscow", "Africa/Johannesburg", "Africa/Cairo", "Asia/Jerusalem", "Asia/Dubai", "Asia/Amman",
        "Asia/Kolkata", "Asia/Kathmandu", "Asia/Shanghai", "Asia/Tokyo", "Asia/Seoul",
        "Asia/Singapore", "Australia/Sydney", "Australia/Perth", "Pacific/Auckland", "Pacific/Honolulu","UTC",
    };
    public string SelectedTimeZone { get; set; } = TimeZoneValues[0];
    protected override void OnInitialized()
    {
        TaskCollection = GanttData.EditingData().ToList();
        toolbarItems = new List<object>()
        {
            "Add",
            "Edit",
            "Update",
            "Cancel",
            "Delete",
            "ZoomIn",
            "ZoomOut",
            "ZoomToFit",
            "PrevTimeSpan",
            "NextTimeSpan",
            new ToolbarItem { Text = "PDF Export", TooltipText = "PDF Export", Id = "PdfExport", PrefixIcon = "e-pdfexport" },
            new ItemModel
            {
                Id = "TimeZoneLabel",
                Template = (RenderFragment)(builder =>
                {
                    builder.OpenElement(0, "label");
                    builder.AddAttribute(1, "class", "showhide");
                    builder.AddContent(2, "Current Timezone");
                    builder.CloseElement();
                })
            },
            new ItemModel
            {
                Id = "TimeZoneDropDown",
                Template = (RenderFragment)(builder =>
                {
                    builder.OpenComponent<SfDropDownList<string, string>>(0);
                    builder.AddAttribute(1, "Width", "175px");
                    builder.AddAttribute(2, "DataSource", TimeZoneValues);
                    builder.AddAttribute(3, "Value", SelectedTimeZone);
                    builder.AddAttribute(4, "ValueChanged", EventCallback.Factory.Create<string>(this, v => SelectedTimeZone = v));
                    builder.AddAttribute(5, "ChildContent", (RenderFragment)(childBuilder =>
                    {
                        childBuilder.OpenComponent<DropDownListEvents<string, string>>(0);
                        childBuilder.AddAttribute(1, "ValueChange", EventCallback.Factory.Create<ChangeEventArgs<string, string>>(this, OnTimeZoneChanged));
                        childBuilder.CloseComponent();
                    }));
                    builder.CloseComponent();
                })
            },
        };
    }
    public async Task HandleToolbarClick(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (args.Item.Id == "GanttExport_excelexport")
        {
            await GanttInstance.ExportToExcelAsync();
        }
        else if (args.Item.Id == "GanttExport_csvexport")
        {
            await GanttInstance.ExportToCsvAsync();
        }
        else if (args.Item.Id == "PdfExport")
        {
            await GanttInstance.ExportToPdfAsync();
        }
    }
    public async void OnTimeZoneChanged(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, string> args)
    {
        TimeZone = args.Value;
        await Task.CompletedTask;
    }
