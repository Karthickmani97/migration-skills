@page "/virtualization"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.DropDowns

<div>
    <table class="gantt-virtual">
        <tr>
            <td>
                <div class="e-switch-control">
                    <label class="showhide"> Disable Row drag and drop </label>
                    <SfSwitch ValueChange="ToggleUpdate" @bind-Checked="@isRowDragAndDrop" TChecked="bool"></SfSwitch>
                    <label class="showhide"> Enable Row drag and drop </label>
                </div>
            </td>
            <td>
                <div class="e-switch-control">
                    <label class="showhide"> Disable RTL </label>
                    <SfSwitch ValueChange="ToggleUpdate" @bind-Checked="@isRtl" TChecked="bool"></SfSwitch>
                    <label class="showhide"> Enable RTL </label>
                </div>
            </td>
            <td>
                <div>
                    <div>
                        <label><b>Choose Column Type</b></label>
                    </div>
                    <div>
                        <SfDropDownList @bind-Value="selectedColumnType" DataSource="@columnTypes" TValue="string" TItem="string" Placeholder="Select Column Type" Width="150px">
                            <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
                            <DropDownListEvents TValue="string" TItem="string" ValueChange="OnValueChange"></DropDownListEvents>
                        </SfDropDownList>
                    </div>
                </div>
            </td>
            <td>
                <div>
                    <div>
                        <label><b>Public Method</b></label>
                    </div>
                    <div>
                        <SfDropDownList @bind-Value="selectedMethod" DataSource="@publicMethods" TValue="string" TItem="string" Placeholder="Select Public Method" Width="150px">
                            <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
                            <DropDownListEvents TValue="string" TItem="string" ValueChange="UpdatePublicMethods"></DropDownListEvents>
                        </SfDropDownList>
                    </div>
                </div>
            </td>
            <td>
                <div>
                    <table id="property" title="Properties" class="property-panel-table">
                        <tbody>
                            <tr>
                                <td style="font:bold"><b>Timeline Settings</b></td>
                            </tr>
                            <tr>
                                <td style="width:30%;"><div><b>Top tier</b></div></td>
                            </tr>
                            <tr>
                                <td style="width:30%;"><div>Unit</div></td>
                                <td style="width: 70%">
                                    <div>
                                        <SfDropDownList Enabled="@EnableTopUnitDropDown" TValue="string" TItem="TimelineUnit" Placeholder="Week" DataSource="@TimelineUnits">
                                            <DropDownListFieldSettings Text="Unit" Value="Id"></DropDownListFieldSettings>
                                            <DropDownListEvents TValue="string" TItem="TimelineUnit" ValueChange="@TopUnitChange"></DropDownListEvents>
                                        </SfDropDownList>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td style="width:30%;"><div><b>Bottom tier</b></div></td>
                            </tr>
                            <tr>
                                <td style="width:30%;"><div>Unit</div></td>
                                <td style="width: 70%">
                                    <div>
                                        <SfDropDownList Enabled="@EnableBottomUnitDropDown" TValue="string" TItem="TimelineUnit" Placeholder="Day" DataSource="@TimelineUnits">
                                            <DropDownListFieldSettings Text="Unit" Value="Id"></DropDownListFieldSettings>
                                            <DropDownListEvents TValue="string" TItem="TimelineUnit" ValueChange="@BottomUnitChange"></DropDownListEvents>
                                        </SfDropDownList>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </td>
        </tr>
    </table>
    <div>
        @if (isRtl)
        {
            <SfGantt @ref="Gantt" ID="Gantt" DataSource="@TaskCollection" Height="450px" Width="100%" PageSize="20" TreeColumnIndex="0" AllowRowDragAndDrop="@isRowDragAndDrop" EnableRtl="@isRtl" EnableRowVirtualization="true" EnableTimelineVirtualization="true" EnableColumnVirtualization="true"
                     Toolbar="@(new List<string>() { "Add", "Delete", "Edit", "ZoomIn", "ZoomOut", "NextTimeSpan", "PrevTimeSpan" })" ScrollToTaskbarOnClick="true">
                <GanttLabelSettings LeftLabel="TaskName" TValue="TaskData"></GanttLabelSettings>
                <GanttTaskFields ParentID="ParentId" Work="Work" Id="ID" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" TaskType="TaskType" Dependency="Predecessor">
                </GanttTaskFields>
                @if (isFrozen)
                {
                    <GanttColumns>
                        <GanttColumn Field="ID" HeaderText="TaskId" Width="100" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" IsFrozen="true" Freeze="Syncfusion.Blazor.Grids.FreezeDirection.Left"></GanttColumn>
                        <GanttColumn Field="TaskName" HeaderText="TaskName" IsFrozen="true" Freeze="Syncfusion.Blazor.Grids.FreezeDirection.Left"></GanttColumn>
