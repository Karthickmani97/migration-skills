    // MODEL WITH DATA ANNOTATIONS (replaces column rules)
    public class TaskData : INotifyPropertyChanged, IValidatableObject
    {
        [Required]
        [Range(1, int.MaxValue, ErrorMessage = "TaskId must be greater than 0.")]
        public int TaskId { get; set; }

        private string activityName;
        [Required]
        [StringLength(10, MinimumLength = 5, ErrorMessage = "Activity must be between 5 and 10 characters.")]
        public string ActivityName
        {
            get => activityName;
            set
            {
                if (value != activityName)
                {
                    activityName = value;
                    NotifyPropertyChanged(nameof(ActivityName));
                }
            }
        }

        [Required]
        [Range(0, 365, ErrorMessage = "Duration must be between 0 and 365.")]
        public int? Duration { get; set; }

        public string Predecessor { get; set; } = string.Empty;

        [Range(5, 50, ErrorMessage = "Progress must be between 5 and 50.")]
        public int Progress { get; set; }

        [Range(5, 200, ErrorMessage = "Work must be between 5 and 200.")]
        public int Work { get; set; }

        public int? ParentId { get; set; }

        [EmailAddress(ErrorMessage = "Invalid email address.")]
        public string? Email { get; set; } = string.Empty;

        [RegularExpression(@"^[a-zA-Z0-9_]*$", ErrorMessage = "Username can only contain letters, numbers, and underscores.")]
        public string? Username { get; set; } = string.Empty;

        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        [MaxLength(20, ErrorMessage = "Password cannot exceed 20 characters.")]
        public string? Password { get; set; } = string.Empty;

        [Url(ErrorMessage = "Invalid URL format.")]
        public string? Website { get; set; } = string.Empty;

        [Required(ErrorMessage = "Custom Data is required.")]
        public string? CustomData { get; set; } = string.Empty;

        [Required(ErrorMessage = "Notes is required.")]
        public string? Notes { get; set; } = string.Empty;

        [Required(ErrorMessage = "Task Type is required.")]
        public string? TaskType { get; set; } = string.Empty;

        [Required]
        [Range(typeof(DateTime), "2020-01-01", "9999-12-31", ErrorMessage = "Start Date must be on or after 01-Jan-2020.")]
        public DateTime? StartDate { get; set; }

        [Required]
        [Range(typeof(DateTime), "2020-01-01", "9999-12-31", ErrorMessage = "End Date must be on or after 01-Jan-2020.")]
        public DateTime? EndDate { get; set; }

        [Required]
        [Range(typeof(DateTime), "2020-01-01", "2030-12-31", ErrorMessage = "Baseline Start Date must be between 01-Jan-2020 and 31-Dec-2030.")]
        public DateTime? BaselineStartDate { get; set; }

        [Required]
        [Range(typeof(DateTime), "2020-01-01", "2030-12-31", ErrorMessage = "Baseline End Date must be between 01-Jan-2020 and 31-Dec-2030.")]
        public DateTime? BaselineEndDate { get; set; }

        [Required]
        [Range(typeof(DateTime), "2020-01-01", "9999-12-31", ErrorMessage = "Review Date must be on or after 01-Jan-2020.")]
        public DateTime? ReviewDate { get; set; }

        [Required]
        [Range(typeof(decimal), "100", "1000000", ErrorMessage = "Project Budget must be between $100 and $1,000,000.")]
        public decimal ProjectBudget { get; set; }

        public event PropertyChangedEventHandler? PropertyChanged;
        private void NotifyPropertyChanged(string propertyName)
            => PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));

        // Cross-field and date-range validations mirrored from previous rules
        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            var min2020 = new DateTime(2020, 1, 1).Date;
            var maxToday = DateTime.Today;
            var max2030 = new DateTime(2030, 12, 31).Date;

            if (!StartDate.HasValue)
                yield return new ValidationResult("Start Date is required.", new[] { nameof(StartDate) });
            else
            {
                var d = StartDate.Value.Date;
                if (d < min2020 || d > maxToday)
                    yield return new ValidationResult("Start Date must be between 01-Jan-2020 and today.", new[] { nameof(StartDate) });
            }

            if (!EndDate.HasValue)
                yield return new ValidationResult("End Date is required.", new[] { nameof(EndDate) });
            else
            {
                var d = EndDate.Value.Date;
                if (d < min2020 || d > maxToday)
                    yield return new ValidationResult("End Date must be between 01-Jan-2020 and today.", new[] { nameof(EndDate) });

                if (StartDate.HasValue && d < StartDate.Value.Date)
                    yield return new ValidationResult("End Date cannot be earlier than the Start Date.", new[] { nameof(EndDate) });
            }

            if (!BaselineStartDate.HasValue)
                yield return new ValidationResult("Baseline Start Date is required.", new[] { nameof(BaselineStartDate) });
            else
            {
                var d = BaselineStartDate.Value.Date;
                if (d < min2020 || d > max2030)
                    yield return new ValidationResult("Baseline Start Date must be between 01-Jan-2020 and 31-Dec-2030.", new[] { nameof(BaselineStartDate) });
            }

            if (!BaselineEndDate.HasValue)
                yield return new ValidationResult("Baseline End Date is required.", new[] { nameof(BaselineEndDate) });
            else
            {
                var d = BaselineEndDate.Value.Date;
                if (d < min2020 || d > max2030)
                    yield return new ValidationResult("Baseline End Date must be between 01-Jan-2020 and 31-Dec-2030.", new[] { nameof(BaselineEndDate) });
            }

            if (!ReviewDate.HasValue)
                yield return new ValidationResult("Review Date is required.", new[] { nameof(ReviewDate) });
            else
            {
                var d = ReviewDate.Value.Date;
                if (d < min2020 || d > maxToday)
                    yield return new ValidationResult("Review Date must be between 01-Jan-2020 and today.", new[] { nameof(ReviewDate) });
            }
        }
    }
}