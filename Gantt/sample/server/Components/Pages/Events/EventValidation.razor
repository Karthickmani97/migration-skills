@page "/Event_Validation"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.TreeGrid
@using Syncfusion.Blazor.Layouts
@using Syncfusion.PdfExport
<div>@messsage</div>
<button @onclick="Clear">Clear</button>
<SfGantt @ref="GanttRef" DataSource="@TaskCollection" TValue="TaskData" AllowPdfExport="true" EnableUndoRedo="true" UndoRedoActions="@undoRedoActions" AllowSearching="true" Height="300px" Width="100%" RenderBaseline="true" ConnectorLineBackground="#ab6060fc" ConnectorLineWidth="2" ID="Gantt" AllowFiltering="true" AllowSorting="true" AllowRowDragAndDrop="true" EnableContextMenu="true" Toolbar="Toolbaritems" AllowResizing="true" ShowColumnMenu="true" AllowReordering="true">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" BaselineStartDate="BaselineStartDate" BaselineEndDate="BaselineEndDate" Dependency="Predecessor" ParentID="ParentId"></GanttTaskFields>
    <GanttEditSettings AllowTaskbarEditing="true" AllowDeleting="true" AllowEditing="true" AllowAdding="true"></GanttEditSettings>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
     <GanttSelectionSettings  Mode="Syncfusion.Blazor.Grids.SelectionMode.Row" Type="Syncfusion.Blazor.Grids.SelectionType.Multiple" AllowDragSelection="true"></GanttSelectionSettings>
    <GanttTemplates TValue="TaskData">
        <TaskbarTemplate>
            @{
                var task = context as TaskData;
                <div class="e-gantt-child-taskbar e-gantt-child-taskbar-inner-div" style="background-color: @(task.Predecessor != null ? "#6d619b" : "#d3d3d3");height: 16px;">
                    <span>@((context as TaskData).TaskName)</span>
                </div>
            }
        </TaskbarTemplate>
    </GanttTemplates>
    <GanttTooltipSettings ShowTooltip="true" TValue="TaskData">
        <ConnectorLineTemplate>
            <div>Predecessor: @((context as TaskData).Predecessor)</div>
        </ConnectorLineTemplate>
    </GanttTooltipSettings>
    <GanttEvents OnActionFailure="ActionFailureHandler"
                 Created="CreatedHandler"
                 OnLoad="LoadHandler"
                 DataBound="DataBoundHandler"
                 Destroyed="DestroyHandler"
                 RowDragStarting="RowDragStartHandler"
                 RowDataBound="RowDataBoundHandler"
                 Sorting="SortingHandler"
                 Sorted="SortedHandler"
                 Searching="SearchingHandler"
                 Searched="SearchedHandler"
                 RowCreating="RowAddingHandler"
                 RowCreated="RowCreatedHandler"
                 RowUpdating="RowUpdatingHandler"
                 RowUpdated="RowUpdatedHandler"
                 RowDeleting="RowDeletingHandler"
                 RowDeleted="RowDeletedHandler"
                 Filtering="FilteringHandler"
                 Filtered="FilteredHandler"
                 QueryChartRowInfo="QueryChartRowInfo"
                 EndEdit="EndEdit"
                 QueryCellInfo="QueryCellInfoHandler"
                 BeforeTooltipRender="BeforeTooltipRender"
                 OnCellEdit="CellEditHandler"
                 OnToolbarClick="ToolbarClickHandler"
                 OnCellSave="@SaveHandler"
                 FilterDialogOpening="FilterDialogOpeningHandler"
                 BeforeCopy="BeforeCopyHandler"
                 FilterDialogOpened="FilterDialogOpenedHandler"
                 ColumnReordering="ColumnReorderingHandler"
                 ColumnReordered="ColumnReorderedHandler"
                 GanttDialogOpening="GanttDialogOpeningHandler"
                 GanttDialogOpened="GanttDialogOpenedHandler"
                 GanttDialogClosing="GanttDialogClosingHandler"
                 PdfExporting=" PdfExportingHandler"
                 PdfExported=" PdfExportedHandler"
                 RowDragSelectionStarting="RowDragSelectionStartingHandler"
                 RowDragSelectionCompleted="RowDragSelectionCompletedHandler"
                 OnUndoRedo="UndoRedoHandler"
                 RowDragSelectionCompleting="RowDragSelectionCompletingHandler"
                 TaskbarEditing="TaskbarEditingHandler"
                 TaskConnectorChanging="ConnectorLineDrawHandler"
                 TaskConnectorChanged="ConnectorLineDrawCompletedHandler"
                 IndentationChanging="IndentationChangingHandler"
                 IndentationChanged="IndentationChangedHandler"
                 Zooming="ZoomBeginHandler"
                 Zoomed="ZoomCompleteHandler"
                 TaskbarEdited="TaskbarEdited"
                 RowDropping="RowDropping"
                 RowDropped="RowDropped"
                 CellSelecting="CellSelecting"
                 CellSelected="CellSelectedHandler"
                 SplitterResizeStart="Resizestart"
                 RowSelecting="RowSelectingHandler"
                 RowSelected="rowSelect"
                 RowDeselecting="RowDeselectingHandler"
                 RowDeselected="RowDeselectHandler"
                 CellDeselecting="CellDeselectingHandler"
                 CellDeselected="CellDeselectedHandler"
                 ColumnMenuClicked="ColumnMenuClickedHandler"
                 ContextMenuItemClicked="ContextMenuItemClickedHandler"
                 ContextMenuOpen="ContextMenuOpenHandler"
                 Collapsed="Collapsed"
                 Collapsing="Collapsed"
                 Expanding="Expanding"
                 Expanded="ExpandedHandler"
                 TValue="TaskData">
    </GanttEvents>
    <GanttLabelSettings LeftLabel="TaskName" TValue="TaskData"></GanttLabelSettings>
</SfGantt>
<div>
    @if (PropertyItems?.Any() == true)
    {
        
        @foreach (var data in PropertyItems)
        {
            <span style="font-weight:400; color: red;font-size: 8px;line-height: 12px;">EventName : @data.Key ,</span>
            @foreach (var item in data.Value)
            {
                <span style="color: Blue; font-weight:400; font-size: 8px;line-height: 12px;">@item.Name :</span>
                <span style="color: darkgreen;font-size: 8px;line-height: 12px;">@item.Value</span>

                <span style="padding-right:15px">,</span>
            }
        }
    }
</div>
<style>
    .e-connector-line {
        stroke: #ab6060fc !important;
        stroke-width: 2px;
    }

    .e-connector-line-arrow {
        fill: #ab6060fc !important;
    }
</style>

