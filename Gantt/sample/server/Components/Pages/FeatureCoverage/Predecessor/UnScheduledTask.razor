@page "/Predecessor/unscheduled-task"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Navigations
<div id="dependency_gantt">
    <SfGantt @key="SelectedCollectionType" DataSource="@TaskCollection" @ref="Gantt" Height="550px" Width="1200px" ValidateManualTasksOnLinking="@ValidateManualTask" HighlightWeekends="true" AllowUnscheduledTasks="true" TreeColumnIndex="1" Toolbar="@(new List<string>() { "Add", "Cancel", "Delete", "Edit" })"
    TaskMode="@TaskMode">
        <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true" Mode="EditMode.Auto"></GanttEditSettings>
        @if (SelectedCollectionType == "Auto" || SelectedCollectionType == "Manual")
        {
            <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId" Dependency="Predecessor"></GanttTaskFields>
        }
        else
        {
            <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" ParentID="ParentId" Manual="IsManual" Dependency="Predecessor"></GanttTaskFields>
        }
        <GanttColumns>
            <GanttColumn Field="TaskId" Width="75px"></GanttColumn>
            <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250px" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
            <GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
            <GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
            <GanttColumn Field="Duration" HeaderText="Duration"></GanttColumn>
            <GanttColumn Field="Predecessor" HeaderText="Predecessor"></GanttColumn>
        </GanttColumns>
        <GanttLabelSettings LeftLabel="TaskName" TValue="TaskInfoModel">
        </GanttLabelSettings>
        <GanttSplitterSettings Position="40%"></GanttSplitterSettings>
        <GanttEvents TValue="TaskInfoModel" OnCellSave="CellSaveHandler" CellSaved="CellSaved" TaskbarEditing="OnTaskbarEditingHandler" TaskbarEdited="OnTaskbarEditedHandler" TaskConnectorChanging="ConnectorLineDrawHandler" TaskConnectorChanged="ConnectorLineDrawCompletedHandler"></GanttEvents>
    </SfGantt>
</div>
<div>
    <SfDropDownList @bind-Value="SelectedCollectionType" DataSource="collectionTypes" Placeholder="@SelectedCollectionType" Width="150px">
        <DropDownListEvents TItem="DropdownData" TValue="string" ValueChange="HandleCollectionChange"></DropDownListEvents>
        <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
    </SfDropDownList>
    <SfDropDownList @bind-Value="selectedMethod" DataSource="methods" Placeholder="Public Methods" Width="300px">
        <DropDownListEvents TItem="DropdownData" TValue="string" ValueChange="HandleMethodChange"></DropDownListEvents>
        <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
    </SfDropDownList>
</div>
@code{
    private List<TaskInfoModel> TaskCollection { get; set; }
    private SfGantt<TaskInfoModel> Gantt;
    private ScheduleMode TaskMode = ScheduleMode.Custom;
    private string SelectedCollectionType { get; set; } = "Custom";
    private string selectedMethod { get; set; } = "";
    private bool ValidateManualTask { get; set; } = false;
    protected override void OnInitialized()
    {
        TaskCollection = GetCustomCollection();
    }
    private List<DropdownData> collectionTypes = new List<DropdownData>
    {
        new DropdownData{ Text = "Custom", Value = "Custom" },
        new DropdownData{ Text = "Auto", Value = "Auto" },
        new DropdownData{ Text = "Manual", Value = "Manual" },
    };
    private List<DropdownData> methods = new List<DropdownData>
    {
        new DropdownData{ Text = "Add Predecessor", Value = "AddPredecessor" },
        new DropdownData{ Text = "Update Predecessor", Value = "UpdatePredecessor" },
        new DropdownData{ Text = "Remove Predecessor", Value = "RemovePredecessor" },
    };
    private void HandleMethodChange(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, DropdownData> args)
    {
        selectedMethod = args.Value;
        SwitchMethods();
    }
    private void SwitchMethods()
    {
        switch (selectedMethod)
        {
            case "AddPredecessor":
                this.Gantt.AddPredecessor(4, "2FF-2");
                break;
            case "UpdatePredecessor":
                Gantt.UpdatePredecessor(6, "1FF");
                break;
            case "RemovePredecessor":
                Gantt.RemovePredecessor(2);
                break;
        }
    }
    private async void HandleCollectionChange(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, DropdownData> args)
    {
        SelectedCollectionType = args.Value;
        SwitchDataBinding();
        StateHasChanged();
    }
    private void SwitchDataBinding()
    {
        switch (SelectedCollectionType)
        {
            case "Custom":
                {
                    TaskMode = ScheduleMode.Custom;
                    TaskCollection = GetCustomCollection();
                }
                break;
            case "Auto":
                {
                    TaskMode = ScheduleMode.Auto;
                    TaskCollection = GetTaskCollection();
                }
                break;
            case "Manual":
                {
                    TaskMode = ScheduleMode.Manual;
                    ValidateManualTask = true;
                    TaskCollection = GetManualCollection();
                }
                break;
        }
    }
    public async void CellSaved(Syncfusion.Blazor.Grids.CellSavedArgs<TaskInfoModel> args)
    {
        await Task.CompletedTask;
    }
    public async void ConnectorLineDrawHandler(TaskConnectorChangeEventArgs<TaskInfoModel> args)
    {
        await Task.CompletedTask;
    }
    public async void ConnectorLineDrawCompletedHandler(TaskConnectorChangedEventArgs<TaskInfoModel> args)
    {
        await Task.CompletedTask;
    }
    private async Task OnTaskbarEditingHandler(TaskbarEditingEventArgs<TaskInfoModel> args)
    {
        await Task.CompletedTask;
    }
    private async Task OnTaskbarEditedHandler(TaskbarEditedEventArgs<TaskInfoModel> args)
    {
        await Task.CompletedTask;
    }
    private async Task CellSaveHandler(Syncfusion.Blazor.Grids.CellSaveArgs<TaskInfoModel> args)
    {
        await Task.CompletedTask;
    }
    public class DropdownData
    {
        public string? Text { get; set; }
        public string? Value { get; set; }
    }
    public class TaskInfoModel
    {
        public int TaskId { get; set; }
        public string TaskName { get; set; }
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public string Duration { get; set; }
        public int? ParentId { get; set; }
        public bool IsManual { get; set; }
        public string TaskMode { get; set; }
        public string? Predecessor { get; set; }
        public int? Progress { get; set; }
    }
    public static List<TaskInfoModel> GetCustomCollection()
    {
