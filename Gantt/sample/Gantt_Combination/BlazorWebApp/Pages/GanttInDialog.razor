@page "/gantt-dialog"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Gantt

<h3>Gantt inside Dialog</h3>

<div class="mb-3">
    <SfButton CssClass="e-primary" OnClick="OpenDialog">Open Gantt Dialog</SfButton>
</div>

<SfDialog Width="1500px" IsModal="true" Visible="@IsDialogVisible" Header="Project Gantt" ShowCloseIcon="true" @onclose="CloseDialog">
    <DialogTemplates>
        <Content>
            <SfGantt DataSource="@GanttData" Height="520px" Width="1400px">
                <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" Duration="Duration" Progress="Progress" Child="SubTasks" Dependency="Predecessor">
                </GanttTaskFields>
                <GanttColumns>
                    <GanttColumn Field="TaskId" HeaderText="ID" Width="80"></GanttColumn>
                    <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250"></GanttColumn>
                    <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150" Format="d"></GanttColumn>
                    <GanttColumn Field="Duration" HeaderText="Duration" Width="100"></GanttColumn>
                    <GanttColumn Field="Progress" HeaderText="Progress" Width="100"></GanttColumn>
                </GanttColumns>
            </SfGantt>
        </Content>
    </DialogTemplates>
</SfDialog>

@code {
    private bool IsDialogVisible { get; set; }
    private List<TaskData> GanttData { get; set; } = new();

    protected override void OnInitialized()
    {
        GanttData = GetSampleData();
    }

    private void OpenDialog(MouseEventArgs args)
    {
        IsDialogVisible = true;
    }

    private void CloseDialog()
    {
        IsDialogVisible = false;
    }

    private List<TaskData> GetSampleData()
    {
        return new List<TaskData>
        {
            new TaskData
            {
                TaskId = 1,
                TaskName = "Design Phase",
                StartDate = new DateTime(2026,02,01),
                Duration = 5,
                Progress = 70,
                Predecessor = string.Empty,
                SubTasks = new List<TaskData>
                {
                    new TaskData { TaskId = 2, TaskName = "Requirement Analysis", StartDate = new DateTime(2026,02,01), Duration = 2, Progress = 100, Predecessor = "" },
                    new TaskData { TaskId = 3, TaskName = "Architecture", StartDate = new DateTime(2026,02,03), Duration = 3, Progress = 50, Predecessor = "2FS" }
                }
            },
            new TaskData
            {
                TaskId = 4,
                TaskName = "Implementation",
                StartDate = new DateTime(2026,02,06),
                Duration = 7,
                Progress = 40,
                Predecessor = "1FS",
                SubTasks = new List<TaskData>
                {
                    new TaskData { TaskId = 5, TaskName = "Module A", StartDate = new DateTime(2026,02,06), Duration = 3, Progress = 60, Predecessor = "3FS" },
                    new TaskData { TaskId = 6, TaskName = "Module B", StartDate = new DateTime(2026,02,09), Duration = 4, Progress = 20, Predecessor = "5FS" }
                }
            },
            new TaskData
            {
                TaskId = 7,
                TaskName = "Testing",
                StartDate = new DateTime(2026,02,14),
                Duration = 4,
                Progress = 10,
                Predecessor = "4FS",
                SubTasks = new List<TaskData>
                {
                    new TaskData { TaskId = 8, TaskName = "Unit Tests", StartDate = new DateTime(2026,02,14), Duration = 2, Progress = 0, Predecessor = "6FS" },
                    new TaskData { TaskId = 9, TaskName = "Integration Tests", StartDate = new DateTime(2026,02,16), Duration = 2, Progress = 0, Predecessor = "8FS" }
                }
            }
        };
    }

    public class TaskData
    {
        public int TaskId { get; set; }
        public string TaskName { get; set; } = string.Empty;
        public DateTime StartDate { get; set; }
        public int Duration { get; set; }
        public int Progress { get; set; }
        public string Predecessor { get; set; } = string.Empty;
        public List<TaskData>? SubTasks { get; set; } = new();
    }
}
