    };
    protected override void OnInitialized()
    {
        projectNewData = projectData;
        InitializeCustomDataSource();
    }
    private void InitializeCustomDataSource()
    {
        foreach (var item in customItemsSample)
        {
            CustomListPdfData.Add(new CustomData { Name = item, Value = item });
        }
    }
    private void ChangeExportProperties(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, CustomData> args)
    {
        switch (args.Value)
        {
            case "PdfExportData":
                projectNewData = basicData;
                eventMarkers = new List<GanttEventMarker>
            {
                new GanttEventMarker { Day = new DateTime(2019, 4, 10), Label = "Project approval and kick-off" }
            };
                holidays = new List<GanttHoliday>
            {
                new GanttHoliday { From = new DateTime(2019, 4, 4), To = new DateTime(2019, 4, 5) }
            };
                gridLines = Syncfusion.Blazor.Gantt.GridLine.Both;
                break;
            case "EventMarkersData":
                projectNewData = basicData;
                eventMarkers = new List<GanttEventMarker>
            {
                new GanttEventMarker { Day = new DateTime(2019, 5, 3), Label = "Project approval and kick-off" }
            };
                holidays = new List<GanttHoliday>
            {
                new GanttHoliday { From = new DateTime(2019, 5, 7), To = new DateTime(2019, 5, 7) }
            };
                gridLines = Syncfusion.Blazor.Gantt.GridLine.Both;
                break;
            case "TaskIndicatorsData":
                projectNewData = indicatorData;
                break;
            case "TaskIndicatorsWithHtmlName":
                projectNewData = indicatorData;
                break;
            case "TaskIndicatorsWithDifferentDate":
                projectNewData = indicatorData;
                break;
            case "TaskAndProjectIndicatorsData":
                projectNewData = indicatorData;
                break;
            case "NewProjectTaskData":
                projectNewData = projectData;
                break;
            case "LoclizationData":
                projectNewData = localizationData;
                break;
        }
    }

    private void GetExportProperties(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, ExportPropertyData> args)
    {
        var exportProps = new GanttPdfExportProperties();

        switch (args.ItemData.Id)
        {
            case "customRangeExport":
                customRangeStart = new DateTime(2019, 4, 1);
                customRangeEnd = new DateTime(2019, 4, 25);
                isCustomRangeExport = true;
                break;

            case "theme-Fluent":
                exportProps.Theme = GanttPdfTheme.Fluent;
                break;

            case "theme-Bootstrap":
                exportProps.Theme = GanttPdfTheme.Bootstrap;
                break;

            case "theme-Material3":
                exportProps.Theme = GanttPdfTheme.Material3;
                break;

            case "theme-Fabric":
                exportProps.Theme = GanttPdfTheme.Fabric;
                break;

            case "theme-Bootstrap4":
                exportProps.Theme = GanttPdfTheme.Bootstrap4;
                break;

            case "label-Template":
                isLabelTemplate = true;
                break;
            case "localization":
                exportProps.Style = new PdfGanttStyle()
                {
                    CellStyle = new PdfElementStyle() { Font = new PdfGridFont() { FontFamily = base64Content, IsTrueType = true } },
                    LabelStyleSettings = new PdfLabelSettings() { RightLabel = new PdfElementStyle() { Font = new PdfGridFont() { FontFamily = base64Content, IsTrueType = true } } }
                };
                break;
            case "pdf-cancel":
                isPdfExportCanceled = true;
                break;
            default:
                break;
        }

        GanttExportProperties = exportProps;
    }

    private async Task OnToolbarClick(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (args.Item.Id == "GanttPdfCustomization_PdfExport")
        {
            await Gantt.ExportToPdfAsync(GanttExportProperties,true);
        }
    }

    private async Task PdfExportingHandler(PdfExportEventArgs args)
    {
        if (isCustomRangeExport)
        {
            args.RangeStart = customRangeStart;
            args.RangeEnd = customRangeEnd;
            isCustomRangeExport = false;
        }
        args.Cancel = isPdfExportCanceled;
        await Task.CompletedTask;
    }

    private async Task PdfQueryTaskbarInfoHandler(PdfQueryTaskbarInfoEventArgs<GanttTask> args)
    {
        if (isLabelTemplate && args.Data.TaskID == 2)
        {
            args.LabelSettings.LeftLabelValue = "Custom Label";
            args.LabelSettings.LeftLabel = new PdfElementStyle { Font = new PdfGridFont { FontSize = 4, TextColor = "#0000FF", FontStyle = PdfFontStyle.Bold } };
        }
        await Task.CompletedTask;
    }

    public class GanttTask
    {
        public int TaskID { get; set; }
        public string TaskName { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public double Progress { get; set; }
        public int Duration { get; set; }
        public string Predecessor { get; set; }
        public DateTime? BaselineStartDate { get; set; }
        public DateTime? BaselineEndDate { get; set; }
        public List<GanttTask> Subtasks { get; set; }
        public List<GanttIndicator> Indicators { get; set; }
        public bool IsManual { get; set; }
    }

    public class GanttIndicator
    {
        public DateTime Date { get; set; }
        public string Name { get; set; }
        public string Tooltip { get; set; }
    }

    public class CustomData
    {
        public string Name { get; set; }
        public string Value { get; set; }
    }

    public class ExportPropertyData
    {
        public string Id { get; set; }
        public string Text { get; set; }
    }

