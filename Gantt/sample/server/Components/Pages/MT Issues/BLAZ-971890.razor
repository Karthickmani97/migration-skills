<button @onclick="MergeTaskHandler">Merge Task</button>
<button @onclick="SplitTask" class="btn btn-success">SplitTask</button>
<button @onclick="Refresh">Refresh</button>
<div class="col-lg-8 control-section sb-property-border" style="float:left">
    <div class="content-wrapper">
        <div class="row">
            <SfGantt @ref="GanttObject" ID="Gantt" DateFormat="hh:mm" IncludeWeekend="true" DurationUnit="DurationUnit.Hour" TValue="TaskData" GridLines="Syncfusion.Blazor.Gantt.GridLine.Both" EnableContextMenu DataSource="@TaskCollection" Height="550px" Width="100%" AllowRowDragAndDrop="true"
                     Toolbar="@(new List<Object>() { "Add", "Cancel", "Update" , "Delete", "Edit", "CollapseAll", "ExpandAll", "ZoomIn", "ZoomOut", "ZoomToFit","PrevTimeSpan","NextTimeSpan" })" AllowResizing>
                <GanttTaskFields Id="SplitId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
                                 ParentID="ParentId" Dependency="Predecessor">
                </GanttTaskFields>
                <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true"></GanttEditSettings>
                <GanttSegmentFields PrimaryKey="id" ForeignKey="SplitId" StartDate="StartDate" EndDate="EndDate" Duration="Duration" TValue="TaskData" TSegments="SegmentModel" SegmentChanging="SegmentSaveHanlder" DataSource="segmentCollection">

                </GanttSegmentFields>
                @* <GanttTaskbarSettings AllowTaskbarDragAndDrop="true" EnableMultiTaskbar="true"></GanttTaskbarSettings> *@
               
                <GanttTimelineSettings TimelineUnitSize="@DefaultUnitWidth" WeekStartDay="@weekstartDay">
                    <GanttTopTierSettings Unit="@TopTierUnit" Count="@TopTierCount" Format="@TopTierFormat"></GanttTopTierSettings>
                    <GanttBottomTierSettings Unit="@BottomTierUnit" Count="@BottomTierCount" Format="@BottomTierFormat"></GanttBottomTierSettings>
                </GanttTimelineSettings>
                <GanttDayWorkingTimeCollection>
                    <GanttDayWorkingTime From="0" To="23"></GanttDayWorkingTime>
                </GanttDayWorkingTimeCollection>
                <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
                <GanttEvents TaskbarEditing="TaskbarEditingHandler" TaskbarEdited="TaskbarEditedHandler" OnActionBegin="ActionBeginHandler" OnActionComplete="ActionCompleteHandler" RowUpdated="RowCreatedHandler" TValue="TaskData"></GanttEvents>
            </SfGantt>
        </div>
    </div>
</div>
<div class="col-lg-4 property-section" style="float:left">
    <div class="property-panel-section">
        <div class="property-panel-header">Properties</div><div class="property-panel-content">
