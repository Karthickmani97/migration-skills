    private void AutoCompleteValueChangedHandler(string value)
    {
        if (!string.IsNullOrEmpty(value))
        {
            isRender = true;
            InvokeAsync(StateHasChanged);
        }
    }
    private async Task MethodValueChangedHandler(string value)
    {
        if (!string.IsNullOrEmpty(value))
        {
            await InvokeSelectedMethod(value);
        }
    }

    private void SetInputValue()
    {
        if (autoCompleteInstance?.Value == null)
            return;

        string selectedField = autoCompleteInstance.Value;
        if(selectedField == "DataSource")
        {
            if(dropdownInstance != null){
                if (dropdownInstance.Value == "Empty DataSource"){
                    FeatureParams.DataSource = new List<GanttDataModel.CustomTaskDataModel>();
                }
                else if (dropdownInstance.Value == "Virtual DataSource")
                {
                    FeatureParams.DataSource = GanttDataModel.GetVirtualTaskCollection();
                }
                else if (dropdownInstance.Value == "Custom DataSource")
                {
                    FeatureParams.DataSource = GanttDataModel.GetCustomTaskCollection();
                }
                else{
                    FeatureParams.DataSource = GanttDataModel.GetBasicTaskCollection();
                }
            }
            autoCompleteInstance.Value = null;
            return;
        }
        
        if (selectedField == "WorkWeek" || selectedField == "ColumnMenuItems")
        {
            string input = inputInstance.Value;

            string[] splittedValue = input.Replace("\"", "").Split(", ");
            if (selectedField == "WorkWeek")
            {
                FeatureParams.WorkWeek = splittedValue;
            }
            else if (selectedField == "ColumnMenuItems")
            {
                FeatureParams.ColumnMenuItems = splittedValue;
            }
            autoCompleteInstance.Value = null;
            inputInstance.Value = null;
            return;
        }
        var property = FeatureParams.GetType().GetProperty(selectedField);

        if (property == null)
            return;
        object selectedValue = null;
        if (valueAutoCompleteInstance?.Value != null){
            selectedValue = valueAutoCompleteInstance.Value is GanttFieldValue fieldValue
        ? fieldValue.ActualValue
        : valueAutoCompleteInstance.Value;
        }
        if (selectedField == "IsHierarchy")
        {
            if (selectedValue.ToString() == "True")
            {
                FeatureParams.DataSource = GanttDataModel.GetHierarchicalCollection();
            }
            else
            {
                FeatureParams.DataSource = GanttDataModel.GetBasicTaskCollection();
            }
        }
        object value = property.PropertyType switch
        {
            Type t when t == typeof(DateTime) && (selectedField == "ProjectStartDate" || selectedField == "ProjectEndDate")
                => dateTimeInstance?.Value ?? default,

            Type t when t == typeof(bool) && valueAutoCompleteInstance.Value is GanttFieldValue fieldValue && fieldValue.ActualValue is bool boolValue
    => boolValue,

            Type t when t == typeof(int) && int.TryParse(inputInstance?.Value, out int intValue)
                => intValue,

            Type t when t == typeof(string)
                => inputInstance?.Value,

            Type t when t.IsEnum => selectedValue is Enum
    ? selectedValue
    : Enum.ToObject(t, Convert.ToInt32(selectedValue)),

            _ => ganttValues.Find(v => v.ToString() == inputInstance?.Value)
        };


        if (value != null && property.PropertyType.IsAssignableFrom(value.GetType()))
        {
            property.SetValue(FeatureParams, value);
        }
        autoCompleteInstance.Value = null;
        if(inputInstance != null){
            inputInstance.Value = null;
        }
        if (valueAutoCompleteInstance?.Value != null){
            valueAutoCompleteInstance.Value = null;
        }
    }
        
    public Task HandleEventAsync(EventCallbackWorkItem callback, object? arg) => callback.InvokeAsync(arg);
