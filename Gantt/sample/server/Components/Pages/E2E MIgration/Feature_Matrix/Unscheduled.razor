@page "/E2EMigration/UnScheduleEdit"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
<div>@message</div>
<SfGantt @ref="Gantt" ID="Unscheduled" DataSource="@TaskCollection" Toolbar="@(new List<string>() { "Add", "Cancel", "Delete", "Edit" })" Height="450px" Width="1400px" AllowUnscheduledTasks="true" >
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId" >
    </GanttTaskFields>
    <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true"></GanttEditSettings>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
     <GanttEvents TValue="TaskData" Created="Created"OnActionFailure="ActionFailureHandler" ></GanttEvents>
</SfGantt>

@code{
