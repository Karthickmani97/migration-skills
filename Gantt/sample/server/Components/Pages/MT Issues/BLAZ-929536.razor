                        <GanttBottomTierSettings Unit="TimelineViewMode.Week" Format="dd"></GanttBottomTierSettings>
                    </GanttTimelineSettings>
                    <GanttSplitterSettings Position="500px"> </GanttSplitterSettings>
                    <GanttEvents OnToolbarClick="ToolbarClickHandler" TValue="OverviewData.TaskData"></GanttEvents>
