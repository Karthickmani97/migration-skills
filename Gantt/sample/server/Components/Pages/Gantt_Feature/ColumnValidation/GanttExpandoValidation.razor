@page "/gantt-expando-validation"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.DropDowns
@using System.Dynamic
@using System.ComponentModel.DataAnnotations;
<div class="col-lg-12 control-section">
    <div class="content-wrapper">
        <div class="row">
            <SfGantt EnableContextMenu="true" AllowReordering="true" RenderBaseline="true" TValue="ExpandoObject" AllowSorting="true" AllowFiltering="true" DataSource="@GanttExpandoData" Height="450px" Width="1400px" HighlightWeekends="true"
                     Toolbar="@(new List<string>(){ "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll","Indent","Outdent"})"
                     AllowSelection="true"  TreeColumnIndex="1">

                <GanttTaskFields Id="TaskId" Name="ActivityName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
                                 Dependency="Predecessor" BaselineEndDate="BaselineEndDate" BaselineStartDate="BaselineStartDate" Notes="Notes" ParentID="ParentId"
                                 TaskType="TaskType" Work="Work"></GanttTaskFields>

                <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true"></GanttEditSettings>
                <GanttColumns>
                    <GanttColumn Field="TaskId" HeaderText="Task ID" IsPrimaryKey="true"
                                 Width="80" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right">
                    </GanttColumn>
                    @* <GanttColumn Field="ActivityName" HeaderText="Task Name" Width="160"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, MinLength = 5, MaxLength = 10, Messages = new Dictionary<string, object>() { { "required", "Task Name is required." }, { "minlength", "Task Name must have at least 5 characters." }, { "maxlength", "Task Name cannot exceed 100 characters." } } })" /> *@
                        <GanttColumn Field="ActivityName" HeaderText="Task Name" Width="160"
                    ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules {
                        Required = true,
                        RangeLength = new object[] { 5, 10 },
                        Messages = new Dictionary<string, object>() {
                            { "required", "Task Name is required." },
                            { "rangelength", "Task Name must be between 5 and 10 characters." }
                        }
                    })" />
                    <GanttColumn Field="Duration" HeaderText="Duration" Width="100" 
                                 TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right"
                    ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, })">
                    </GanttColumn>
                    <GanttColumn Field="Predecessor" HeaderText="Dependency" Width="100"
                                 TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right">
                    </GanttColumn>
                    <GanttColumn Field="Progress" HeaderText="Progress" Width="100" EditType="Syncfusion.Blazor.Grids.EditType.NumericEdit"
                                 TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true,Number = true, Min = 5,Max = 50, Messages = new Dictionary<string, object>() { { "required", "Progress is required." }, { "min", "Progress must be greater than 5" }, { "max", "Progress must be lesser than 50" } } })">
                    </GanttColumn>
                    <GanttColumn Field="Email" HeaderText="Email" Width="200" EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, Email = true, Messages = new Dictionary<string, object>() { { "required", "Email is required." }, { "email", "Invalid Email format." } } })">
                    </GanttColumn>
                    <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150"
                                 Format="d" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true,Range = new object[] { new DateTime(2020, 1, 1), DateTime.Now }, Messages = new Dictionary<string, object>() { { "required", "Start Date is required." } } })">
                    </GanttColumn>
                    <GanttColumn Field="EndDate" HeaderText="End Date" Width="150"
                                 Format="g" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, Range = new object[] { new DateTime(2020, 1, 1), DateTime.Now }, Messages = new Dictionary<string, object>() { { "required", "End Date is required." } } })">
                    </GanttColumn>
                     <GanttColumn Field="Work" HeaderText="Work"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules {
                                     Required = true,
                                     Number = true,
                                     Range = new object[] { 5, 200 }
                                 })">
                    </GanttColumn>

                    <GanttColumn Field="BaselineStartDate" HeaderText="Baseline Start" Width="150" Format="d"  EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit"
                                 ValidationRules="@(new ValidationRules {
                                     Required = true,
                                     Range = new object[] { new DateTime(2020, 1, 1), DateTime.Now },
                                     Messages = new Dictionary<string, object> {
                                         { "Required", "Baseline Start Date is required." },
                                         { "Range", "Baseline Start Date must be between 01-Jan-2020 and 31-Dec-2030." }
                                     }
                                 })" />
                    <GanttColumn Field="BaselineEndDate" HeaderText="Baseline End" Width="150" Format="d"  EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit"
                                 ValidationRules="@(new ValidationRules {
                                     Required = true,
                                     Range = new object[] { new DateTime(2020, 1, 1), DateTime.Now },
                                     Messages = new Dictionary<string, object> {
                                         { "Required", "Baseline End Date is required." },
                                         { "Range", "Baseline End Date must be between 01-Jan-2020 and 31-Dec-2030." }
                                     }
                                 })" />

                    <GanttColumn Field="Username" HeaderText="Username" Width="150" EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, RegexPattern = @"^[a-zA-Z0-9_]*$", Messages = new Dictionary<string, object>() { { "required", "Username is required." }, { "regexpattern", "Username can only contain letters, numbers, and underscores." } } })">
                    </GanttColumn>
                    <GanttColumn Field="Password" HeaderText="Password" Width="150" EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, MinLength = 8, MaxLength = 20, Messages = new Dictionary<string, object>() { { "minlength", "Password must be at least 8 characters." }, { "maxlength", "Password cannot exceed 20 characters." } } })">
                    </GanttColumn>
                    <GanttColumn Field="Website" HeaderText="Website" Width="200" EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, Messages = new Dictionary<string, object>() { { "required", "Website is required." }, { "url", "Invalid URL format." } } })">
                    </GanttColumn>
                    <GanttColumn Field="CustomData" HeaderText="Custom Data (String)" Width="200" EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, Messages = new Dictionary<string, object>() { { "required", "Custom Data is required." } } })">
                    </GanttColumn>
                    <GanttColumn Field="Notes" HeaderText="Notes"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, Messages = new Dictionary<string, object> { { "required", "Notes is required."  },}})"></GanttColumn>


                   <GanttColumn Field="TaskType" HeaderText="Task Type" Width="120" EditType="Syncfusion.Blazor.Grids.EditType.DropDownEdit"
                                 ValidationRules="@(new ValidationRules { Required = true, Messages = new Dictionary<string, object>() { { "Required", "Task Type is required." } } })">
  
                    </GanttColumn>


                    @* --- New Custom Columns --- *@
                    <GanttColumn Field="ProjectBudget" HeaderText="Project Budget" Width="150" EditType="Syncfusion.Blazor.Grids.EditType.NumericEdit" Format="C2"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true, Number = true, Range = new object[] { 100, 1000000 }, Messages = new Dictionary<string, object>() { { "required", "Project Budget is required." }, { "range", "Project Budget must be between $100 and $1,000,000." } } })" />

                   

                    <GanttColumn Field="ReviewDate" HeaderText="Review Date" Width="150" Format="d" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit"
                                 ValidationRules="@(new Syncfusion.Blazor.Grids.ValidationRules { Required = true,Range = new object[] { new DateTime(2020, 1, 1), DateTime.Now }, Messages = new Dictionary<string, object>() { { "required", "Review Date is required." }, { "range", "Review Date can be with in the provided range." } } })" />


                </GanttColumns>
                <GanttLabelSettings LeftLabel="ActivityName" TValue="ExpandoObject">
                </GanttLabelSettings>
                <GanttSegmentFields PrimaryKey="id" ForeignKey="TaskId" StartDate="StartDate" EndDate="EndDate" Duration="Duration" TValue="ExpandoObject" TSegments="SegmentModel" DataSource="SegmentCollection"></GanttSegmentFields>
                <GanttSplitterSettings Position="40%"> </GanttSplitterSettings>
            </SfGantt>
        </div>
    </div>
</div>
