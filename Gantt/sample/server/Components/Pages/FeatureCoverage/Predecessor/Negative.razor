                StartDate = new DateTime(2019, 04, 02),
                EndDate = new DateTime(2019, 04, 21),
            },
            new TaskInfoModel() {
                TaskId = -2,
                TaskName = "Perform soil test",
                StartDate = new DateTime(2019, 04, 02),
                Duration = "4",
                Progress = 40,
            },
            new TaskInfoModel() {
                TaskId = 3,
                TaskName = "Perform soil test",
                StartDate = new DateTime(2019, 04, 02),
                Duration = "4",
                Progress = 40,
                Predecessor = "-2FS - 2Days",
            },
             new TaskInfoModel() {
                TaskId = 4,
