<button @onclick="Add">Add Assignment</button>
<button @onclick="Update">Update Assignment</button>
<button @onclick="Delete">Delete Assignment</button>
<button @onclick="GetResource">GetResource</button>
<button @onclick="GetAssignment">GetAssignments</button>
