    private async void MergeTask()
    {
        List<ValueTuple<int, int>> indexes = new List<ValueTuple<int, int>>();
        indexes.Add((0, 1));
        indexes.Add((-1, 0));
        indexes.Add((2, 5));
        indexes.Add((3, 4));
        await Gantt.MergeTaskAsync(3, indexes);
    }

