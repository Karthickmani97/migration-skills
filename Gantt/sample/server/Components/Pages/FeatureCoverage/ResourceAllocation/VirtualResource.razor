            TaskCollection = GetTaskCollection();
        }
    }
    private void HandleTaskTypeCollectionChange(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, DropdownData> args)
    {
        selectedTaskType = args.Value != null ? args.Value : selectedTaskType;
    }

    private void HandlePublicMethods(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, DropdownData> args)
    {
        selectedMethod = args.Value != null ? args.Value : selectedMethod;
    }
    private void MethodCallingHandler()
    {
        switch (selectedMethod)
        {
            case "AddWithResource":
                AddType = selectedMethod;
                HandleAddRecord();
                break;
            case "AddWithOutResource":
                AddType = selectedMethod;
                HandleAddRecord();
                break;
            case "DeleteRecord":
                HandleDeleteRecord();
                break;
            case "DeleteRecordCancel":
                HandleDeleteRecord();
                break;
            case "RemoveAssignment":
                HandleRemoveAssignment();
                break;

            case "AddAssignment":
                HandleAddAssignment();
                break;

            case "UpdateAssignment":
                HandleUpdateAssignment();
                break;

            default:
                break;
        }
    }
    private async void HandleAddRecord()
    {
        var record = new AssignmentModel();
        TaskInfoModel data = new TaskInfoModel();
        if (AddType == "AddWithResource")
        {
            record = new AssignmentModel() { PrimaryId = ++assignmentCount, TaskId = ++dataCount, ResourceId = 1 };
            data = new TaskInfoModel() { TaskId = TaskCollection.Count + 1, TaskName = "New Added Task", StartDate = new DateTime(2022, 01, 04), ParentId = 1, Work = 24, Duration = "3", TaskType = TaskType.FixedUnit };
            await Gantt.AddRecordAsync(data, null, null, record);
        }
        else
        {
            data = new TaskInfoModel() { TaskId = TaskCollection.Count + 1, TaskName = "New Added Task", StartDate = new DateTime(2022, 03, 14), ParentId = 1, Work = 24, Duration = "3", TaskType = TaskType.FixedUnit };
            await Gantt.AddRecordAsync(data);
        }
    }
    private async void HandleDeleteRecord()
    {
        if (selectedMethod == "DeleteRecordCancel")
        {
            await Gantt.DeleteRecordAsync("3");
        }
        else
        {
            TaskInfoModel data = new TaskInfoModel() { TaskId = 2, TaskName = "Requirement Gathering", ParentId = 1, StartDate = new DateTime(2022, 03, 15), EndDate = new DateTime(2022, 01, 08), TaskType = TaskType.FixedDuration, Duration = "2", Work = 16, IsManual = true };
            await Gantt.UpdateRecordByIDAsync(data);
            await Gantt.DeleteRecordAsync("2");
        }
    }
