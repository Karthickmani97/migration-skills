				BottomTierFormat = "hh";
				break;
			default:
				changedBottomUnit = TimelineViewMode.Day;
				DayFormatValue = DayFormats;
				BottomTierFormat = "dd";
				break;
		}
		this.UpdateUnitWidth(args.Value, "bottom");
		BottomTierUnit = changedBottomUnit;
	}
