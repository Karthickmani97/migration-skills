@page "/BLAZ-1018861"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@using System.Collections.ObjectModel
@using System.ComponentModel
@using System.Runtime.CompilerServices
<SfButton OnClick="() => TaskCollection = GetTaskCollection()">Get Tasks</SfButton>
<SfButton OnClick="CustomIndent">Indent Task</SfButton>
<SfButton OnClick="CustomOutdent">Outdent Task</SfButton>
<SfButton OnClick="CustomAdd">Add Task</SfButton>
<SfButton OnClick="ForceRerender">Force Rerender</SfButton>
@if (IsGanttVisible)
{
    <SfGantt @ref="Gantt" class="gantt" ID="ScheduleBuilder" DataSource="@TaskCollection" Height="500px" Width="100%" TreeColumnIndex="0" CopyHierarchyMode="Syncfusion.Blazor.TreeGrid.CopyHierarchyType.None"
             TaskbarHeight="30"
             RowHeight="30"
             EnableContextMenu="true"
             EnableRowHover
             TaskMode="ScheduleMode.Custom"
             AllowFiltering="true"
             HighlightWeekends="true"
             RenderBaseline="true"
             GridLines="Syncfusion.Blazor.Gantt.GridLine.Both"
             ScrollToTaskbarOnClick
             EnablePredecessorValidation="true"
             AutoUpdatePredecessorOffset="false"
             AllowResizing
             AllowRowDragAndDrop="@true"
             EnableRowVirtualization
             EnableTimelineVirtualization
             OverscanCount="-1"
             AllowPdfExport
             EnableCriticalPath
             ProjectStartDate="new DateTime(2024, 04, 05)">
        <GanttColumns>
            <GanttColumn Field="TaskID" HeaderText="ID" Width="120">
                <Template>
                    @{
                        var data = context as TaskData;
                    }
                    <span>@($"#{data?.TaskID}")</span>
                </Template>
            </GanttColumn>
            <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250"></GanttColumn>
            <GanttColumn Field="StartDate" HeaderText="Start Date" Format="yyyy-MM-dd" Width="150"></GanttColumn>
            <GanttColumn Field="EndDate" HeaderText="End Date" Format="yyyy-MM-dd" Width="150"></GanttColumn>
            <GanttColumn Field="Duration" HeaderText="Duration" Width="80"></GanttColumn>
            <GanttColumn Field="Predecessor" HeaderText="Predecessors" Width="80"></GanttColumn>

        </GanttColumns>
        <GanttTaskFields Id="TaskID" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId" Work="Work" TaskType="TaskType" Dependency="Predecessor" Manual="IsManual" ExpandState="IsExpanded" Notes="Notes">
        </GanttTaskFields><GanttTooltipSettings TValue="TaskData" ShowTooltipOnEditing="false"></GanttTooltipSettings>
        <GanttEditSettings AllowSchedulingOnDrag="@true" AllowAdding="@true" AllowDeleting="false" AllowEditing="@true" AllowTaskbarEditing="@true" ShowDeleteConfirmDialog="false" Mode="Syncfusion.Blazor.Gantt.EditMode.Auto">
        </GanttEditSettings>
        <GanttHolidays>
            @for (var i = 0; i < 24; ++i)
            {
                var exceptionDate = new DateTime(2023, 04, 05).AddDays(i * 28);
                <GanttHoliday Label="@($"Holiday {i}")" From="exceptionDate" To="exceptionDate"></GanttHoliday>
            }
        </GanttHolidays>
        <GanttEvents TValue="TaskData" ContextMenuOpen="() => { }" RowSelected="OnRowSelected" DataBound="DataBoundEvent"></GanttEvents>
        <GanttSelectionSettings Mode="Syncfusion.Blazor.Grids.SelectionMode.Both" Type="Syncfusion.Blazor.Grids.SelectionType.Multiple" AllowDragSelection EnableToggle />
        <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
    </SfGantt>


}
@code {
