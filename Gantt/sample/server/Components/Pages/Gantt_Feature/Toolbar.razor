@page "/toolbar"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.TreeGrid

<button @onclick="Click1" id="Toolbar1">Toolbar1</button>
<button @onclick="Click2" id="Toolbar2">Toolbar2</button>
<br>
<br>
<SfGantt  ID="GanttToolbar" DataSource="@TaskCollection" RowHeight="RowsHeight" 
 GridLines="Syncfusion.Blazor.Gantt.GridLine.Both"
 @ref="Gantt" Toolbar="@Tools" 
 Height="550px" Width="1400px">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate"
                     Duration="Duration" Progress="Progress" Child="SubTasks">
    </GanttTaskFields>
    <GanttEditSettings AllowEditing="true" AllowAdding="true" AllowDeleting="true">
    </GanttEditSettings>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
     <GanttEvents OnToolbarClick="ToolBarClick" Created="Created" TValue="TaskData"></GanttEvents>
</SfGantt>
<style>
    @@font-face {
        font-family: 'e-grid-rowheight';
        src: url(data:application/x-font-ttf;charset=utf-8;base64,) format('truetype');
        font-weight: normal;
        font-style: normal;
    }

    .e-small-icon::before {
        font-family: 'e-grid-rowheight';
        content: '\e707';
    }

    .e-medium-icon::before {
        font-family: 'e-grid-rowheight';
        content: '\e701';
    }

    .e-big-icon::before {
        font-family: 'e-grid-rowheight';
        content: '\e702';
    }
</style>
@code{
    public SfGantt<TaskData> Gantt;
    public List<TaskData> TaskCollection { get; set; }
    public int RowsHeight { get; set; } = 36;
    public List<object> Tools = new List<object>();
    protected override void OnInitialized()
    {
        this.TaskCollection = GetTaskCollection();
        Tools.Add("Add");
        Tools.Add("Update");
        Tools.Add("Cancel");
        Tools.Add("Delete");
        Tools.Add("Edit");
        Tools.Add("CollapseAll");
        Tools.Add("ExpandAll");
    }
    public async Task Created()
    {   
     
    }
    public void Click2() {
        Tools = new List<object>();
        Tools.Add("ZoomToFit");
		Tools.Add("NextTimeSpan");
		Tools.Add("PrevTimeSpan");
        Tools.Add("ZoomIn");
        Tools.Add("ZoomOut");
        Tools.Add(new ToolbarItem() { PrefixIcon = "e-big-icon", Id = "small", Align = ItemAlign.Left, TooltipText = "Small" });
        Tools.Add(new ToolbarItem() { PrefixIcon = "e-medium-icon", Id = "medium", Align = ItemAlign.Left, TooltipText = "Medium" });
        Tools.Add(new ToolbarItem() { PrefixIcon = "e-small-icon", Id = "big", Align = ItemAlign.Left, TooltipText = "Big" });
        Tools.Add(new ToolbarItem() { Id = "showChart", Text = "ShowChart", Align = ItemAlign.Left, TooltipText = "ShowChart" });
        Tools.Add(new ToolbarItem() { Id = "hideChart", Text = "HideChart", Align = ItemAlign.Left, TooltipText = "HideChart" });
    }

     public void Click1() {
        Tools = new List<object>();
        Tools.Add("Add");
        Tools.Add("Update");
        Tools.Add("Cancel");
        Tools.Add("Delete");
        Tools.Add("Edit");
        Tools.Add("CollapseAll");
        Tools.Add("ExpandAll");
        Tools.Add("Indent");
        Tools.Add("Outdent");
    }
    public void ToolBarClick(Syncfusion.Blazor.Navigations.ClickEventArgs Args)
    {
        if (Args.Item.Id == "small")
        {
            RowsHeight = 20;
        }
        if (Args.Item.Id == "medium")
        {
            RowsHeight = 40;
        }
        if (Args.Item.Id == "big")
        {
            RowsHeight = 60;
        }
        if (Args.Item.Id == "showChart")
        {
            this.Gantt.SetSplitterPositionAsync(Syncfusion.Blazor.Gantt.SplitterView.Default);
        }
        if (Args.Item.Id == "hideChart")
        {
            this.Gantt.SetSplitterPositionAsync(Syncfusion.Blazor.Gantt.SplitterView.Grid);
        }

    }
    public class TaskData
