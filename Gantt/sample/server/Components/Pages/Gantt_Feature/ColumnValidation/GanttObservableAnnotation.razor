@page "/gantt-observable-annotation"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Buttons
@using System.Collections.ObjectModel
@using System.ComponentModel
@using System.ComponentModel.DataAnnotations
@using System.Collections.Generic
@using Syncfusion.Blazor.Grids

<div class="col-lg-12 control-section">
    <div class="content-wrapper">
        <div class="row">
            <div style="padding-bottom: 10px;">
                <SfButton ID="add" @onclick="AddRecord">Add Data</SfButton>
                <SfButton ID="del" @onclick="DeleteRecord">Delete Data</SfButton>
                <SfButton ID="update" @onclick="UpdateRecord">Update Data</SfButton>
            </div>

            <SfGantt DataSource="@ObservableData"
                     Height="450px" Width="1400px" RenderBaseline="true" EnableContextMenu="true" AllowSorting="true" AllowFiltering="true"
                     Toolbar="@(new List<string>() { "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll", "Indent", "Outdent" })"
                     AllowSelection="true" TreeColumnIndex="1">
                <GanttTaskFields Id="TaskId"
                                 Name="ActivityName"
                                 StartDate="StartDate"
                                 EndDate="EndDate"
                                 BaselineStartDate="BaselineStartDate"
                                 BaselineEndDate="BaselineEndDate"
                                 Duration="Duration"
                                 Progress="Progress"
                                 Work="Work"
                                 Notes="Notes"
                                 Dependency="Predecessor"
                                 ParentID="ParentId">
                </GanttTaskFields>

                <GanttColumns>
                    <GanttColumn Field="TaskId" HeaderText="ID" Width="90" IsPrimaryKey="true" />
                    <GanttColumn Field="ActivityName" HeaderText="Activity" Width="220"
                                 ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip" />
                    <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150" Format="d" EditType="EditType.DatePickerEdit" />
                    <GanttColumn Field="EndDate" HeaderText="End Date" Width="150" Format="d" EditType="EditType.DatePickerEdit" />
                    <GanttColumn Field="BaselineStartDate" HeaderText="Baseline Start" Width="160" Format="d" EditType="EditType.DatePickerEdit" />
                    <GanttColumn Field="BaselineEndDate" HeaderText="Baseline End" Width="160" Format="d" EditType="EditType.DatePickerEdit" />
                    <GanttColumn Field="Duration" HeaderText="Duration" Width="110"  />
                    <GanttColumn Field="Predecessor" HeaderText="Dependency" Width="140" />
                    <GanttColumn Field="Progress" HeaderText="Progress" Width="120" EditType="EditType.NumericEdit" />
                    <GanttColumn Field="Work" HeaderText="Work" Width="110" />
                    <GanttColumn Field="Notes" HeaderText="Notes" Width="220" />
                    <GanttColumn Field="Email" HeaderText="Email" Width="220" />
                    <GanttColumn Field="Username" HeaderText="Username" Width="160" />
                    <GanttColumn Field="Password" HeaderText="Password" Width="150" />
                    <GanttColumn Field="Website" HeaderText="Website" Width="220" />
                    <GanttColumn Field="CustomData" HeaderText="Custom Data" Width="180" />
                    <GanttColumn Field="TaskType" HeaderText="Task Type" Width="140" />
                    <GanttColumn Field="ReviewDate" HeaderText="Review Date" Width="150" Format="d" EditType="EditType.DatePickerEdit" />
                    <GanttColumn Field="ProjectBudget" HeaderText="Project Budget" Width="160" Format="C2" EditType="EditType.NumericEdit" />
                </GanttColumns>

                <GanttEditSettings AllowEditing="true" AllowAdding="true" AllowDeleting="true" AllowTaskbarEditing="true"></GanttEditSettings>
                <GanttEvents TValue="TaskData" RowUpdated="RowUpdated"></GanttEvents>
            </SfGantt>
        </div>
    </div>
</div>

@code {
    public ObservableCollection<TaskData> ObservableData { get; set; }
    private int recordId = 0;
    private int taskId;

    protected override void OnInitialized()
    {
        ObservableData = ProjectNewData();
    }

    public async Task RowUpdated(RowUpdatedEventArgs<TaskData> args)
    {
        taskId = args.Data.TaskId;
        await Task.CompletedTask;
    }

    public void AddRecord()
    {
        if (ObservableData.Count != 0)
        {
            recordId = ObservableData.Max(data => data.TaskId);
            recordId = Math.Max(recordId, taskId);
        }
        recordId++;
        ObservableData.Insert(0, new TaskData()
        {
            TaskId = recordId,
            ActivityName = "New Activity",
            StartDate = new DateTime(2021, 04, 04),
            EndDate = new DateTime(2021, 04, 08),
            BaselineStartDate = new DateTime(2021, 04, 01),
            BaselineEndDate = new DateTime(2021, 04, 10),
            Duration = 4,
            Progress = 10,
            Work = 8,
            Notes = "New item",
            TaskType = "FixedWork",
            ReviewDate = new DateTime(2021, 04, 08),
            ProjectBudget = 1000
        });
    }

    public void DeleteRecord()
    {
        if (ObservableData.Count != 0)
        {
            int deleteRecordTaskId = ObservableData.First().TaskId;
            ObservableData.Remove(ObservableData.First());
            RemoveChild(deleteRecordTaskId);
        }
    }

    public void RemoveChild(int id)
    {
        var childRecords = new List<TaskData>();
        for (int j = 0; j < ObservableData.Count; j++)
        {
            if (id == ObservableData[j].ParentId)
                childRecords.Add(ObservableData[j]);
        }
        for (int i = childRecords.Count - 1; i >= 0; i--)
        {
            int deleteRecordId = childRecords[i].TaskId;
            RemoveChild(deleteRecordId);
            ObservableData.Remove(childRecords[i]);
        }
    }

    public void UpdateRecord()
    {
        if (ObservableData.Count != 0)
        {
            var first = ObservableData.First();
            first.ActivityName = "Record Updated";
            first.Notes = "Updated Notes";
            first.Progress = Math.Min(50, (first.Progress <= 0 ? 10 : first.Progress + 5));
        }
    }

