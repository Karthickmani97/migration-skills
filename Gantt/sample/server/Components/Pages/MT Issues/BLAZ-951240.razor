    private void MethodCallingHandler()
    {
        switch (selectedMethod)
        {
            case "AddRecord":
                HandleAddRecord();
                break;

            case "RemoveAssignment":
                HandleRemoveAssignment();
                break;

            case "AddAssignment":
                HandleAddAssignment();
                break;

            case "UpdateAssignment":
                HandleUpdateAssignment();
                break;

            default:
                break;
        }
    }
    private async void HandleAddRecord()
    {
        var record = new AssignmentModel();
        TaskInfoModel data = new TaskInfoModel();
        switch (selectedTaskType)
        {
            case "FixedDuration":
                record = new AssignmentModel() { PrimaryId = ++assignmentCount,TaskId = ++dataCount, ResourceId = 1, Unit = unitvalue };
                data = new TaskInfoModel() { TaskId = TaskCollection.Count + 1, TaskName = "New Task Fixed Duration", StartDate = new DateTime(2022, 03, 29), Work = workvalue, Duration = durationvalue, TaskType = TaskType.FixedDuration };
                break;
            case "FixedUnit":
                record = new AssignmentModel() { PrimaryId = ++assignmentCount, TaskId = ++dataCount, ResourceId = 2, Unit = unitvalue };
                data = new TaskInfoModel() { TaskId = TaskCollection.Count + 1, TaskName = "New Task Fixed Unit", StartDate = new DateTime(2022, 03, 29), Work = workvalue, Duration = durationvalue, TaskType = TaskType.FixedUnit };
                break;
            default:
                record = new AssignmentModel() { PrimaryId = ++assignmentCount, TaskId = ++dataCount, ResourceId = 3, Unit = unitvalue };
                data = new TaskInfoModel() { TaskId = TaskCollection.Count + 1, TaskName = "New Task Fixed Work", StartDate = new DateTime(2022, 03, 29), Work = workvalue, Duration = durationvalue, TaskType = TaskType.FixedWork };
                break;
        }
        await Gantt.AddRecordAsync(data, null, null, record);
    }

    private async void HandleRemoveAssignment()
    {
        var record = new AssignmentModel();
        switch (selectedTaskType)
        {
            case "FixedDuration":
