    private async void UpdateCollectionsBasedOnIdType(string idType)
    {
        switch (idType)
        {
            case "int":
                TaskCollectionInt = GetTaskCollectionInt();
                currentDataType = idType;
                break;
            case "object":
                TaskCollectionObject = GetTaskCollectionObject();
                currentDataType = idType;
                break;
            case "string":
