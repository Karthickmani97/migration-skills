@page "/Resource-sb"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.TreeGrid
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.DropDowns

<div>
<button id="Scroll_Rows" class="btn btn-primary" @onclick="Scroll">Scroll</button>
</div>

<div class="col-lg-12 control-section">
    <div class="content-wrapper">
        <div class="row">
            <div class="e-switch-control">
                <label class="showhide"> Project View </label>
                <SfSwitch ValueChange="Resource" @bind-Checked="@Check" TChecked="bool"></SfSwitch>
                <label class="showhide"> Resource View </label>
            </div>
            <SfGantt @ref="Gantt" ID="Gamtt" ShowOverallocation="@ShowOverallocation" EnableContextMenu="true" AllowFiltering="true" AllowSorting="true" TreeColumnIndex="1" DataSource="@TaskCollection" Height="550px" Width="100%" AllowRowDragAndDrop="true" RowHeight="37"
                     Toolbar="@(new List<Object>() { "Add", "Cancel", "Update" , "Delete", "Edit", "CollapseAll", "ExpandAll", "ZoomIn", "ZoomOut", "ZoomToFit", "NextTimeSpan", "PrevTimeSpan", "Search", new ToolbarItem() { Text = "Show/Hide Overallocation", TooltipText = "Show/Hide Overallocation", Id = "ShowHideBar", Visible=Check, PrefixIcon="e-icons e-eye" } })" AllowResizing ViewType="@viewType">
                <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
                                 ParentID="ParentId" Work="Work" Dependency="Predecessor">
                </GanttTaskFields>
               <GanttResource TValue="TaskData" Group="ResourceGroup" DataSource="@ResourceCollection" Id="ResourceId" Name="ResourceName" MaxUnits="Unit" TResources="ResourceAlloacteData"></GanttResource>
<GanttAssignmentFields DataSource="AssignmentCollection" PrimaryKey="@nameof(AssignmentModel.PrimaryId)" TaskID="@nameof(AssignmentModel.TaskId)" ResourceID="@nameof(AssignmentModel.ResourceId)" Units="@nameof(AssignmentModel.Unit)" TValue="TaskData" TAssignment="AssignmentModel">
    </GanttAssignmentFields>
                <GanttLabelSettings RightLabel="Resources" TaskLabel="Progress" TValue="TaskData"></GanttLabelSettings>
                <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true" ShowDeleteConfirmDialog="true"></GanttEditSettings>
                <GanttColumns>
                    <GanttColumn Field="TaskId" Visible=false></GanttColumn>
                    <GanttColumn Field="TaskName" HeaderText="Name" Width="250"></GanttColumn>
                    <GanttColumn Field="Work" HeaderText="Work"></GanttColumn>
                    <GanttColumn Field="Progress"></GanttColumn>
                    <GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
                    <GanttColumn Field="Duration" HeaderText="Duration"></GanttColumn>
                    <GanttColumn Field="Predecessor" HeaderText="Dependency"></GanttColumn>
                </GanttColumns>
                <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
                <GanttEvents OnToolbarClick="ToolbarClickHandler" TValue="TaskData"></GanttEvents>
            </SfGantt>
        </div>
         <div class="row">
              <div class="e-switch-control" style="width: 750px;">
                <label class="showhide" style="padding: 10px 15px 10px 10px"> Methods: </label>
                  <SfDropDownList Width="25%" @ref="@DropdownMode" TValue="string" TItem="DropDownData" DataSource="@Methods" @bind-Value="@Mode" AllowFiltering="true" Placeholder=" ">
                    <DropDownListEvents TValue="string" ValueChange="MethodChange" TItem="DropDownData"></DropDownListEvents>
                    <DropDownListFieldSettings Text="Mode" Value="ID"></DropDownListFieldSettings>
                </SfDropDownList>
            </div>
         </div>
    </div>
</div>
<style>
    .showhide {
        font-size: 15px;
        font-weight: 400;
        margin-bottom: 1px;
        padding:10px;
    }
    .e-switch-control {
        display: flex;
        align-items: center;
    }
</style>
@code {
    public SfGantt<TaskData> Gantt;
    private DateTime ProjectStart = new DateTime(2022, 03, 25);
    private DateTime ProjectEnd = new DateTime(2022, 05, 10);
    private List<TaskData> TaskCollection { get; set; }
    private SfDropDownList<string, DropDownData> DropdownMode { get; set; }
    private static List<AssignmentModel> AssignmentCollection { get; set; } = new();
    private List<DropDownData> Methods { get; set; } = new List<DropDownData>();
    private string Mode { get; set; }
     public class DropDownData
    {
        public string ID { get; set; }
        public string Mode { get; set; }
    }
    private List<ResourceAlloacteData> ResourceCollection { get; set; }
    private ViewType viewType { get; set; } = ViewType.ResourceView;
    private bool ShowOverallocation { get; set; } = true;
    private Boolean Check = true;
    protected override void OnInitialized()
    {
        this.TaskCollection = GetTaskCollection();
        this.ResourceCollection = GetResources;
        AssignmentCollection = GetAssignmentCollection();
        this.Methods.Add(new DropDownData() { ID = "FilterByColumn", Mode = "FilterByColumn"});
        this.Methods.Add(new DropDownData() { ID = "FilterByDate", Mode = "FilterByDate"});
        this.Methods.Add(new DropDownData() { ID ="ResetZoomAsync", Mode = "ResetZoomAsync"});
        this.Methods.Add(new DropDownData() { ID = "UpdateProjectDates", Mode = "UpdateProjectDates" });
    }
      public void MethodChange(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, DropDownData> args)
    {
        if (args.Value == "FilterByColumn")
        {
            this.Gantt.FilterByColumnAsync("Duration", "equal", "7.5", "and", true, false);
        }
        if (args.Value == "FilterByDate")
        {
            this.Gantt.FilterByColumnAsync("StartDate", "greaterthan", "4/6/2022", "or", true, false);
        }
         if (args.Value == "ResetZoomAsync")
        {
            this.Gantt.ResetZoomAsync();
        } 
         if (args.Value == "UpdateProjectDates")
        {
            this.Gantt.UpdateProjectDates(new DateTime(2022, 04, 14), new DateTime(2022, 05, 20));
        }
    }
    private async Task Scroll()
    {
        Gantt.ScrollIntoViewAsync(0, 30);
    }
