    <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
</SfDropDownList>
<SfDropDownList @bind-Value="selectedMethod" DataSource="PublicMethods" Placeholder="Public Method" Width="150px">
    <DropDownListEvents TItem="DropdownData" TValue="string" ValueChange="HandlePublicMethods"></DropDownListEvents>
    <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
</SfDropDownList>
<span>Duration</span>
<SfTextBox @bind-Value="durationvalue"  Placeholder="@durationvalue.ToString()" Width="50px"></SfTextBox>
<span>Work</span>
