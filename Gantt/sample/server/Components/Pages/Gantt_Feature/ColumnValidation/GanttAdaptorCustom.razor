    public class CustomValidationStartDate : ValidationAttribute
    {
        private static readonly DateTime Min = new DateTime(2020, 1, 1);

        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            if (value is not DateTime dt)
                return new ValidationResult("Start Date is required.");

            var dateOnly = dt.Date;
            var max = DateTime.Today;

            if (dateOnly < Min || dateOnly > max)
                return new ValidationResult("Start Date must be between 01-Jan-2020 and today.");

            return ValidationResult.Success;
        }
    }

    public class CustomValidationEndDate : ValidationAttribute
    {
        private static readonly DateTime Min = new DateTime(2020, 1, 1);

        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            if (value is not DateTime dt)
                return new ValidationResult("End Date is required.");

            var dateOnly = dt.Date;
            var max = DateTime.Today;

            if (dateOnly < Min || dateOnly > max)
                return new ValidationResult("End Date must be between 01-Jan-2020 and today.");

            return ValidationResult.Success;
        }
    }

    public class CustomValidationBaselineStartDate : ValidationAttribute
    {
        private static readonly DateTime Min = new DateTime(2020, 1, 1);
        private static readonly DateTime Max = new DateTime(2030, 12, 31);

        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            if (value == null)
                return new ValidationResult("Baseline Start Date is required.");
            var dt = (DateTime)value;
            if (dt < Min || dt > Max)
                return new ValidationResult("Baseline Start Date must be between 01-Jan-2020 and 31-Dec-2030.");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationBaselineEndDate : ValidationAttribute
    {
        private static readonly DateTime Min = new DateTime(2020, 1, 1);
        private static readonly DateTime Max = new DateTime(2030, 12, 31);

        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            if (value == null)
                return new ValidationResult("Baseline End Date is required.");
            var dt = (DateTime)value;
            if (dt < Min || dt > Max)
                return new ValidationResult("Baseline End Date must be between 01-Jan-2020 and 31-Dec-2030.");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationReviewDate : ValidationAttribute
    {
        private static readonly DateTime Min = new DateTime(2020, 1, 1);
        private static readonly DateTime Max = new DateTime(2030, 12, 31);
        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            if (value == null)
                return new ValidationResult("Review Date is required.");
            // Original message: "can be within the provided range" — if you want a fixed range, add checks here.
            var dt = (DateTime)value;
            if (dt < Min || dt > Max)
                return new ValidationResult("Baseline End Date must be between 01-Jan-2020 and 31-Dec-2030.");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationProjectBudget : ValidationAttribute
    {
        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            // Required + range 100..1,000,000
            if (value == null)
                return new ValidationResult("Project Budget is required.");

            decimal amount = value switch
            {
                decimal d => d,
                int i => i,
                long l => l,
                _ => 0m
            };

            if (amount < 100m || amount > 1_000_000m)
                return new ValidationResult("Project Budget must be between $100 and $1,000,000.");
            return ValidationResult.Success;
        }
    }
