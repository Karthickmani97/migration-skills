    public async Task CollapseByKey(){
        await Gantt.CollapseByKeyAsync(1);
    }
    public async Task ExpandByKey(){
        await Gantt.ExpandByKeyAsync(1);
    }
    public async Task CollapseAtLevel(){
        await Gantt.CollapseAtLevelAsync(0);
    }

    public async Task ExpandAtLevel(){
        await Gantt.CollapseAtLevelAsync(0);
    }
    private async Task Scroll()
    {
        Gantt.ScrollIntoViewAsync(0, 30);
    }
    public async Task Delete()
    {
        await this.Gantt.DeleteRecordAsync(2);
    }
    public SfGantt<TaskData> Gantt;
    SfGantt<TaskData> Obj { get; set; }
    Stopwatch timer = new Stopwatch();
    public DateTime ProjectStartDate = new DateTime(2017, 01, 01);
    public DateTime ProjectEndDate = new DateTime(2020, 02, 28);

    public void LoadHandler(object args)
    {
        timer.Stop();
        Debug.WriteLine("Time taken for Initial Rendering: " + timer.ElapsedMilliseconds.ToString());
        Console.WriteLine("Time taken for Initial Rendering: " + timer.ElapsedMilliseconds.ToString());
        timer.Start();
    }

    public void Created(Object args)
    {
        timer.Stop();
        Debug.WriteLine("Time taken for Initial Creating: " + timer.ElapsedMilliseconds.ToString());
        Console.WriteLine("Time taken for Initial Creating: " + timer.ElapsedMilliseconds.ToString());
    }

    public void ActionComplete(GanttActionEventArgs<TaskData> args)
    {
        timer.Stop();
        Debug.WriteLine("Time taken for " + args.RequestType.ToString() + " " + timer.ElapsedMilliseconds.ToString());
        Console.WriteLine("Time taken for " + args.RequestType.ToString() + " " + timer.ElapsedMilliseconds.ToString());
        timer.Reset();
    }


    public void ActionBegin(GanttActionEventArgs<TaskData> args)
    {
        timer.Start();
