            new TaskInfoModel() { TaskId = 2, TaskName = "Auto with Duration only", Duration = "2", ParentId = 1,Predecessor="3" },
            new TaskInfoModel() { TaskId = 3, TaskName = "Auto with End Date only", EndDate = new DateTime(2021, 04, 03), ParentId = 1 },
            new TaskInfoModel() { TaskId = 4, TaskName = "Auto with Start Date only", StartDate = new DateTime(2021, 04, 02), ParentId = 1 },
            new TaskInfoModel() { TaskId = 5, TaskName = "No Scheduling Task" },
            new TaskInfoModel() { TaskId = 6, TaskName = "Market Research" },
            new TaskInfoModel() { TaskId = 7, TaskName = "Manual with Duration only", Duration = "2", IsManual = true, ParentId = 6 },
            new TaskInfoModel() { TaskId = 8, TaskName = "Manual with End Date only", EndDate = new DateTime(2021, 04, 03), ParentId = 6, IsManual = true },
            new TaskInfoModel() { TaskId = 9, TaskName = "Manual with Start Date only", StartDate = new DateTime(2021, 04, 02), ParentId = 6, IsManual = true },
        };
        return Tasks;
    }
