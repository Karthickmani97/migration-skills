@page "/E2EMigration/Customcontext"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
<div>@messsage</div>

<SfGantt @ref="sfGantt" id="Customcontextmenu" EnableContextMenu="true" DataSource="@TaskCollection" Height="450px" Width="1400px"
 ContextMenuItems="@(new List<object>() { new ContextMenuItemModel{Text = "ZoomOut", Target = ".e-content", Id = "ZoomOut" }})">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId">
    </GanttTaskFields>
    <GanttEditSettings AllowTaskbarEditing="true" AllowEditing="true" AllowAdding="true"
		AllowDeleting="true" ShowDeleteConfirmDialog="true">
	</GanttEditSettings>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
	<GanttEvents  ContextMenuItemClicked="OnContextMenuClick" ContextMenuOpen="ContextMenuOpenHandler" Created="Created" TValue="TaskData" OnActionFailure="ActionFailureHandler"></GanttEvents>
</SfGantt>

@code{
    private SfGantt<TaskData> sfGantt;
    public List<TaskData> TaskCollection { get; set; }
    public string messsage{ get; set; }
    private List<string> HiddenItems = new List<string>();
    protected override void OnInitialized()
    {
        this.TaskCollection = GetTaskCollection();
    }
    public async Task Created()
    {   
     
    }
    public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       messsage += " OnAction failure Event triggered";
    }

    public void OnContextMenuClick(ContextMenuClickEventArgs<TaskData> args)
    {
        if (args.Item.Id == "ZoomOut")
        {
            sfGantt.ZoomOutAsync();
        }
    }
    public void ContextMenuOpenHandler(ContextMenuOpenEventArgs<TaskData> args)
    {
       Console.WriteLine("ContextMenuOpenHandler");

    }
