@code {
    public SfGantt<TaskInfoModel> Gantt;
    private DateTime ProjectStart = new DateTime(2022, 03, 25);
    private DateTime ProjectEnd = new DateTime(2022, 08, 10);
    private List<TaskInfoModel> TaskCollection { get; set; }
    private List<ResourceInfoModel> ResourceCollection { get; set; }
    private static List<AssignmentModel> AssignmentCollection { get; set; } = new();
    private DateTime Holiday1 = new DateTime(2022, 04, 11);
    private DateTime Holiday2 = new DateTime(2022, 04, 12);
    private DateTime Holiday3 = new DateTime(2022, 04, 01);
    private DateTime Holiday4 = new DateTime(2022, 04, 01);
    private bool IsToggleEnabled { get; set; }
    private Boolean IsCheck { get; set; }
    private int workvalue {get;set;} = 24;
    private string durationvalue { get; set; } = "6";
    private int unitvalue { get; set; } = 100;
    private ViewType viewType = ViewType.ProjectView;
    public Syncfusion.Blazor.Gantt.ScheduleMode TaskMode { get; set; } = ScheduleMode.Auto;
    private TimelineViewMode timelineViewMode { get; set; } = TimelineViewMode.Week;
    private Syncfusion.Blazor.Gantt.DurationUnit durationUnit { get; set; } = Syncfusion.Blazor.Gantt.DurationUnit.Day;
    private WorkUnit workUnit { get; set; } = WorkUnit.Hour;
    private string selectedCollectionType { get; set; } = "Auto";
    private string selectedTaskType { get; set; } = "FixedDuration";
    private string selectedMethod { get; set; } = "PublicMethod";
    private string selectedEditType { get; set; } = "UpdateRecord";
    private int assignmentCount { get; set; }
    private int dataCount { get; set; }
    protected override void OnInitialized()
    {
        TaskCollection = GetTaskCollection();
        ResourceCollection = GetResources;
        AssignmentCollection = GetAssignmentCollection();
        ganttDayWorkingTimes = new List<GanttDayWorkingTime> { new GanttDayWorkingTime() { From = 8, To = 12 }, new GanttDayWorkingTime() { From = 13, To = 17 } };
        assignmentCount = AssignmentCollection.Count;
        dataCount = TaskCollection.Count;
    }
    public List<GanttDayWorkingTime> ganttDayWorkingTimes { get; set; }
    public string[] workWeek { get; set; } = new string[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" };
    public bool includeWeenEnd { get; set; }
    public int weekStart { get; set; } = 0;
    private List<DropdownData> collectionTypes = new List<DropdownData>
    {
        new DropdownData{ Text = "Custom", Value = "Custom" },
        new DropdownData{ Text = "Auto", Value = "Auto" },
        new DropdownData{ Text = "Manual", Value = "Manual" },
    };
    private List<DropdownData> TaskTypeCollection = new List<DropdownData>
    {
        new DropdownData{ Text = "FixedDuration", Value = "FixedDuration" },
        new DropdownData{ Text = "FixedUnit", Value = "FixedUnit" },
        new DropdownData{ Text = "FixedWork", Value = "FixedWork" },
    };
    private List<DropdownData> PublicMethods = new List<DropdownData>
    {
        new DropdownData{ Text = "AddRecord", Value = "AddRecord" },
        new DropdownData{ Text = "UpdateAssignment", Value = "UpdateAssignment" },
        new DropdownData{ Text = "AddAssignment", Value = "AddAssignment" },
        new DropdownData{ Text = "RemoveAssignment", Value = "RemoveAssignment" },
    };
    private List<DropdownData> UpdateRecordByIdEditType = new List<DropdownData>
    {
        new DropdownData{ Text = "EditDuration", Value = "EditDuration" },
        new DropdownData{ Text = "EditWork", Value = "EditWork" },
    };
    public class DropdownData
    {
        public string? Text { get; set; }
        public string? Value { get; set; }
    }
    public int DefaultUnitWidth = 33;
    public int TopTierCount = 1;
    public int BottomTierCount = 1;
    public string DefaultFormatvalue = "MMM dd, yyyy";
    public string DefaultBottomTierValue = "Day";
    public bool EnableTopNumericBox = true;
    public bool EnableTopUnitDropDown = true;
    public bool EnableTopFormatDropDown = true;
    public bool EnableBottomNumericBox = true;
    public bool EnableBottomUnitDropDown = true;
    public bool EnableBottomFormatDropDown = true;
    public string TopTierFormat = "MMM dd, yyyy";
    public string BottomTierFormat = "";
    TimelineViewMode TopTierUnit = TimelineViewMode.Week;
    TimelineViewMode BottomTierUnit = TimelineViewMode.Day;

    List<DayFormat> YearFormats = new List<DayFormat>()
    {
         new DayFormat { Id ="MMM yy", Format = "Jan 18" },
        new DayFormat {  Id = "yyyy", Format = "2018"   },
        new DayFormat { Id = "MMMM, y", Format = "January, 18" },
    };
    List<DayFormat> MonthFormats = new List<DayFormat>()
    {
        new DayFormat { Id = "MMM dd, yyyy", Format = "Jan 01, 2018" },
        new DayFormat { Id = "MMMM", Format = "January" },
        new DayFormat { Id = "MMM", Format = "Jan" },
    };
