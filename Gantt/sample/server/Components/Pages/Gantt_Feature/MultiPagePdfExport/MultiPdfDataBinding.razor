                currentDataType = idType;
                break;
            case "expando":
                TaskCollectionExpando = GetTaskCollectionExpando();
                currentDataType = idType;
                break;
            case "dynamic object":
                TaskCollectionDynamic = GetTaskCollectionDynamic();
                currentDataType = idType;
                break;
            case "custom adaptor":
                TaskCollectionInt = GetTaskCollectionInt();
                currentDataType = idType;
                break;
            case "rtl":
                TaskCollectionInt = GetTaskCollectionInt();
                currentDataType = idType;
                break;
            default:
                break;
        }
    }
