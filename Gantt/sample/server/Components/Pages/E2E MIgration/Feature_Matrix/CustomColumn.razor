@page "/E2EMigration/customcolumn"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Gantt
<div>@messsage</div>
<SfGantt Id="GanttCustomcolumn" DataSource="@TaskCollection" Toolbar="@(new List<string>() { "Add", "Cancel","Delete", "Edit","Update", "CollapseAll", "ExpandAll", "ZoomIn", "ZoomOut", "ZoomToFit"})" 
Height="500px" Width="1400px">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate"
                     Notes="Notes" Duration="Duration" Progress="Progress" Child="SubTasks">
    </GanttTaskFields>
    <GanttColumns>
        <GanttColumn Field="TaskId"></GanttColumn>
        <GanttColumn Field="TaskName"></GanttColumn>
        <GanttColumn Field="Custom"></GanttColumn>
        <GanttColumn Field="StartDate"></GanttColumn>
        <GanttColumn Field="EndDate"></GanttColumn>
        <GanttColumn Field="Duration"></GanttColumn>
        <GanttColumn Field="Progress"></GanttColumn>
        <GanttColumn Field="Notes" ClipMode="Syncfusion.Blazor.Grids.ClipMode.Ellipsis"></GanttColumn>
    </GanttColumns>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
    <GanttEvents TValue="TaskData" OnActionFailure="ActionFailureHandler"></GanttEvents>
    <GanttEditSettings AllowTaskbarEditing="true" AllowEditing="true" ShowDeleteConfirmDialog="true" AllowAdding="true" AllowDeleting="true" Mode="Syncfusion.Blazor.Gantt.EditMode.Auto"></GanttEditSettings>


</SfGantt>

@code{ 

    public List<TaskData> TaskCollection { get; set; }
    public string messsage{ get; set; }

    protected override void OnInitialized()
    {
        this.TaskCollection = GetTaskCollection();
    }
    public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       messsage += " OnAction failure Event triggered";
    }

    public class TaskData
    {
        public int TaskId { get; set; }
        public string TaskName { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public string? Duration { get; set; }
        public string? Notes { get; set; }
        public int Progress { get; set; }
        public List<TaskData> SubTasks { get; set; }
        public string? Custom { get; set; }
    }

    public static List<TaskData> GetTaskCollection()
