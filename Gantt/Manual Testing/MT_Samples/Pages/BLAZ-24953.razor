</SfGantt>
@code {
    public SfGantt<TaskData> Gantt;
    SfGantt<TaskData> Obj { get; set; }
    Stopwatch timer = new Stopwatch();
    public DateTime ProjectStartDate = new DateTime(2017, 01, 01);
    public DateTime ProjectEndDate = new DateTime(2017, 02, 28);
    private async Task Scroll()
    {
        Gantt.ScrollIntoViewAsync(10, 30);
    }
    private void AddColumns()
    {
        Gantt.Columns.Add(new GanttColumn() { Field = "ProjectProgress", Width = "150" });
    }
    private void RemoveColumns()
    {
        Gantt.Columns = new List<GanttColumn>() {
new GanttColumn() { Field= "ProjectId", Width = "150"},
new GanttColumn() { Field= "ProjectName",HeaderText="Task Name", Width = "150"},
};
    }
    private void HideColumns()
    {
        Gantt.HideColumnAsync("ProjectName", "Field");
    }
    private void ShowColumns()
    {
        Gantt.ShowColumnAsync("ProjectName", "Field");
    }
    private async void ReorderColumns()
    {
        Gantt.ReorderColumnsAsync(new List<string>() { "ProjectName" }, "FIELD6");
        var col = await Gantt.GetColumnsAsync();
        Console.WriteLine(col);
