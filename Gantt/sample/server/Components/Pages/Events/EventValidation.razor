    public async Task ToolbarClickHandler(ClickEventArgs args)
    {
        EventName = count++ + " OnToolbarClick"; PropertyItems.Add(EventName, new());
        ExtractProperties(args);

        try
        {
            var itemText = args?.Item?.Text ?? string.Empty;
            var itemId = args?.Item?.Id ?? string.Empty;
            if (itemId == "Gantt_PdfExport" || itemText.Equals("PDF Export", StringComparison.OrdinalIgnoreCase) || itemText.Equals("PdfExport", StringComparison.OrdinalIgnoreCase) || (!string.IsNullOrEmpty(itemId) && itemId.IndexOf("PdfExport", StringComparison.OrdinalIgnoreCase) >= 0))
            {
                if (GanttRef != null)
                {
                    await GanttRef.ExportToPdfAsync();
                    PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = "PdfExport", Value = "Triggered" });
                }
                else
                {
                    PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = "PdfExport", Value = "GanttRef is null" });
                }
            }
        }
        catch (Exception ex)
        {
            PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = "PdfExportError", Value = ex.GetType().Name + ": " + ex.Message });
        }

        StateHasChanged();
    }
