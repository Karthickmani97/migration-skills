    public static List<TaskInfoModel> GetVirtualData()
    {
        var dataCollection = new List<TaskInfoModel>();
        int taskId = 0;
        for (int i = 1; i <= 50; i++)
        {
            var parentTask = new TaskInfoModel
                {
                    TaskId = ++taskId,
                    TaskName = "Task " + taskId,
                    StartDate = new DateTime(2025, 4, 9),
                    EndDate = new DateTime(2025, 4, 13),
                    Duration = "10",
                    Progress = 10,
                    ParentId = null,
                    Predecessor = null
                };

            dataCollection.Add(parentTask);
            int parentId = parentTask.TaskId;
            int prevChildId = 0;

            for (int j = 1; j <= 9; j++)
            {
                int childId = ++taskId;
                string predecessor = prevChildId > 0 ? $"{prevChildId}FS" : null;

                var childTask = new TaskInfoModel
                    {
                        TaskId = childId,
                        TaskName = "Task " + childId,
                        StartDate = new DateTime(2025, 4, 9),
                        EndDate = new DateTime(2025, 4, 13),
                        Duration = "10",
                        Progress = 30 + (j * 2),
                        ParentId = parentId,
                        Predecessor = predecessor
                    };

                dataCollection.Add(childTask);
                prevChildId = childId;
            }
        }

        return dataCollection;
    }
