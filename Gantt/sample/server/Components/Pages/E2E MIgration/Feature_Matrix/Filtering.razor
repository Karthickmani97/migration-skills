@page "/E2EMigration/filtering"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
<div>@messsage</div>
<button id="ClearFilter" @onclick="ClearFilter">Clear Filter</button>
<button id="FilterDynamic"  @onclick="Filter">Filter Column</button>
<br>
<SfGantt @ref="Gantt" ID="GanttFilter" DataSource="@TaskCollection" Height="450px" Width="1400px" AllowFiltering="true">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" Child="SubTasks">
    </GanttTaskFields>
    <GanttSplitterSettings Position="70%"></GanttSplitterSettings>
 <GanttEvents TValue="TaskData" Created="Created" OnActionFailure="ActionFailureHandler"></GanttEvents>
</SfGantt>

@code{
    public SfGantt<TaskData> Gantt;
    public List<TaskData> TaskCollection { get; set; }
    public string messsage{ get; set; }

    protected override void OnInitialized()
    {
        this.TaskCollection = GetTaskCollection();
    }
    public async Task Created()
    {   
     
    }
    public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       messsage += " OnAction failure Event triggered";
    }
    public void ClearFilter()
    {
        this.Gantt.ClearFilteringAsync();
    }
    public void Filter()
    {
        this.Gantt.FilterByColumnAsync("TaskName","startswith","Iden");
    }
    public class TaskData
    {
        public int TaskId { get; set; }
        public string TaskName { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public string Duration { get; set; }
        public int Progress { get; set; }
        public List<TaskData> SubTasks { get; set; }
    }

    public static List<TaskData> GetTaskCollection()
    {
