@page "/gantt-tab"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Gantt

<h3>Gantt inside Tab</h3>

<SfTab>
    <TabItems>
        <TabItem>
            <ChildContent>
                <TabHeader Text="Project Alpha"></TabHeader>
            </ChildContent>
            <ContentTemplate>
                <div class="p-3">
                    <SfGantt DataSource="@ProjectAlphaData" 
                             Height="450px" 
                             Width="1000px"
                             AllowSorting="true"
                             ShowColumnMenu="true"
                             Toolbar="@(new List<string>() { "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll", "ZoomIn", "ZoomOut", "ZoomToFit" })"
                             EnableContextMenu="true">
                        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" Duration="Duration" Progress="Progress" Child="SubTasks" Dependency="Predecessor">
                        </GanttTaskFields>
                        <GanttEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true" Mode="EditMode.Dialog"></GanttEditSettings>
                        <GanttColumns>
                            <GanttColumn Field="TaskId" HeaderText="ID" Width="80" AllowSorting="true"></GanttColumn>
                            <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250" AllowSorting="true"></GanttColumn>
                            <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150" Format="d" AllowSorting="true"></GanttColumn>
                            <GanttColumn Field="Duration" HeaderText="Duration" Width="100" AllowSorting="true"></GanttColumn>
                            <GanttColumn Field="Progress" HeaderText="Progress" Width="100" AllowSorting="true"></GanttColumn>
                        </GanttColumns>
                    </SfGantt>
                </div>
            </ContentTemplate>
        </TabItem>
        <TabItem>
            <ChildContent>
                <TabHeader Text="Project Beta"></TabHeader>
            </ChildContent>
            <ContentTemplate>
                <div class="p-3">
                    <SfGantt DataSource="@ProjectBetaData" 
                             Height="450px" 
                             Width="1000px"
                             AllowSorting="true"
                             ShowColumnMenu="true"
                             Toolbar="@(new List<string>() { "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll", "ZoomIn", "ZoomOut", "ZoomToFit" })"
                             EnableContextMenu="true">
                        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" Duration="Duration" Progress="Progress" Child="SubTasks" Dependency="Predecessor">
                        </GanttTaskFields>
                        <GanttEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true" Mode="EditMode.Dialog"></GanttEditSettings>
                        <GanttColumns>
                            <GanttColumn Field="TaskId" HeaderText="ID" Width="80" AllowSorting="true"></GanttColumn>
                            <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250" AllowSorting="true"></GanttColumn>
                            <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150" Format="d" AllowSorting="true"></GanttColumn>
                            <GanttColumn Field="Duration" HeaderText="Duration" Width="100" AllowSorting="true"></GanttColumn>
                            <GanttColumn Field="Progress" HeaderText="Progress" Width="100" AllowSorting="true"></GanttColumn>
                        </GanttColumns>
                    </SfGantt>
                </div>
            </ContentTemplate>
        </TabItem>
        <TabItem>
            <ChildContent>
                <TabHeader Text="Summary"></TabHeader>
            </ChildContent>
            <ContentTemplate>
                <div class="p-3">
                    <h5>Project Overview</h5>
                    <p>Total Projects: 2</p>
                    <p>Project Alpha Progress: 65%</p>
                    <p>Project Beta Progress: 50%</p>
                    <p>Click on different tabs to view Gantt charts for each project.</p>
                </div>
            </ContentTemplate>
        </TabItem>
    </TabItems>
</SfTab>

@code {
    private List<TaskData> ProjectAlphaData { get; set; } = new();
    private List<TaskData> ProjectBetaData { get; set; } = new();

    protected override void OnInitialized()
    {
        ProjectAlphaData = GetProjectAlphaData();
        ProjectBetaData = GetProjectBetaData();
    }

    private List<TaskData> GetProjectAlphaData()
    {
        return new List<TaskData>
        {
            new TaskData
            {
                TaskId = 1,
                TaskName = "Alpha Development",
                StartDate = new DateTime(2026, 02, 01),
                Duration = 8,
                Progress = 65,
                SubTasks = new List<TaskData>
                {
                    new TaskData { TaskId = 2, TaskName = "Frontend Development", StartDate = new DateTime(2026,02,01), Duration = 4, Progress = 80 },
                    new TaskData { TaskId = 3, TaskName = "Backend Development", StartDate = new DateTime(2026,02,05), Duration = 4, Progress = 50, Predecessor = "2FS" }
                }
            },
            new TaskData
            {
                TaskId = 4,
                TaskName = "Alpha Testing",
                StartDate = new DateTime(2026,02,09),
                Duration = 3,
                Progress = 30,
                Predecessor = "1FS",
                SubTasks = new List<TaskData>
                {
                    new TaskData { TaskId = 5, TaskName = "Unit Testing", StartDate = new DateTime(2026,02,09), Duration = 1, Progress = 100 },
                    new TaskData { TaskId = 6, TaskName = "Integration Testing", StartDate = new DateTime(2026,02,10), Duration = 2, Progress = 0, Predecessor = "5FS" }
                }
            }
        };
    }

    private List<TaskData> GetProjectBetaData()
    {
        return new List<TaskData>
        {
            new TaskData
            {
                TaskId = 1,
                TaskName = "Beta Design Phase",
                StartDate = new DateTime(2026, 02, 03),
                Duration = 5,
                Progress = 70,
                SubTasks = new List<TaskData>
                {
                    new TaskData { TaskId = 2, TaskName = "UI/UX Design", StartDate = new DateTime(2026,02,03), Duration = 3, Progress = 100 },
                    new TaskData { TaskId = 3, TaskName = "Mockup Creation", StartDate = new DateTime(2026,02,06), Duration = 2, Progress = 40, Predecessor = "2FS" }
                }
            },
            new TaskData
            {
                TaskId = 4,
                TaskName = "Beta Implementation",
                StartDate = new DateTime(2026,02,08),
                Duration = 6,
                Progress = 30,
                Predecessor = "1FS",
                SubTasks = new List<TaskData>
                {
                    new TaskData { TaskId = 5, TaskName = "Core Features", StartDate = new DateTime(2026,02,08), Duration = 3, Progress = 60 },
                    new TaskData { TaskId = 6, TaskName = "Advanced Features", StartDate = new DateTime(2026,02,11), Duration = 3, Progress = 0, Predecessor = "5FS" }
                }
            }
        };
    }

    public class TaskData
    {
        public int TaskId { get; set; }
        public string TaskName { get; set; } = string.Empty;
        public DateTime StartDate { get; set; }
        public int Duration { get; set; }
        public int Progress { get; set; }
        public string Predecessor { get; set; } = string.Empty;
        public List<TaskData>? SubTasks { get; set; } = new();
    }
}
