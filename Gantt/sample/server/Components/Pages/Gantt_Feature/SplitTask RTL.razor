    private void SegmentSaveHanlder(SegmentEventArgs<SegmentModel> args)
    {
        @* if (args.UpdatedSegments != null)
        {
            foreach (var data in args.UpdatedSegments)
            {
                var record = segmentCollection.Where(s => s.id == data.id).FirstOrDefault();
                record = data;
            }
        }
        if (args.DeletedSegments != null)
        {
            // args.Cancel = true;
            foreach (var data in args.DeletedSegments)
            {
                var record = segmentCollection.Where(s => s.id == data.id).FirstOrDefault();
                segmentCollection.Remove(record);
            }
        }
        if (args.AddedSegments != null)
        {
            foreach (var data in args.AddedSegments)
            {
                var maxId = segmentCollection.Count() + 1;
              //  data.id = maxId;
                //var record = segmentCollection.Where(s => s.id == data.id).FirstOrDefault();
                segmentCollection.Add(data);
            }
        } *@
