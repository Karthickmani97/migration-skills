@page "/splittaskweekmonth"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
<button id="durationWeek" @onclick="DurationWeek">DurationWeek</button>
<button id="durationMonth" @onclick="DurationMonth">DurationMonth</button>
<button id="yearMonth" @onclick="YearMonth">YearMonth</button>
<button id="monthWeek" @onclick="MonthWeek">MonthWeek</button>
<button id="splitTaskFuncWeek" @onclick="SplitTaskFuncWeek">Split Task Week</button>
<button id="splitTaskFuncWeek1" @onclick="SplitTaskFuncWeek1">Split Task Week1</button>
<button id="splitTaskFuncMon" @onclick="SplitTaskFuncMon">Split Task Month</button>
<button id="splitTaskFuncMon1" @onclick="SplitTaskFuncMon1">Split Task Month1</button>
<button id="mergeTaskFunc" @onclick="MergeTaskFunc">MergeTask</button>
<div class="control-section e-gantt-splitTasks-sample">
    <SfGantt @ref="GanttInstance" TValue="SplitTasksData.TaskData" DataSource="@TaskCollection" Height="450px" Width="100%" TreeColumnIndex="1" Toolbar="@(new List<Object>() { "Add", "Cancel", "Update", "Delete", "Edit", "CollapseAll", "ExpandAll", "ZoomIn", "ZoomOut", "ZoomToFit" })"
             EnableContextMenu="true" RowHeight="37" ScrollToTaskbarOnClick="true" DurationUnit="@durationunit">
        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId" Dependency="Predecessor">
        </GanttTaskFields>
        <GanttEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true" AllowTaskbarEditing="true"></GanttEditSettings>
        <GanttSegmentFields PrimaryKey="id" ForeignKey="TaskId" StartDate="StartDate" EndDate="EndDate" Duration="Duration" TValue="SplitTasksData.TaskData" TSegments="SplitTasksData.SegmentModel" DataSource="SegmentCollection"></GanttSegmentFields>
        <GanttLabelSettings LeftLabel="TaskName" TValue="SplitTasksData.TaskData"></GanttLabelSettings>
        <GanttColumns>
            <GanttColumn Field="TaskId" Width="100" Visible="false"></GanttColumn>
            <GanttColumn Field="TaskName" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
            <GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
            <GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
            <GanttColumn Field="Duration" HeaderText="Duration"></GanttColumn>
            <GanttColumn Field="Progress" HeaderText="Progress"></GanttColumn>
            <GanttColumn Field="Predecessor" HeaderText="Dependency"></GanttColumn>
        </GanttColumns>
        <GanttSplitterSettings Position="28%"></GanttSplitterSettings>
        <GanttTimelineSettings TimelineUnitSize="@DefaultUnitWidth">
            <GanttTopTierSettings Unit="@TopTierUnit"></GanttTopTierSettings>
            <GanttBottomTierSettings Unit="@BottomTierUnit"></GanttBottomTierSettings>
        </GanttTimelineSettings>
    </SfGantt>
</div>
@code {
    public SfGantt<SplitTasksData.TaskData>? GanttInstance { get; set; }
    public List<SplitTasksData.TaskData> TaskCollection { get; set; } = new List<SplitTasksData.TaskData>();
    public List<SplitTasksData.SegmentModel> SegmentCollection { get; set; } = new List<SplitTasksData.SegmentModel>();
    TimelineViewMode TopTierUnit = TimelineViewMode.Week;
    TimelineViewMode BottomTierUnit = TimelineViewMode.Day;
    DurationUnit durationunit = DurationUnit.Day;
    public int DefaultUnitWidth = 33;
    /// <summary>
    /// Initializes the Split Tasks sample with task and segment data.
    /// </summary>
    protected override void OnInitialized()
    {
        TaskCollection = SplitTasksData.GetTaskCollection();
        SegmentCollection = SplitTasksData.GetSegmentCollection();
    }
    public void YearMonth()
    {
        TopTierUnit = TimelineViewMode.Year;
        BottomTierUnit = TimelineViewMode.Month;
        DefaultUnitWidth = 300;
    }
    public void MonthWeek()
    {
        TopTierUnit = TimelineViewMode.Month;
        BottomTierUnit = TimelineViewMode.Week;
        DefaultUnitWidth = 300;
    }
    public void DurationWeek()
    {
        durationunit = DurationUnit.Week;
    }
    public void DurationMonth()
    {
        durationunit = DurationUnit.Month;
    }
    public async void SplitTaskFuncWeek()
    {
        if (GanttInstance!=null)
        {
            await GanttInstance.SplitTaskAsync(
            2,
            new List<DateTime>
            {
            new DateTime(2022, 04, 04) 
            });
        }
    }
    public async void SplitTaskFuncWeek1()
    {
        if (GanttInstance != null)
        {
            await GanttInstance.SplitTaskAsync(
            2,
            new List<DateTime>
            {
            new DateTime(2022, 04, 05)
            });
        }

    }
    public async void SplitTaskFuncMon()
    {
        if (GanttInstance != null)
        {
            await GanttInstance.SplitTaskAsync(
            2,
            new List<DateTime>
            {
            new DateTime(2022, 04, 28)
            });
        }

    }
    public async void SplitTaskFuncMon1()
    {
        if (GanttInstance != null)
        {
            await GanttInstance.SplitTaskAsync(
            2,
            new List<DateTime>
            {
            new DateTime(2022, 04, 29)
            });
        }

    }
    public async Task MergeTaskFunc()
    {
        if (GanttInstance != null)
        {
            List<ValueTuple<int, int>> indexes = new List<ValueTuple<int, int>>();
            indexes.Add((0, 1));
            await GanttInstance.MergeTaskAsync("2", indexes);
        }

    }
    public class SplitTasksData
