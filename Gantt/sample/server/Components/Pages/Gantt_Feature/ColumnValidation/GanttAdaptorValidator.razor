    public class CustomAdaptor : DataAdaptor
    {
        public override object Read(DataManagerRequest dm, string key = null)
        {
            return new DataResult() { Result = GanttData, Count = GanttData.Count };
        }

        public override object Insert(DataManager dm, object value, string key)
        {
            var incoming = value as GanttData.TaskData;
            if (incoming != null)
            {
                // Ensure unique TaskId if not provided
                if (incoming.TaskId == 0)
                {
                    incoming.TaskId = (GanttData.Count == 0 ? 1 : GanttData.Max(t => t.TaskId) + 1);
                }
                GanttData.Insert(0, incoming);
            }
            return value;
        }

        public override object Remove(DataManager dm, object value, string keyField, string key)
        {
            if (int.TryParse(value?.ToString(), out var id))
            {
                var toRemove = GanttData.FirstOrDefault(t => t.TaskId == id);
                if (toRemove != null)
                {
                    GanttData.Remove(toRemove);
                    // Optionally remove descendants
                    var desc = GanttData.Where(t => t.ParentId == id).ToList();
                    foreach (var d in desc) GanttData.Remove(d);
                }
            }
            return value;
        }

        public override object Update(DataManager dm, object value, string keyField, string key)
        {
            var incoming = value as GanttData.TaskData;
            var data = GanttData.FirstOrDefault(or => or.TaskId == incoming.TaskId);
            if (data != null)
            {
                data.ActivityName = incoming.ActivityName;
                data.StartDate = incoming.StartDate;
                data.EndDate = incoming.EndDate;
                data.BaselineStartDate = incoming.BaselineStartDate;
                data.BaselineEndDate = incoming.BaselineEndDate;
                data.ReviewDate = incoming.ReviewDate;

                data.Duration = incoming.Duration;
                data.Predecessor = incoming.Predecessor;
                data.Progress = incoming.Progress;
                data.Work = incoming.Work;
                data.ParentId = incoming.ParentId;

                data.Email = incoming.Email;
                data.Username = incoming.Username;
                data.Password = incoming.Password;
                data.Website = incoming.Website;
                data.CustomData = incoming.CustomData;
                data.Notes = incoming.Notes;
                data.TaskType = incoming.TaskType;

                data.ProjectBudget = incoming.ProjectBudget;
            }
            return value;
        }
    }
