    private GanttPdfExportProperties HandleExportProperties(string propertyId)
    {
        var pdfExportProps = new GanttPdfExportProperties();

        switch (propertyId)
        {
            case "disablefooter":
                pdfExportProps.Footer = null;
                break;

            case "exporttype-CurrentViewData":
                // Adjust according to the actual implementation in your PdfExportPropertiesBase,
                // assuming it should set IsCurrentViewExport to true
                isCurrentViewExport = true;
                break;

            case "exporttype-AllData":
                isCurrentViewExport = false;
                break;

            case "filename":
                pdfExportProps.FileName = "GanttExport.pdf";
                break;

            case "header":
                pdfExportProps.Header = new PdfHeader
                    {
                        Left = 0, // Adjust property name to Left
                        Height = 50,
                        Contents = new List<PdfHeaderFooterContent>
                {
                    new PdfHeaderFooterContent
                    {
                        Type = ContentType.Text,
                        Value = "Gantt Chart Header",
                        Position = new PdfPosition { X = 0, Y = 25 },
                    }
                }
                    };
                break;

            case "footer":
                pdfExportProps.Footer = new PdfFooter
                    {
                        Left = 0, // Adjust property name to Left
                        Height = 50,
                        FromBottom = 25,
                        Contents = new List<PdfHeaderFooterContent>
                {
                    new PdfHeaderFooterContent
                    {
                        Type = ContentType.Text,
                        Value = "Page 1 of 1",
                    }
                }
                    };
                break;

            case "ganttStyle-columnHeader":
                pdfExportProps.Style ??= new PdfGanttStyle();
                pdfExportProps.Style.HeaderStyle = new PdfElementStyle
                    {
                        Font = new PdfGridFont { TextColor = "#000000", FontFamily = "Arial", FontSize = 12, FontStyle = PdfFontStyle.Bold } // Adjust to use PdfGridFont
                    };
                break;

            case "ganttStyle-cell":
                pdfExportProps.Style ??= new PdfGanttStyle();
                pdfExportProps.Style.CellStyle = new PdfElementStyle
                    {
                        Font = new PdfGridFont { TextColor = "#333333", FontSize = 11 } // Adjust to use PdfGridFont
                    };
                break;

            case "ganttStyle-taskbar":
                pdfExportProps.Theme = GanttPdfTheme.Fluent;
                pdfExportProps.Style = new PdfGanttStyle
                {
                    TaskbarColor = new PdfTaskbarColor
                    {
                        ChildTaskbarColor = new PdfColor(13, 143, 224), // Adjust for instantiation
                        ParentTaskbarColor = new PdfColor(10, 110, 180) // Adjust for instantiation
                    }
                };
                break;
            case "ganttStyle-label":
                PdfStringFormat stringFormat = new PdfStringFormat();
                stringFormat.Alignment = PdfTextAlignment.Center;

                PdfStringFormat vertical = new PdfStringFormat();
                vertical.Alignment = PdfTextAlignment.Center;

                pdfExportProps.Style = new PdfGanttStyle
                {
                    LabelStyleSettings = new PdfLabelSettings
                    {
                        LeftLabel = new PdfElementStyle
                        {
                            Padding = new PdfPaddings { Left = 0.5f, Right = 0.5f, Top = 0.4f, Bottom = 0.5f },
                            Font = new PdfGridFont { FontSize = 3, TextColor = "#000000", FontStyle = PdfFontStyle.Strikeout, TextHighlightColor = "#FFC0CB" },
                            StringFormat = stringFormat,
                            FillBackgroundColor = "#FFC0CB"
                        },
                        RightLabel = new PdfElementStyle
                        {
                            Padding = new PdfPaddings { Left = 0.5f, Right = 0.5f, Top = 0.4f, Bottom = 0.5f },
                            Font = new PdfGridFont { FontSize = 3, TextColor = "#000000", FontStyle = PdfFontStyle.Strikeout, TextHighlightColor = "#FFC0CB" },
                            StringFormat = stringFormat,
                            FillBackgroundColor = "#FFC0CB"
                        },
                        TaskLabel = new PdfElementStyle
                        {
                            Padding = new PdfPaddings { Left = 0.5f, Right = 0.5f, Top = 0.4f, Bottom = 0.5f },
                            Font = new PdfGridFont { FontSize = 3, TextColor = "#000000", FontStyle = PdfFontStyle.Strikeout, TextHighlightColor = "#FFC0CB" },
                            StringFormat = stringFormat,
                            FillBackgroundColor = "#FFC0CB"
                        }

                    }
                };
                break;
            case "ganttStyle-timeline":
                PdfStringFormat timelineStringFormat = new PdfStringFormat();
                timelineStringFormat.Alignment = PdfTextAlignment.Center;

                PdfStringFormat timelineVertical = new PdfStringFormat();
                timelineVertical.Alignment = PdfTextAlignment.Center;

                PdfBorder timelinePdfBorders = new PdfBorder(){ Color = "#c0c0c0", DashStyle = Syncfusion.Blazor.Grids.PdfDashStyle.Dash, Width = 1};
                pdfExportProps.Style = new PdfGanttStyle
                    {
                        TimelineTopTierStyle = new PdfElementStyle
                        {
                            Padding = new PdfPaddings { Left = 0.5f, Right = 0.5f, Top = 0.4f, Bottom = 0.5f },
                            Font = new PdfGridFont { FontSize = 3, TextColor = "#6495ed", FontStyle = PdfFontStyle.Strikeout, TextHighlightColor = "#FFC0CB" },
                            StringFormat = timelineStringFormat,
                            FillBackgroundColor = "#FFC0CB",
                            Border = timelinePdfBorders
                        },
                        TimelineBottomTierStyle = new PdfElementStyle
                        {
                            Padding = new PdfPaddings { Left = 0.5f, Right = 0.5f, Top = 0.4f, Bottom = 0.5f },
                            Font = new PdfGridFont { FontSize = 3, TextColor = "#6495ed", FontStyle = PdfFontStyle.Strikeout, TextHighlightColor = "#FFC0CB" },
                            StringFormat = timelineStringFormat,
                            FillBackgroundColor = "#FFC0CB",
                            Border = timelinePdfBorders
                        }
                    };
                break;
            case "ganttStyle-connectorLineColor":
                pdfExportProps.Style ??= new PdfGanttStyle();
                pdfExportProps.Style.ConnectorLine = new PdfBorder
                    {
                        Color = "#000000",
                        Width = 1
                    };
                break;

            case "ganttStyle-criticalConnectorLineColor":
                pdfExportProps.Style ??= new PdfGanttStyle();
                pdfExportProps.Style.CriticalPathConnectorLine = new PdfBorder
                    {
                        Color = "#FF0000",
                        Width = 1
                    };
                break;

            case "ganttStyle-eventmarkers":
                pdfExportProps.Style ??= new PdfGanttStyle();
                pdfExportProps.Style.EventMarkerStyle = new PdfElementStyle
                    {
                        Border = new PdfBorder { Color = "#FFFF00" }, // Adjust name for color
                    };
                break;

            case "ganttStyle-holiday":
                pdfExportProps.Style ??= new PdfGanttStyle();
                pdfExportProps.Style.HolidayStyle = new PdfElementStyle
                    {
                        FillBackgroundColor = "#FFC0CB", // Adjust name for color
                    };
                break;
        }

        return pdfExportProps;
    }

    private async Task OnToolbarClick(ClickEventArgs args)
    {
        if (args.Item.Id == "GanttPdfCustomization_PdfExport")
        {
            await Gantt.ExportToPdfAsync(ExportProperties,true);
        }
    }
    private async Task PdfExportingHandler(PdfExportEventArgs args)
    {
        args.IsCurrentViewExport = isCurrentViewExport;
        await Task.CompletedTask;
    }
    public class GanttTask
    {
        public int TaskID { get; set; }
        public string TaskName { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public double Progress { get; set; }
        public int Duration { get; set; }
        public string Predecessor { get; set; }
        public DateTime? BaselineStartDate { get; set; }
        public DateTime? BaselineEndDate { get; set; }
        public List<GanttTask> Subtasks { get; set; }
        public List<GanttIndicator> Indicators { get; set; }
        public bool IsManual { get; set; }
    }

    public class GanttIndicator
    {
        public DateTime Date { get; set; }
        public string Name { get; set; }
        public string Tooltip { get; set; }
    }

    public class GanttSegment
    {
        public DateTime StartDate { get; set; }
        public int Duration { get; set; }
    }

    public class CustomData
    {
        public string Name { get; set; }
        public string Value { get; set; }
    }

    
    private List<object> ToolbarItems = new List<object> {
        "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll",
        "Search", "ZoomIn", "ZoomOut", "ZoomToFit", "PrevTimeSpan", "NextTimeSpan", new ToolbarItem{ Id = "GanttPdfCustomization_PdfExport", Text = "PdfExport", PrefixIcon="e-pdfexport"}
    };

