@page "/BLAZ-993746"
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Calendars
@rendermode InteractiveServer
@using Syncfusion.Blazor
@using Syncfusion.Blazor.Data
@using Syncfusion.Blazor.Grids
<span>@ErrorMessage</span>
<SfGantt  ID="Gantt" @ref="mGanttRef" DataSource="@TaskCollection" Height="450px" Width="100%"
                     CopyHierarchyMode="Syncfusion.Blazor.TreeGrid.CopyHierarchyType.None"
                     TaskbarHeight="25"
                     AllowReordering
                     EnableRowHover
                     AllowRowDragAndDrop
                     EnableContextMenu
                     Toolbar="@(new List<object>(){"Indent", "Outdent",
                     new Syncfusion.Blazor.Navigations.ToolbarItem(){ TooltipText = "Add", Id = "CustomAdd" , PrefixIcon="e-icons e-plus"},
                     new Syncfusion.Blazor.Navigations.ToolbarItem(){ TooltipText = "Edit", Id = "CustomEdit" , PrefixIcon="e-icons e-edit"},
                     new Syncfusion.Blazor.Navigations.ToolbarItem(){ TooltipText = "Delete", Id = "CustomDelete" , PrefixIcon="e-icons e-trash"}})"
                     AllowSelection
                     AllowFiltering="true"
                     TaskMode="ScheduleMode.Custom"
                     HighlightWeekends="true"
                     RenderBaseline="true"
                     AllowUnscheduledTasks="true"
                     AllowSorting="true"
                     GridLines="Syncfusion.Blazor.Gantt.GridLine.Both"
                     TreeColumnIndex="0"
                     ShowColumnChooser="true"
                     EnablePredecessorValidation="true"
                     AllowResizing
                     EnableRowVirtualization
                     EnableTimelineVirtualization
                     OverscanCount="-1"
                     AllowPdfExport
                     EnableCriticalPath
                     >
                <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate"
                                 EndDate="EndDate" Duration="Duration" Progress="Progress"
                                 Dependency="Predecessor" ParentID="ParentId">
                </GanttTaskFields>
                <GanttTemplates TValue="DefaultData.TaskData"></GanttTemplates>
                <GanttColumns>
                    <GanttColumn AllowEditing Field="@nameof(DefaultData.TaskData.TaskId)">
                    </GanttColumn>
                    <GanttColumn AllowEditing Field="@nameof(DefaultData.TaskData.StartDate)" HeaderText="Start" Width="120px" Format="yyyy-MM-dd">
                        <EditTemplate><SfDatePicker TValue="DateTime?" Value="@((context as DefaultData.TaskData)?.StartDate)" ValueChanged="v => (context as DefaultData.TaskData)!.StartDate = v"></SfDatePicker></EditTemplate>
                    </GanttColumn>
                    <GanttColumn AllowEditing Field="@nameof(DefaultData.TaskData.EndDate)" HeaderText="End" Width="120px" Format="yyyy-MM-dd">
                        <EditTemplate><SfDatePicker TValue="DateTime?" Value="@((context as DefaultData.TaskData)?.EndDate)" ValueChanged="v => (context as DefaultData.TaskData)!.EndDate = v"></SfDatePicker></EditTemplate>
                    </GanttColumn>
                    <GanttColumn AllowEditing Field="@nameof(DefaultData.TaskData.TaskName)" HeaderText="Name" Width="120px" Format="yyyy-MM-dd"></GanttColumn>
                </GanttColumns>
                <GanttHolidays>
                    @for (var i = 0; i < 5; i++)
        {
            <GanttHoliday Label="@string.Empty" CssClass="e-custom-holiday" From="@(new DateTime(2021, 04, 10).AddDays(i * 7))" To="@(new DateTime(2021, 04, 10).AddDays(i * 7))">
            </GanttHoliday>
        }
    </GanttHolidays>
    <GanttEvents TValue="DefaultData.TaskData" OnToolbarClick="OnToolbarClick" OnActionFailure="OnActionFailureHandler"></GanttEvents>
    <GanttEditSettings AllowEditing AllowAdding AllowDeleting></GanttEditSettings>
    <GanttSelectionSettings Mode="Syncfusion.Blazor.Grids.SelectionMode.Row" Type="Syncfusion.Blazor.Grids.SelectionType.Multiple" AllowDragSelection />
    <GanttSplitterSettings Position="70%"> </GanttSplitterSettings>
</SfGantt>
