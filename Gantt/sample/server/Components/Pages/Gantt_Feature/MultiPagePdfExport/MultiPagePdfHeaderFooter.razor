@page "/multipagepdf-header-footer"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.DropDowns;
@using Syncfusion.PdfExport
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@using System.Net
@using System.Reflection;
@using System.Runtime.Serialization;
<SfDropDownList Width="200px" TValue="Syncfusion.Blazor.Grids.PdfHorizontalAlign" TItem="Syncfusion.Blazor.Grids.PdfHorizontalAlign"
                Placeholder="Select paper size"
                DataSource="@HeaderOptions"
                @bind-Value="SelectedAlign">
</SfDropDownList>

<SfGantt @ref="Gantt" ID="Gantt" Toolbar="@ToolbarItems" DataSource="@TaskCollection" Height="450px" Width="1500px" AllowPdfExport GridLines="Syncfusion.Blazor.Gantt.GridLine.Both">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" Dependency="Predecessor" ParentID="ParentId">
    </GanttTaskFields>
    <GanttColumns>
        <GanttColumn Field="TaskId" Width="100"></GanttColumn>
        <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
        <GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
        <GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
        <GanttColumn Field="Progress" HeaderText="Progress"></GanttColumn>
        <GanttColumn Field="Predecessor" HeaderText="Dependency"></GanttColumn>
    </GanttColumns>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
    <GanttEvents TValue="TimelineData.TaskData" OnToolbarClick="OnToolbarClick"></GanttEvents>
    <GanttEditSettings AllowEditing AllowTaskbarEditing></GanttEditSettings>
</SfGantt>


@code {
    public SfGantt<TimelineData.TaskData> Gantt { get; set; }
    private DateTime ProjectStartDate { get; set; } = new DateTime(2021, 3, 24);
    private DateTime ProjectEndDate { get; set; } = new DateTime(2021, 7, 6);
    public List<TimelineData.TaskData> TaskCollection { get; set; } = new List<TimelineData.TaskData>();

    private List<object> ToolbarItems = new List<object> {
        new ToolbarItem{ Id = "GanttPdfCustomization_PdfExport", Text = "PdfExport", PrefixIcon="e-pdfexport"},"Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll",
        "Search", "ZoomIn", "ZoomOut", "ZoomToFit", "PrevTimeSpan", "NextTimeSpan"
    };
    public async Task PdfExportHandler()
    {
        GanttPdfExportProperties exportProperties = new GanttPdfExportProperties();
        exportProperties.PageOrientation = PageOrientation.Landscape;
        PdfHeader header = new PdfHeader()
        {
            Height = 50,
            Contents = new List<PdfHeaderFooterContent>()
            {
                new PdfHeaderFooterContent(){ Type = ContentType.Text, Value = "Gantt PDF Header", Style= new PdfContentStyle(){ FontSize = 16,HAlign = SelectedAlign} },
            }
        };
        PdfFooter footer = new PdfFooter()
        {
            Height = 50,
            Contents = new List<PdfHeaderFooterContent>()
            {
                new PdfHeaderFooterContent(){ Type = ContentType.Text, Value = "Gantt PDF Footer", Style= new PdfContentStyle(){ FontSize = 16,HAlign = SelectedAlign} },
            }
        };
        exportProperties.Footer = footer;
        exportProperties.Header = header;
        await Gantt.ExportToPdfAsync(exportProperties, true);
    }
    private async Task OnToolbarClick(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (args.Item.Id == "GanttPdfCustomization_PdfExport")
        {
            await PdfExportHandler();
        }
    }
    public List<Syncfusion.Blazor.Grids.PdfHorizontalAlign> HeaderOptions =
        Enum.GetValues(typeof(Syncfusion.Blazor.Grids.PdfHorizontalAlign)).Cast<Syncfusion.Blazor.Grids.PdfHorizontalAlign>().ToList();
    public Syncfusion.Blazor.Grids.PdfHorizontalAlign SelectedAlign = Syncfusion.Blazor.Grids.PdfHorizontalAlign.Center;
    protected override void OnInitialized()
    {
        this.TaskCollection = TimelineData.TimelineRecord();
    }
