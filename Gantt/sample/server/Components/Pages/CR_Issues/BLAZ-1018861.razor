        private string _taskName = string.Empty;
        private DateTime _startDate;
        private DateTime? _endDate;
        private string _duration = string.Empty;
        private int _progress;
        private int? _parentId;
        private string? _predecessor;
        private bool _isManual;
        private bool _isExpanded = true;
        private double? _work;
        private string? _taskType;
        private string? _notes;

        public int TaskID
        {
            get => _taskID;
            set => SetProperty(ref _taskID, value);
        }

        public string TaskName
        {
            get => _taskName;
            set => SetProperty(ref _taskName, value);
        }

        public DateTime StartDate
        {
            get => _startDate;
            set => SetProperty(ref _startDate, value);
        }

        public DateTime? EndDate
        {
            get => _endDate;
            set => SetProperty(ref _endDate, value);
        }

        public string Duration
        {
            get => _duration;
            set => SetProperty(ref _duration, value);
        }

        public int Progress
        {
            get => _progress;
            set => SetProperty(ref _progress, value);
        }

        public int? ParentId
        {
            get => _parentId;
            set => SetProperty(ref _parentId, value);
        }

        public string? Predecessor
        {
            get => _predecessor;
            set => SetProperty(ref _predecessor, value);
        }

        public bool IsManual
        {
            get => _isManual;
            set => SetProperty(ref _isManual, value);
        }

        public bool IsExpanded
        {
            get => _isExpanded;
            set => SetProperty(ref _isExpanded, value);
        }

        public double? Work
        {
            get => _work;
            set => SetProperty(ref _work, value);
        }

        public string? TaskType
        {
            get => _taskType;
            set => SetProperty(ref _taskType, value);
        }

        public string? Notes
        {
            get => _notes;
            set => SetProperty(ref _notes, value);
        }

        public event PropertyChangedEventHandler? PropertyChanged;

        protected void OnPropertyChanged([CallerMemberName] string? propertyName = null)
            => PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));

        /// <summary>
        /// Sets the field to the provided value and raises PropertyChanged if the value changed.
        /// Returns true if the value was changed; otherwise false.
        /// </summary>
        protected bool SetProperty<T>(ref T field, T value, [CallerMemberName] string? propertyName = null)
        {
            if (Equals(field, value)) return false;
            field = value;
            OnPropertyChanged(propertyName);
            return true;
        }
    }

    public void OnRowSelected(RowSelectEventArgs<TaskData> args)
    {
        SelectedRowIndex = args.RowIndex;
    }

    public void CustomAdd()
    {
        var selectedTask = TaskCollection[SelectedRowIndex];
        var newTask = new TaskData
        {
            TaskID = TaskCollection.Max(t => t.TaskID) + 1,
            TaskName = "New Task",
            StartDate = DateTime.Now,
            Duration = "2",
            Progress = 0,
            ParentId = selectedTask.TaskID
        };
        if (0 <= SelectedRowIndex && SelectedRowIndex < TaskCollection.Count - 1)
        {
            TaskCollection.Insert(SelectedRowIndex, newTask);
        }
        else
        {
            TaskCollection.Add(newTask);
        }
    }

    public void CustomDelete()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }
        TaskCollection.RemoveAt(SelectedRowIndex);
    }

    public async Task SetTaskName()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }

        var task = TaskCollection[SelectedRowIndex];
        task.TaskName = "Hello World";

        await Gantt.UpdateRecordByIDAsync(task);
    }

    public async Task CustomIndent()
    {
        if (SelectedRowIndex - 1 < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }

        TaskCollection[SelectedRowIndex].ParentId = TaskCollection[SelectedRowIndex - 1].TaskID;
    }

    public async Task CustomOutdent()
    {
        if (SelectedRowIndex < 0 || SelectedRowIndex >= TaskCollection.Count)
        {
            return;
        }

        TaskCollection[SelectedRowIndex].ParentId = TaskCollection.FirstOrDefault(o => o.TaskID == TaskCollection[SelectedRowIndex].ParentId)?.ParentId;

    }

    public async Task ForceRerender()
    {
        IsGanttVisible = false;
        await Task.Delay(1);
        TaskCollection = GetTaskCollection();
        await InvokeAsync(StateHasChanged);
        IsGanttVisible = true;
    }

    public async Task DataBoundEvent()
    {
        if (this.dataReassign)
        {
            this.Gantt.ScrollIntoViewAsync(0, this.scrollIndex);
            this.dataReassign = false;
        }
    }

