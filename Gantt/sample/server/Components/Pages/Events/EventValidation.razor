    // Tracking helpers to avoid infinite recursion when reflecting complex event args
    private HashSet<object> __extractedObjects = new HashSet<object>(ReferenceEqualityComparer.Instance);
    private int __extractDepth = 0;
    private const int __MAX_EXTRACT_DEPTH = 12;

    private void ExtractProperties(object obj, string prefix = "")
    {
        // Initialize/clear tracking on top-level calls
        if (string.IsNullOrEmpty(prefix))
        {
            __extractedObjects.Clear();
            __extractDepth = 0;
        }

        if (obj == null) return;
        if (__extractDepth > __MAX_EXTRACT_DEPTH)
        {
            PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = prefix + "_Error", Value = "Max recursion depth reached" });
            return;
        }

        // Prevent infinite recursion on circular references
        if (!obj.GetType().IsValueType)
        {
            if (__extractedObjects.Contains(obj))
            {
                PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = prefix + "_CircularReference", Value = obj.GetType().Name });
                return;
            }
            __extractedObjects.Add(obj);
        }

        __extractDepth++;

        var type = obj.GetType();
        if (type == null) { __extractDepth--; return; }
        var properties = type.GetProperties();

        foreach (var prop in properties)
        {
            // Skip indexer properties (they require parameters)
            if (prop.GetIndexParameters()?.Length > 0) continue;

            // Avoid reflecting into types that may trigger JSInterop, disposed DotNetObjectReference, or heavy internal frameworks
            if (IsSkippableType(prop.PropertyType))
            {
                // Previously we recorded a "<skipped type: ...>" entry; remove that to avoid clutter.
                continue;
            }

            object value = null;
            try
            {
                value = prop.GetValue(obj);
            }
            catch (System.Reflection.TargetParameterCountException)
            {
                PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = $"{prefix}{prop.Name}", Value = "<indexed property - skipped>" });
                continue;
            }
            catch (ObjectDisposedException)
            {
                PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = $"{prefix}{prop.Name}", Value = "<disposed>" });
                continue;
            }
            catch (System.Exception ex)
            {
                PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = $"{prefix}{prop.Name}", Value = $"<error: {ex.GetType().Name}>" });
                continue;
            }

            if (value == null)
            {
                PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = $"{prefix}{prop.Name}", Value = "null" });
            }
            else if (IsSimpleType(prop.PropertyType))
            {
                PropertyItems.Last().Value.Add(new PropertyDisplayItem { Name = $"{prefix}{prop.Name}", Value = value.ToString() });
            }
            else if (typeof(System.Collections.IEnumerable).IsAssignableFrom(prop.PropertyType) && prop.PropertyType != typeof(string))
            {
                int index = 0;
                foreach (var item in (System.Collections.IEnumerable)value)
                {
                    ExtractProperties(item, $"{prefix}{prop.Name}[{index}].");
                    index++;
                }
            }
            else
            {
                ExtractProperties(value, $"{prefix}{prop.Name}.");
            }
        }

        __extractDepth--;
        if (!obj.GetType().IsValueType)
        {
            __extractedObjects.Remove(obj);
        }
    }

    // Skip types that are likely to trigger JS interop, framework internals or unsafe reflection
    private bool IsSkippableType(Type type)
    {
        if (type == null) return true;
        var fullname = type.FullName ?? string.Empty;
        var ns = type.Namespace ?? string.Empty;

        if (fullname.Contains("DotNetObjectReference") || ns.StartsWith("Microsoft.JSInterop") || ns.StartsWith("Microsoft.AspNetCore") || ns.StartsWith("Syncfusion") || ns.StartsWith("Microsoft.Extensions") || ns.StartsWith("System.Threading"))
            return true;

        if (typeof(Delegate).IsAssignableFrom(type)) return true;

        return false;
    }

    // Helper comparer to use reference equality in HashSet
    private class ReferenceEqualityComparer : IEqualityComparer<object>
    {
        public static ReferenceEqualityComparer Instance { get; } = new ReferenceEqualityComparer();
        public new bool Equals(object x, object y) => ReferenceEquals(x, y);
        public int GetHashCode(object obj) => System.Runtime.CompilerServices.RuntimeHelpers.GetHashCode(obj);
    }

    private bool IsSimpleType(Type type)
    {
        return
            type.IsPrimitive ||
            type.IsEnum ||
            type == typeof(string) ||
            type == typeof(decimal) ||
            type == typeof(DateTime) ||
            type == typeof(Guid) ||
            Nullable.GetUnderlyingType(type)?.IsPrimitive == true ||
            Nullable.GetUnderlyingType(type) == typeof(decimal) ||
            Nullable.GetUnderlyingType(type) == typeof(DateTime) ||
            Nullable.GetUnderlyingType(type) == typeof(Guid);
    }


