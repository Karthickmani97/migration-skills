<div class="p-3 container-fluid">
    <div class="row">
        <div class="col-lg-6 col-xl-6">
            <div class="row">
        <label>API</label>
        <div class="col-lg-4 col-xl-4">
            <SfAutoComplete @ref="autoCompleteInstance" TValue="string" TItem="GanttFields" Placeholder="e.g AllowFiltering" DataSource="@ganttFields" ValueChanged="AutoCompleteValueChangedHandler">
                <AutoCompleteFieldSettings Value="Text" />
            </SfAutoComplete>
        </div>
        @if (isRender)
        {
            <div class="col-lg-4 col-xl-4">
                @if (autoCompleteInstance?.Value == "DataSource")
                {
                    <SfDropDownList @ref="dropdownInstance" TValue="string" TItem="string" DataSource="@ganttDataCollections"></SfDropDownList>
                }
                else if (autoCompleteInstance?.Value == "ProjectStartDate" || autoCompleteInstance?.Value == "ProjectEndDate")
                {
                    <SfDateTimePicker @ref="dateTimeInstance" TValue="DateTime"></SfDateTimePicker>
                }
                else if (autoCompleteInstance?.Value == "Methods")
                {
                    <SfAutoComplete @ref="methodAutoCompleteInstance" TValue="string" TItem="string" Placeholder="Select a method" DataSource="@ganttMethodNames" ValueChanged="MethodValueChangedHandler">
                        <AutoCompleteFieldSettings Value="Value" />
                    </SfAutoComplete>
                }
                else if (autoCompleteInstance != null && !ganttProperties.Contains(autoCompleteInstance.Value))
                {
                    <SfAutoComplete @ref="valueAutoCompleteInstance" TValue="object" TItem="object" Placeholder="e.g true" DataSource="@formattedGanttValues">
                        <AutoCompleteFieldSettings Value="Value" />
                    </SfAutoComplete>
                }
                else
                {
                    <SfTextBox @ref="inputInstance" Placeholder="e.g Add, Delete"></SfTextBox>
                }
                @{isRender = false;}
            </div>
        }
        <div class="col-lg-4 col-xl-4">
            <SfButton @onclick="SetInputValue" CssClass="e-primary">Set Value</SfButton>

        </div>
    </div>
    <div class="row py-3">
        <label> Methods</label>
        <div class="col-lg-4 col-xl-4">
            <SfAutoComplete @ref="methodAutoCompleteInstance" TValue="string" TItem="string" Placeholder="Select a method" DataSource="@ganttMethodNames" ValueChanged="MethodValueChangedHandler">
                <AutoCompleteFieldSettings Value="Value" />
            </SfAutoComplete>
        </div>
        <div class="col-lg-4 col-xl-4">
            <SfButton @onclick="ApplyChanges" CssClass="e-info">Refresh</SfButton>
        </div>
    </div>
    <div class="row">
        <p class="py-2"><span class="fw-bold">Method Name :</span> @methodAutoCompleteInstance?.Value</p>
        <p><span class="fw-bold">Value :</span> @valueFromMethods</p>
    </div>
        </div>
        <div class="col-lg-6 col-xl-6">
            <div class="text-end">
                <p>
                    <span class="px-2"><a href="https://blazor.syncfusion.com/documentation/gantt-chart/getting-started-with-web-app" class="d-inline-block">Documentation</a></span>
                    <span class="px-2"><a href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.SfGantt-1.html?_gl=1*t5zc5g*_ga*OTE0NjU1OTYyLjE3Mzc2MjYyNjk.*_ga_41J4HFMX1J*MTczOTk0NjQ0Ny43Mi4xLjE3Mzk5NDY0NjUuMC4wLjA." class="d-inline-block">API Reference</a></span>
                </p>
            </div>
            <div class="text-end">
                <SfButton @onclick="ClearMessageHandler" CssClass="e-success">Clear</SfButton>
            </div>
            <div class="row">
                @if (ganttBaseInstance != null)
                {
                    <p>Triggeed Event : </p>
                    <p>@ganttBaseInstance.EventMessage</p>
                }
            </div>
            <div class="row">
                @if (ganttBaseInstance != null)
                {
                    <p>Error Message : </p>
                    <p>@ganttBaseInstance.ErrorMessage</p>
                }
            </div>
        </div>
    </div>    
</div>

