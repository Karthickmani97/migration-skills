<span>Unit</span>
<SfNumericTextBox @bind-Value="unitvalue" TValue="int" Placeholder="@unitvalue.ToString()" Width="100px" Min="0" Max="100"></SfNumericTextBox>
<SfButton OnClick="MethodCallingHandler">Click</SfButton>
<SfDropDownList @bind-Value="selectedEditType" DataSource="UpdateRecordByIdEditType" Placeholder="UpdateRecord" Width="150px">
    <DropDownListEvents TItem="DropdownData" TValue="string" ValueChange="HandleUpdateRecordById"></DropDownListEvents>
    <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
</SfDropDownList>
<SfButton OnClick="UpdateRecordCallingHandler">Click</SfButton>
<SfButton OnClick="ChangeWorkWeek">ChangeWorkWeek</SfButton>
<SfButton OnClick="IncludeWeekEnd">IncludeWeekEnd</SfButton>
<SfButton OnClick="ChangeWeekStart">ChangeWeekStart</SfButton>
<label class="showhide"> Project View </label>
