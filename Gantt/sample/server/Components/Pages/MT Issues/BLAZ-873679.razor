        <GanttColumn Field="Predecessor" HeaderText="Dependency"></GanttColumn>
        <GanttColumn Field="Notes" Width="100"></GanttColumn>
    </GanttColumns>
    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
     <GanttEvents TValue="TaskData" Created="Created" ></GanttEvents>
</SfGantt>

