@page "/gantt-sidebar"
@rendermode InteractiveServer
@using Syncfusion.Blazor
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Gantt
@using Microsoft.AspNetCore.Components.Web

<h3>Project Management - Gantt Chart with Sidebar Navigation</h3>

<div class="mb-3">
    <p class="text-muted">This sample demonstrates a Sidebar with project navigation. Click the hamburger menu to expand/collapse the project sidebar. Select different projects from the sidebar to view their corresponding Gantt charts.</p>
</div>

<div class="mb-3">
    <SfButton Id="toggleSidebarBtn" CssClass="e-primary" IconCss="e-icons e-menu" OnClick="ToggleSidebar">
        Toggle Projects Sidebar
    </SfButton>
    <span class="ms-3 badge bg-info">Selected: @SelectedProject</span>
</div>

<div id="main" style="position: relative; height: 650px; border: 1px solid #ddd;">
    <SfSidebar Width="280px" @bind-IsOpen="IsSidebarOpen" Target="#main" EnableDock="true" DockSize="50px" Type="SidebarType.Push">
        <div class="p-3">
            <h6 class="mb-3 text-primary">
                <i class="e-icons e-folder me-2"></i>Projects
            </h6>
            
            <div class="list-group">
                <button type="button" 
                        class="list-group-item list-group-item-action d-flex align-items-center @(SelectedProject == "Website Redesign" ? "active" : "")" 
                        @onclick='() => SelectProject("Website Redesign")'>
                    <i class="e-icons e-file-new me-2"></i>
                    <div>
                        <div class="fw-bold">Website Redesign</div>
                        <small class="text-muted">8 tasks, 45% complete</small>
                    </div>
                </button>
                
                <button type="button" 
                        class="list-group-item list-group-item-action d-flex align-items-center @(SelectedProject == "Mobile App Development" ? "active" : "")" 
                        @onclick='() => SelectProject("Mobile App Development")'>
                    <i class="e-icons e-file-new me-2"></i>
                    <div>
                        <div class="fw-bold">Mobile App Development</div>
                        <small class="text-muted">9 tasks, 60% complete</small>
                    </div>
                </button>
                
                <button type="button" 
                        class="list-group-item list-group-item-action d-flex align-items-center @(SelectedProject == "Database Migration" ? "active" : "")" 
                        @onclick='() => SelectProject("Database Migration")'>
                    <i class="e-icons e-file-new me-2"></i>
                    <div>
                        <div class="fw-bold">Database Migration</div>
                        <small class="text-muted">6 tasks, 75% complete</small>
                    </div>
                </button>
            </div>
            
            <hr class="my-3" />
            
            <div class="mt-3">
                <h6 class="text-muted small">FILTERS</h6>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" @bind="ShowCompleted" @bind:after="UpdateGanttData" id="showCompleted">
                    <label class="form-check-label small" for="showCompleted">
                        Show Completed Tasks
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" @bind="ShowInProgress" @bind:after="UpdateGanttData" id="showInProgress">
                    <label class="form-check-label small" for="showInProgress">
                        Show In-Progress Tasks
                    </label>
                </div>
            </div>
        </div>
    </SfSidebar>
    
    <div class="p-3" style="height: 100%; overflow: hidden; background-color: #f8f9fa;">
        @if (!string.IsNullOrEmpty(SelectedProject))
        {
            <div style="background-color: white; border: 1px solid #dee2e6; border-radius: 4px; padding: 10px;">
                <SfGantt DataSource="@GanttData" Height="520px" Width="1000px" 
                         Toolbar="@(new List<string>() { "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll" })">
                    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" 
                                     Duration="Duration" Progress="Progress" Child="SubTasks" Dependency="Predecessor"></GanttTaskFields>
                    <GanttEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true"></GanttEditSettings>
                    <GanttColumns>
                        <GanttColumn Field="TaskId" HeaderText="ID" Width="80"></GanttColumn>
                        <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250"></GanttColumn>
                        <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150" Format="d"></GanttColumn>
                        <GanttColumn Field="EndDate" HeaderText="End Date" Width="150" Format="d"></GanttColumn>
                        <GanttColumn Field="Duration" HeaderText="Duration" Width="100"></GanttColumn>
                        <GanttColumn Field="Progress" HeaderText="Progress %" Width="120"></GanttColumn>
                    </GanttColumns>
                </SfGantt>
            </div>
        }
        else
        {
            <div class="text-center mt-5 pt-5">
                <i class="e-icons e-folder-open" style="font-size: 64px; color: #ccc;"></i>
                <h5 class="mt-3 text-muted">No Project Selected</h5>
                <p class="text-muted">Select a project from the sidebar to view its Gantt chart</p>
            </div>
        }
    </div>
</div>

@code {
    private bool IsSidebarOpen { get; set; } = true;
    private string SelectedProject { get; set; } = "";
    private List<GanttTask> GanttData { get; set; } = new();
    private List<GanttTask> AllProjectData { get; set; } = new();
    private bool ShowCompleted { get; set; } = true;
    private bool ShowInProgress { get; set; } = true;

    protected override void OnInitialized()
    {
        SelectProject("Website Redesign");
    }

    private void ToggleSidebar(MouseEventArgs args)
    {
        IsSidebarOpen = !IsSidebarOpen;
    }

    private void SelectProject(string projectName)
    {
        SelectedProject = projectName;
        AllProjectData = GetProjectData(projectName);
        UpdateGanttData();
    }

    private void UpdateGanttData()
    {
        GanttData = AllProjectData.Where(task =>
        {
            if (task.Progress == 100 && !ShowCompleted) return false;
            if (task.Progress > 0 && task.Progress < 100 && !ShowInProgress) return false;
            return true;
        }).ToList();
    }

    private int GetTotalSubtasks()
    {
        return GanttData.Sum(task => task.SubTasks?.Count ?? 0);
    }

    private int GetCompletedPercentage()
    {
        if (!AllProjectData.Any()) return 0;
        return (int)AllProjectData.Average(task => task.Progress);
    }

