@page "/observable-sample"

@rendermode InteractiveServer

@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@using System.Collections.ObjectModel
@using System.ComponentModel
@using System.Runtime.CompilerServices
<SfButton OnClick="() => TaskCollection = GetTaskCollection()">Get Tasks</SfButton>
<SfButton OnClick="CustomIndent">Indent Task</SfButton>
<SfButton OnClick="CustomMultiIndent">Multiple Indent Task</SfButton>
<SfButton OnClick="CustomOutdent">Outdent Task</SfButton>
<SfButton OnClick="CustomMultiOutdent">Multiple Outdent Task</SfButton>
<SfButton OnClick="CustomAdd">Add below</SfButton>
<SfButton OnClick="CustomDescEdit">Edit Desc</SfButton>
<SfButton OnClick="ClearPredecessors">Clear Predecessors</SfButton>
<SfButton OnClick="ChangeData">Change DataSource</SfButton>
<SfButton OnClick="EmptyGantt">Empty Gantt</SfButton>
<SfButton OnClick="DeleteTaskRemoveAt">Delete Task (RemoveAt)</SfButton>
<SfButton OnClick="DeleteTaskRemove">Delete Task (Remove)</SfButton>
<SfButton Onclick="RemoveExpand">Remove Expand</SfButton>



<SfButton OnClick="AddTask_OC">Add (ObservableCollection)</SfButton>
<SfButton OnClick="InsertTask_OC">Insert (ObservableCollection)</SfButton>
<SfButton OnClick="RemoveTask_OC">Remove (ObservableCollection)</SfButton>
<SfButton OnClick="RemoveAt_OC">RemoveAt (ObservableCollection)</SfButton>
<SfButton OnClick="MoveTask_OC">Move (ObservableCollection)</SfButton>
<SfButton OnClick="ClearTasks_OC">Clear (ObservableCollection)</SfButton>

@if (IsGanttVisible)
{
    <SfGantt @ref="Gantt" class="gantt" ID="ScheduleBuilder" AllowRowDragAndDrop EnableContextMenu  Toolbar="@(new List<string>() { "CriticalPath","Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll", "Indent", "Outdent","Undo","Redo" })" EnableRowVirtualization
			 AllowSelection="true" ScrollToTaskbarOnClick DataSource="@TaskCollection" Height="500px" Width="100%" TreeColumnIndex="0" >
        <GanttColumns>
            <GanttColumn Field="TaskID" HeaderText="ID" Width="120">
                <Template>
                    @{
                        var data = context as TaskData;
                    }
                    <span>@($"#{data?.TaskID}")</span>
                </Template>
            </GanttColumn>
            <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250"></GanttColumn>
            <GanttColumn Field="StartDate" HeaderText="Start Date" Format="yyyy-MM-dd" Width="150"></GanttColumn>
            <GanttColumn Field="EndDate" HeaderText="End Date" Format="yyyy-MM-dd" Width="150"></GanttColumn>
            <GanttColumn Field="Duration" HeaderText="Duration" Width="80"></GanttColumn>

        </GanttColumns>
        <GanttTaskFields Id="TaskID" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId" Work="Work" TaskType="TaskType" ExpandState="IsExpanded" Dependency="Predecessor" Manual="IsManual" Notes="Notes">
        </GanttTaskFields><GanttTooltipSettings TValue="TaskData" ShowTooltipOnEditing="false"></GanttTooltipSettings>
        <GanttEditSettings AllowSchedulingOnDrag="@true" AllowAdding="@true" AllowDeleting="true" AllowEditing="@true" AllowTaskbarEditing="@true" ShowDeleteConfirmDialog="false" Mode="Syncfusion.Blazor.Gantt.EditMode.Auto">
        </GanttEditSettings>
        <GanttEvents TValue="TaskData" ContextMenuOpen="() => { }" RowSelected="OnRowSelected" DataBound="DataBoundEvent"></GanttEvents>
        <GanttSelectionSettings Mode="Syncfusion.Blazor.Grids.SelectionMode.Both" Type="Syncfusion.Blazor.Grids.SelectionType.Multiple" AllowDragSelection EnableToggle />
    </SfGantt>


}
