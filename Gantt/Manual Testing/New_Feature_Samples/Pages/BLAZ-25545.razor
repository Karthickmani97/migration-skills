    private void Expanding(Syncfusion.Blazor.TreeGrid.RowExpandingEventArgs<TaskData> args)
    {
        args.ExpandAll = true;
        timer.Reset();
        timer.Start();
    }

    private void expanded(Syncfusion.Blazor.TreeGrid.RowExpandedEventArgs<TaskData> args)
    {
        Debug.WriteLine("Time taken for Expanding: " + timer.ElapsedMilliseconds.ToString());
        Console.WriteLine("Time taken for Expadning: " + timer.ElapsedMilliseconds.ToString());
        timer.Stop();

    }

    private void collapsing(Syncfusion.Blazor.TreeGrid.RowCollapsingEventArgs<TaskData> args)
    {
        timer.Reset();
        args.CollapseAll = true;
        timer.Start();
    }

    private void collapsed(Syncfusion.Blazor.TreeGrid.RowCollapsedEventArgs<TaskData> args)
    {
        Debug.WriteLine("Time taken for Collapsing: " + timer.ElapsedMilliseconds.ToString());
        Console.WriteLine("Time taken for Collapsing: " + timer.ElapsedMilliseconds.ToString());
        timer.Stop();

    }

    private void selecting(RowSelectingEventArgs<TaskData> args)
    {
        timer.Reset();
