@page "/gantt-dashboard"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Layouts
@using Syncfusion.Blazor.Gantt

<h3>Gantt inside Dashboard Layout</h3>

<SfDashboardLayout CellSpacing="@(new double[]{8,8})">
    <DashboardPanels>
        <DashboardPanel SizeX="6" SizeY="10" Row="0" Col="0">
            <Content>
                <div class="p-2">
                    <h5>Project Timeline</h5>
                    <SfGantt DataSource="@GanttData" Height="420px" Width="1000px">
                        <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" Duration="Duration" Progress="Progress" Child="SubTasks" Dependency="Predecessor">
                        </GanttTaskFields>
                        <GanttColumns>
                            <GanttColumn Field="TaskId" HeaderText="ID" Width="80"></GanttColumn>
                            <GanttColumn Field="TaskName" HeaderText="Task Name" Width="250"></GanttColumn>
                            <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150" Format="d"></GanttColumn>
                            <GanttColumn Field="Duration" HeaderText="Duration" Width="100"></GanttColumn>
                            <GanttColumn Field="Progress" HeaderText="Progress" Width="100"></GanttColumn>
                        </GanttColumns>
                    </SfGantt>
                </div>
            </Content>
        </DashboardPanel>
        <DashboardPanel SizeX="6" SizeY="4" Row="0" Col="6">
            <Content>
                <div class="p-2">
                    <h5>Summary</h5>
                    <p>Use the left panel to view the timeline. Panels are draggable and resizable.</p>
                </div>
            </Content>
        </DashboardPanel>
    </DashboardPanels>
</SfDashboardLayout>

@code {
