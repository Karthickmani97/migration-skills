@page "/Events-virtual"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.TreeGrid
@using Syncfusion.Blazor.Layouts
<div>@message</div>
<section class="container-fluid">
    <div class="row">
        <div class="col-lg-9">
            <SfGantt DataSource="@TaskCollection" @ref="Gantt" ID="Gantt" AllowFiltering="true" AllowSorting="true" AllowRowDragAndDrop="true" 
             EnableRowVirtualization="true" EnableTimelineVirtualization="true" EnableContextMenu="true" Height="550px" Width="100%"
          Toolbar="Toolbaritems" AllowResizing="true" ShowColumnMenu="true" AllowReordering="true">

    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
                                 Dependency="Predecessor" ParentID="ParentId" Notes="Notes"></GanttTaskFields>

    <GanttEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true" Mode="Syncfusion.Blazor.Gantt.EditMode.Auto" AllowTaskbarEditing="true">
    </GanttEditSettings>

    <GanttSplitterSettings Position="50%"></GanttSplitterSettings>

     <GanttColumns>
                    <GanttColumn Field="TaskId" Width="100"></GanttColumn>
                    <GanttColumn Field="TaskName" HeaderText="Job Name" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
                    <GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
                    <GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
                    <GanttColumn Field="Duration" HeaderText="Duration"></GanttColumn>
                    <GanttColumn Field="Progress" HeaderText="Progress"></GanttColumn>
                    <GanttColumn Field="Predecessor" HeaderText="Dependency"></GanttColumn>
                </GanttColumns>
                 <SfToolbar ID="Gantt_Gantt_Toolbar">
                    <ToolbarItems>
                        <ToolbarItem Id="copyHeader" Text="Copy With Header" OnClick="CopyClip" PrefixIcon="e-copy"></ToolbarItem>
                        <ToolbarItem Id="copy" Text="Copy" OnClick="CopyClip" PrefixIcon="e-copy"></ToolbarItem>
                    </ToolbarItems>
                </SfToolbar>
               
                <GanttLabelSettings LeftLabel="TaskName" TValue="TaskData">
                </GanttLabelSettings>

     <GanttSelectionSettings Mode="SelectionMode.Row" Type="Syncfusion.Blazor.Grids.SelectionType.Multiple"></GanttSelectionSettings>

    <GanttEvents TValue="TaskData"
        BeforeCopy="BeforeCopyHandler"
         OnActionBegin="actionBegin" 
         OnActionComplete="OnActionComplete" 
         Created="CreatedHandler"
         OnLoad="LoadHandler" 
         TaskbarEdited="TaskbarEdited" 
         TaskbarEditing="TaskbarEditing" 
         RowDropping="RowDropping"
         RowDropped="RowDropped"   
         QueryChartRowInfo ="QueryChartRowInfo" 
         EndEdit="EndEdit" 
         BeforeTooltipRender="BeforeTooltipRender"
         SplitterResizeStart="Resizestart" 
         SplitterResized="Resized" 
         RowSelecting="RowSelectingHandler" 
         RowSelected="rowSelect"
         RowDeselecting="RowDeselectingHandler" 
         RowDeselected="RowDeselectHandler" 
         CellSelecting="CellSelecting"
         CellSelected="CellSelectedHandler" 
         CellDeselecting="CellDeselectingHandler" 
         CellDeselected="CellDeselectedHandler"
         OnToolbarClick="ToolbarClickHandler" 
         ColumnMenuClicked="ColumnMenuClickedHandler" 
         ContextMenuItemClicked="ContextMenuItemClickedHandler"
         ContextMenuOpen="ContextMenuOpenHandler" 
         Collapsed="Collapsed" 
         Collapsing="Collapsed" 
         Expanding="Expanding" 
         Expanded="ExpandedHandler" 
         ColumnResized="ColumnResizedHandler" 
         SplitterCreated="SplitterCreatedHandler"
         OnActionFailure="ActionFailureHandler">
     </GanttEvents>


</SfGantt>
            </div>
            <div class="col-lg-3">
                
                <table class="table table-bordered" style="border: 1px solid black">
                    <tr><th>Event</th><th>Count</th></tr>
                    <tr><td>Create</td><td>@CreateCount</td></tr>
                    <tr><td>QueryRowInfoEvent</td><td>@QueryCount</td></tr>
                    <tr><td>BeforeCopy</td><td>@CopyCount</td></tr>
                    <tr><td>LoadEvent</td><td>@LoadCount</td></tr>
                    <tr><td>TaskbarEditEvent</td><td>@TaskbarEditedCount</td></tr>
                    <tr><td>TaskbarEditingEvent</td><td>@TaskbarEditingCount</td></tr>     
                    <tr><td>RowDrappingEvent</td><td>@RowDroppingCount</td></tr>   
                    <tr><td>RowDropped</td><td>@RowDroppedCount</td></tr>
                    <tr><td>EndEdit</td><td>@EndEditCount</td></tr>
                    <tr><td>BeforeTooltipRender</td><td>@BeforeTooltipCount</td></tr>
                    <tr><td>Resizestart</td><td>@ResizestartCount</td></tr>
                    <tr><td>Resized</td><td>@ResizedCount</td></tr>      
                    <tr><td>RowSelecting</td><td>@RowSelectingCount</td></tr> 
                    <tr><td>RowSelect</td><td>@RowSelectCount</td></tr>      
                    <tr><td>RowDeselecting</td><td>@RowDeselectingCount</td></tr> 
                    <tr><td>RowDeselect</td><td>@RowDeselectCount</td></tr>
                    <tr><td>CellSelecting</td><td>@CellSelectingCount</td></tr>
                    <tr><td>CellSelected</td><td>@CellSelectedCount</td></tr>
                    <tr><td>CellDeselecting</td><td>@CellDeselectingCount</td></tr>
                    <tr><td>CellDeselected</td><td>@CellDeselectedCount</td></tr>      
                    <tr><td>ToolbarClick</td><td>@ToolbarClickCount</td></tr> 
                    <tr><td>ColumnMenuClick</td><td>@ColumnMenuClickCount</td></tr> 
                    <tr><td>ContextMenuItem</td><td>@ContextMenuItemCount</td></tr>      
                    <tr><td>ContextMenuOpen</td><td>@ContextMenuOpenCount</td></tr> 
                    <tr><td>Collapsed</td><td>@CollapsedCount</td></tr>
                    <tr><td>Collapsing</td><td>@CollapsingCount</td></tr>
                    <tr><td>Expanding</td><td>@ExpandingCount</td></tr>
                    <tr><td>Expanded</td><td>@ExpandedCount</td></tr>
                    <tr><td>ColumnResized</td><td>@ColumnResizedCount</td></tr>      
                    <tr><td>SplitterCreated</td><td>@SplitterCreatedCount </td></tr> 
                    <tr><td>actionBegin</td><td>@actionBeginCount</td></tr>      
                    <tr><td>ActionComplete </td><td>@ActionCompleteCount </td></tr>      
                </table>
            </div>
    </div>
</section>


