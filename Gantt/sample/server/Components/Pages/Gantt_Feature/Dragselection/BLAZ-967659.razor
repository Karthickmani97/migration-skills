@page "/BLAZ-967659"
@using Syncfusion.Blazor.Gantt
@rendermode InteractiveServer
@*

Replication Procedure:
    1. Run this sample.
    2. check the Events (RowDragSelectionStarting, RowDragSelectionCompleting, RowDragSelectionCompleted) are Triggred for DragSelection. Begin drag using mouse or touch on a selectable row or cell and confirm RowDragSelectionStarting is triggered.Then Release mouse or touch after dragging across multiple rows or cells and confirm RowDragSelectionCompleting is triggered before applying selection and Confirm RowDragSelectionCompleted is triggered after selection is rendered in the UI.
    3. Right-click and drag to confirm row drag-and-drop is performed.
    4. check args.Cancel = true in RowDragSelectionStarting and confirm no selection is applied and no UI errors occur. 
    5. Check args.PreventRender = true in event args and confirm no unnecessary re-renders occur.
    6. Validate event arguments.
    7. Enter edit mode on a record and perform drag selection using the left mouse button.
*@
    <SfGantt DataSource="@TaskCollection" Height="600px" AllowSelection="true" AllowRowDragAndDrop="true">
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId"></GanttTaskFields>
    <GanttSelectionSettings Mode="Syncfusion.Blazor.Grids.SelectionMode.Row" Type="Syncfusion.Blazor.Grids.SelectionType.Multiple" AllowDragSelection="true"></GanttSelectionSettings>
    <GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId"></GanttTaskFields>

    <GanttEvents RowDragSelectionStarting="OnDragSelectionStart"
                 RowDragSelectionCompleting="OnDragSelectionCompleting"
                 RowDragSelectionCompleted="OnDragSelectionCompleted"
                 TValue="TaskData">
    </GanttEvents>
      <GanttSplitterSettings Position="50%"></GanttSplitterSettings>
    <GanttEditSettings AllowEditing="true" AllowAdding="true"></GanttEditSettings>
</SfGantt>
