@page "/BLAZ-933402"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons
@using System;
<div>@messsage</div>
<SfGantt @ref="DisplayGantt"
         DataSource="@DerivedResponseStepsSorted"
         TaskMode="ScheduleMode.Auto"
         HighlightWeekends="true"
         ProjectStartDate="@ProjectDisplayStart"
         TValue="DerivedResponseStep"
         
         AllowSelection="true"
         DurationUnit="DurationUnit.Minute"
         GridLines="Syncfusion.Blazor.Gantt.GridLine.Both"
         ProjectEndDate="@ProjectDisplayEnd"
         AllowExcelExport="true"
         AllowRowDragAndDrop="true"
         AllowResizing>

    <GanttEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true" Mode="Syncfusion.Blazor.Gantt.EditMode.Auto" AllowTaskbarEditing="true"></GanttEditSettings>

    <GanttEvents RowSelected="RowSelect" RowDeselected="RowDeselect" TaskbarEditing="TaskbarEditing" TaskbarEdited="TaskbarEdited" TValue="DerivedResponseStep" OnActionFailure="ActionFailureHandler"></GanttEvents>

    <GanttTaskFields Id="Id" Name="StepName" StartDate="StartTime" EndDate="EndTime" Duration="Duration"></GanttTaskFields>

    <GanttTaskbarSettings AllowTaskbarDragAndDrop="true"></GanttTaskbarSettings>

    <GanttTimelineSettings UpdateTimescaleView="false" TimelineUnitSize="60">

        <GanttTopTierSettings Unit="TimelineViewMode.Hour" ></GanttTopTierSettings>

        <GanttBottomTierSettings Unit="TimelineViewMode.Minutes" ></GanttBottomTierSettings>



    </GanttTimelineSettings>

    <GanttDayWorkingTimeCollection>

        <GanttDayWorkingTime From="0" To="24"></GanttDayWorkingTime>

    </GanttDayWorkingTimeCollection>

    <GanttSplitterSettings ColumnIndex="3"></GanttSplitterSettings>

    <SfToolbar @ref="GanttToolbar">

        <ToolbarItems>

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    @* Add *@

                    <SfButton IconCss="fa-solid fa-plus fa-xs" Disabled="false" CssClass="toolbarbutton">Add</SfButton>

                </Template>

            </ToolbarItem>

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    @* Delete *@

                    <SfButton IconCss="fa-solid fa-trash fa-xs" Disabled="false" CssClass="toolbarbutton">Delete</SfButton>

                </Template>

            </ToolbarItem>

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    @* Save *@

                    <SfButton IconCss="fa-solid fa-cloud-upload fa-xs" Disabled="false" CssClass="toolbarbutton">Save</SfButton>

                </Template>

            </ToolbarItem>

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    @* Cancel *@

                    <SfButton IconCss="far fa-undo fa-xs" CssClass="toolbarbutton" Disabled="false">Cancel</SfButton>

                </Template>

            </ToolbarItem>

            @* =================================== *@

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    @* ZoomIn *@

                    <SfButton IconCss="fa-solid fa-magnifying-glass-plus fa-xs" style="margin-left:20px" CssClass="toolbarbutton">Zoom In</SfButton>

                </Template>

            </ToolbarItem>

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    <SfButton IconCss="fa-solid fa-magnifying-glass-minus fa-xs" CssClass="toolbarbutton">Zoom Out</SfButton>

                </Template>

            </ToolbarItem>

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    <SfButton IconCss="fa-solid fa-expand fa-xs" CssClass="toolbarbutton">Zoom To Fit</SfButton>

                </Template>

            </ToolbarItem>

            @* ================================ *@

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    @* XLSX *@

                    <SfButton IconCss="fa-solid fa-file-xls fa-xs" style="margin-left:20px" CssClass="toolbarbutton">Export</SfButton>

                </Template>

            </ToolbarItem>

            <ToolbarItem Type="ItemType.Button">

                <Template>

                    @* CSV *@

                    <SfButton IconCss="fa-solid fa-file-csv fa-xs" CssClass="toolbarbutton">Export</SfButton>

                </Template>

            </ToolbarItem>

        </ToolbarItems>

    </SfToolbar>

    <GanttColumns>

        <GanttColumn Field="DerivedSequence" Visible="false"></GanttColumn>

        <GanttColumn Field="RowIndex" HeaderText="Step #" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Width="70"></GanttColumn>

        <GanttColumn Field="StepName" HeaderText="Activity"></GanttColumn>

        <GanttColumn Field="Duration" HeaderText="Duration"></GanttColumn>

        <GanttColumn Field="StartTime" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" HeaderText="Start Time" Width="145px" AllowEditing="false" Type="Syncfusion.Blazor.Grids.ColumnType.DateTime" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit">

            <HeaderTemplate>

                <div>Start Time</div>

                <div> </div>

            </HeaderTemplate>

            <Template>

                @{

                    DerivedResponseStep? derivedResponseStep = (context as DerivedResponseStep);

                    <div style="font-size:smaller">@derivedResponseStep.StartTime.ToString("MMM d, yyyy h:mm tt")</div>

                }

            </Template>

        </GanttColumn>

        <GanttColumn Field="EndTime" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" HeaderText="End Time" Width="145px" AllowEditing="false" Type="Syncfusion.Blazor.Grids.ColumnType.DateTime" EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit">

            <HeaderTemplate>

                <div style="vertical-align:text-top">End Time</div>

                <div> </div>

            </HeaderTemplate>

            <Template>

                @{

                    DerivedResponseStep? derivedResponseStep = (context as DerivedResponseStep);

                    <div style="font-size:smaller">@derivedResponseStep.EndTime.ToString("MMM d, yyyy h:mm tt")</div>

                }

            </Template>

        </GanttColumn>

        <GanttColumn Field="Id" Visible="false" IsPrimaryKey="true"></GanttColumn>

    </GanttColumns>

</SfGantt>
@code {
    public SfGantt<DerivedResponseStep> DisplayGantt { get; set; }
    public SfToolbar GanttToolbar { get; set; }
    public string messsage{ get; set; }
    public DateTime ProjectDisplayStart = new DateTime(2023, 11, 29, 23, 00, 00);
    public DateTime ProjectDisplayEnd = new DateTime(2023, 12, 02, 23, 00, 00);
    public List<DerivedResponseStep> DerivedResponseStepsSorted = new List<DerivedResponseStep>()
    {
        new DerivedResponseStep() { Id = 1, StepName = "Step 1", StartTime = DateTime.Parse("2023-11-30T00:30:00"), EndTime = DateTime.Parse("2023-11-30T01:00:00"), Duration="30", RowIndex = "1" },
        new DerivedResponseStep(){ Id = 2, StepName = "Step 2", StartTime = DateTime.Parse("2023-11-30T00:30:00"), EndTime = DateTime.Parse("2023-11-30T01:00:00"), Duration="30", RowIndex = "2"},
        new DerivedResponseStep(){ Id = 3, StepName = "Step 3", StartTime = DateTime.Parse("2023-11-30T01:00:00"), EndTime = DateTime.Parse("2023-11-30T01:30:00"), Duration="30", RowIndex = "3"},
        new DerivedResponseStep(){ Id = 4, StepName = "Step 4", StartTime = DateTime.Parse("2023-11-30T01:30:00"), EndTime = DateTime.Parse("2023-11-30T02:00:00"), Duration="30", RowIndex = "4"}

    };
    public class DerivedResponseStep
    {
        public int Id { get; set; }
        public string DerivedSequence { get; set; }
        public string RowIndex { get; set; }
        public string StepName { get; set; }
        public DateTime StartTime { get; set; }
        public DateTime EndTime { get; set; }
        public string Duration { get; set; }
    }
    private void RowSelect(RowSelectEventArgs<DerivedResponseStep> args)
    {

    }
    public void ActionFailureHandler(Syncfusion.Blazor.Grids.FailureEventArgs args)
    {
       messsage += " OnAction failure Event triggered";
    }
    private void RowDeselect(RowDeselectEventArgs<DerivedResponseStep> args)
    {

    }
    private void TaskbarEditing(TaskbarEditingEventArgs<DerivedResponseStep> args)
    {

    }
    private void TaskbarEdited(TaskbarEditedEventArgs<DerivedResponseStep> args)
    {

    }
}



