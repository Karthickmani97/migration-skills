@page "/gantt-adaptor-custom"
@rendermode InteractiveServer
@using Syncfusion.Blazor
@using Syncfusion.Blazor.Gantt;
@using Syncfusion.Blazor.Data;
@using Syncfusion.Blazor.Grids;
@using System.ComponentModel.DataAnnotations;
<SfGantt EnableContextMenu="true" AllowReordering="true" RenderBaseline="true" TValue="TaskData" AllowSorting="true" AllowFiltering="true" Height="450px" Width="1400px" HighlightWeekends="true"
                     Toolbar="@(new List<string>(){ "Add", "Edit", "Update", "Delete", "Cancel", "ExpandAll", "CollapseAll","Indent","Outdent"})"
                     AllowSelection="true"  TreeColumnIndex="1">
    <SfDataManager AdaptorInstance="@typeof(CustomAdaptor)" Adaptor="Adaptors.CustomAdaptor"></SfDataManager>

    <GanttTaskFields Id="TaskId"
                     Name="ActivityName"
                     StartDate="StartDate"
                     EndDate="EndDate"
                     BaselineStartDate="BaselineStartDate"
                     BaselineEndDate="BaselineEndDate"
                     Duration="Duration"
                     Progress="Progress"
                     Work="Work"
                     Notes="Notes"
                     Dependency="Predecessor"
                     TaskType="TaskType"
                     ParentID="ParentId">
    </GanttTaskFields>

    <GanttColumns>
        <GanttColumn Field="TaskId" HeaderText="Task ID" IsPrimaryKey="true" Width="80"
                     TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right">
        </GanttColumn>

        <GanttColumn Field="ActivityName" HeaderText="Task Name" Width="160" />

        <GanttColumn Field="Duration" HeaderText="Duration" Width="100"
                     TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right">
        </GanttColumn>

        <GanttColumn Field="Predecessor" HeaderText="Dependency" Width="100"
                     TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right">
        </GanttColumn>

        <GanttColumn Field="Progress" HeaderText="Progress" Width="100"
                     EditType="Syncfusion.Blazor.Grids.EditType.NumericEdit"
                     TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right">
        </GanttColumn>

        <GanttColumn Field="Email" HeaderText="Email" Width="200"
                     EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit">
        </GanttColumn>

        <GanttColumn Field="StartDate" HeaderText="Start Date" Width="150" Format="d"
                     EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit">
        </GanttColumn>

        <GanttColumn Field="EndDate" HeaderText="End Date" Width="150" Format="g"
                     EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit">
        </GanttColumn>

        <GanttColumn Field="Work" HeaderText="Work">
        </GanttColumn>

        <GanttColumn Field="BaselineStartDate" HeaderText="Baseline Start" Width="150" Format="d"
                     EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit" />

        <GanttColumn Field="BaselineEndDate" HeaderText="Baseline End" Width="150" Format="d"
                     EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit" />

        <GanttColumn Field="Username" HeaderText="Username" Width="150"
                     EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit">
        </GanttColumn>

        <GanttColumn Field="Password" HeaderText="Password" Width="150"
                     EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit">
        </GanttColumn>

        <GanttColumn Field="Website" HeaderText="Website" Width="200"
                     EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit">
        </GanttColumn>

        <GanttColumn Field="CustomData" HeaderText="Custom Data (String)" Width="200"
                     EditType="Syncfusion.Blazor.Grids.EditType.DefaultEdit">
        </GanttColumn>

        <GanttColumn Field="Notes" HeaderText="Notes" />

        <GanttColumn Field="TaskType" HeaderText="Task Type" Width="120"
                     EditType="Syncfusion.Blazor.Grids.EditType.DropDownEdit">
        </GanttColumn>

        <GanttColumn Field="ProjectBudget" HeaderText="Project Budget" Width="150"
                     EditType="Syncfusion.Blazor.Grids.EditType.NumericEdit" Format="C2" />

        <GanttColumn Field="ReviewDate" HeaderText="Review Date" Width="150" Format="d"
                     EditType="Syncfusion.Blazor.Grids.EditType.DateTimePickerEdit" />
    </GanttColumns>
    <GanttLabelSettings LeftLabel="ActivityName" TValue="TaskData">
    </GanttLabelSettings>
    <GanttSegmentFields PrimaryKey="id" ForeignKey="TaskId" StartDate="StartDate" EndDate="EndDate" Duration="Duration" TValue="TaskData" TSegments="SegmentModel" DataSource="SegmentCollection"></GanttSegmentFields>
    <GanttSplitterSettings Position="40%"> </GanttSplitterSettings>
    <GanttEditSettings AllowEditing="true" AllowAdding="true" AllowDeleting="true" AllowTaskbarEditing="true"></GanttEditSettings>
</SfGantt>

@code {
    public static SfGantt<TaskData>? Gantt { get; set; }
    public static List<TaskData> GanttData { get; set; } = new List<TaskData>();
    private List<SegmentModel> SegmentCollection { get; set; } = new List<SegmentModel>();
    public class SegmentModel
    {
        public int id { get; set; }
        public int TaskId { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }

        [Required(ErrorMessage = "Need Duration")]
        [Range(10, 365, ErrorMessage = "Duration must be between 10 and 365 days.")]
        public double? Duration { get; set; }

    }
    
    public class TaskData
    {
        public int TaskId { get; set; }

        [CustomValidationActivityName]
        public string ActivityName { get; set; } = string.Empty;

        public int? Duration { get; set; }

        public string Predecessor { get; set; } = string.Empty;

        [CustomValidationProgress]
        public int Progress { get; set; }

        [CustomValidationWork]
        public int Work { get; set; }

        // Present in your model; no validation rules specified
        public int? ParentId { get; set; }

        [CustomValidationEmail]
        public string? Email { get; set; } = string.Empty;

        [CustomValidationUsername]
        public string? Username { get; set; } = string.Empty;

        [CustomValidationPassword]
        public string? Password { get; set; } = string.Empty;

        [CustomValidationWebsite]
        public string? Website { get; set; } = string.Empty;

        [CustomValidationCustomData]
        public string? CustomData { get; set; } = string.Empty;

        [CustomValidationNotes]
        public string? Notes { get; set; } = string.Empty;

        [CustomValidationTaskType]
        public string? TaskType { get; set; } = string.Empty;

        [CustomValidationStartDate]
        public DateTime? StartDate { get; set; }

        [CustomValidationEndDate]
        public DateTime? EndDate { get; set; }

        [CustomValidationBaselineStartDate]
        public DateTime? BaselineStartDate { get; set; }

        [CustomValidationBaselineEndDate]
        public DateTime? BaselineEndDate { get; set; }

        [CustomValidationReviewDate]
        public DateTime? ReviewDate { get; set; }

        [CustomValidationProjectBudget]
        public decimal ProjectBudget { get; set; }

        public List<TaskData> SubTasks { get; set; }
    }
    public class CustomValidationActivityName : ValidationAttribute
    {
        protected override ValidationResult IsValid(object value, ValidationContext validationContext)
        {
            var str = value as string;
            if (string.IsNullOrWhiteSpace(str))
                return new ValidationResult("Task Name is required.");
            if (str.Length < 5 || str.Length > 10)
                return new ValidationResult("Task Name must be between 5 and 10 characters.");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationProgress : ValidationAttribute
    {
        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            if (value == null)
                return new ValidationResult("Progress is required.");
            var v = (int)value;
            if (v < 5)
                return new ValidationResult("Progress must be greater than 5");
            if (v > 50)
                return new ValidationResult("Progress must be lesser than 50");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationWork : ValidationAttribute
    {
        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            if (value == null)
                return new ValidationResult("Work is required.");
            var v = (int)value;
            if (v < 5 || v > 200)
                return new ValidationResult("Work must be between 5 and 200.");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationEmail : ValidationAttribute
    {
        private static readonly EmailAddressAttribute EmailValidator = new EmailAddressAttribute();

        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            var str = value as string;
            if (string.IsNullOrWhiteSpace(str))
                return new ValidationResult("Email is required.");
            if (!EmailValidator.IsValid(str))
                return new ValidationResult("Invalid Email format.");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationUsername : ValidationAttribute
    {
        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            var str = value as string;
            if (string.IsNullOrWhiteSpace(str))
                return new ValidationResult("Username is required.");
            if (!System.Text.RegularExpressions.Regex.IsMatch(str, @"^[a-zA-Z0-9_]*$"))
                return new ValidationResult("Username can only contain letters, numbers, and underscores.");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationPassword : ValidationAttribute
    {
        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            var str = value as string ?? string.Empty;
            if (string.IsNullOrEmpty(str))
                return new ValidationResult("Password required");
            // Not required, only length constraints
            if (str.Length > 0 && (str.Length < 8 || str.Length > 20))
                return new ValidationResult("Password must be between 8 and 20 characters.");
            return ValidationResult.Success;
        }
    }

    public class CustomValidationWebsite : ValidationAttribute
    {
        private static readonly UrlAttribute UrlValidator = new UrlAttribute();

        protected override ValidationResult IsValid(object value, ValidationContext context)
        {
            var str = value as string;
            if (string.IsNullOrWhiteSpace(str))
                return new ValidationResult("Website is required.");
