                        <GanttColumn Field="ID" HeaderText="TaskId" Width="100" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center"></GanttColumn>
                        <GanttColumn Field="TaskName" HeaderText="TaskName"></GanttColumn>
