<button id="Scroll_column" class="btn btn-primary" @onclick="Scroll">Scroll</button>
<button id="Add_column" @onclick="@AddColumns">Add Columns</button>
<button id="Remove_column" @onclick="@RemoveColumns">Remove Columns</button>
<button id="Hide_column" @onclick="@HideColumns">Hide Columns</button>
<button id="Show_column" @onclick="@ShowColumns">Show Columns</button>
